[
  {
    "Type": "DataTable",
    "Name": "StoryTextDataTable_Zh_Hans",
    "Flags": "RF_Public | RF_Standalone | RF_Transactional | RF_WasLoaded | RF_LoadCompleted",
    "Class": "UScriptClass'DataTable'",
    "Properties": {
      "RowStruct": {
        "ObjectName": "Class'GameDataTableRow_GameText'",
        "ObjectPath": "/Script/Abrams"
      },
      "ImportKeyField": "Id"
    },
    "Rows": {
      "CHAP_0001": {
        "ID": "CHAP_0001",
        "Text": "咒胎戴天 前篇"
      },
      "CHAP_0002": {
        "ID": "CHAP_0002",
        "Text": "咒胎戴天 后篇"
      },
      "CHAP_0003": {
        "ID": "CHAP_0003",
        "Text": "幼鱼与逆罚"
      },
      "CHAP_0004": {
        "ID": "CHAP_0004",
        "Text": "京都姊妹校交流会"
      },
      "CHAP_0005": {
        "ID": "CHAP_0005",
        "Text": "起首雷同"
      },
      "CHAP_0006": {
        "ID": "CHAP_0006",
        "Text": "咒术回战0"
      },
      "CHAP_0007": {
        "ID": "CHAP_0007",
        "Text": "EX战"
      },
      "CHAP_0008": {
        "ID": "CHAP_0008",
        "Text": "怀玉・玉折"
      },
      "CHAP_0009": {
        "ID": "CHAP_0009",
        "Text": "涩谷事变"
      },
      "STMSN_01000M": {
        "ID": "STMSN_01000M",
        "Text": "「最强」的传授"
      },
      "STMSN_01000M_EXPLANATION": {
        "ID": "STMSN_01000M_EXPLANATION",
        "Text": "认知到自己的弱点\n少年决心要变强……\n追寻「正确的死亡」"
      },
      "STMSN_01001M": {
        "ID": "STMSN_01001M",
        "Text": "两面宿傩"
      },
      "STMSN_01001M_EXPLANATION": {
        "ID": "STMSN_01001M_EXPLANATION",
        "Text": "封印被解开的凶恶咒物招来诅咒\n「只要我有咒力就可以了吧！」\n虎杖为了能迎战诅咒而……"
      },
      "STMSN_01002M": {
        "ID": "STMSN_01002M",
        "Text": "秘密死刑"
      },
      "STMSN_01002M_EXPLANATION": {
        "ID": "STMSN_01002M_EXPLANATION",
        "Text": "特级咒术师「五条悟」确认宿傩寄宿体内\n便要求虎杖放出宿傩……\n最强对上最恐怖的战斗即将开始！"
      },
      "STMSN_01003M": {
        "ID": "STMSN_01003M",
        "Text": "遗言"
      },
      "STMSN_01003M_EXPLANATION": {
        "ID": "STMSN_01003M_EXPLANATION",
        "Text": "是要现在就死\n还是吃下宿傩所有的手指再死\n虎杖想着祖父的遗言，做出决定……"
      },
      "STMSN_01004M": {
        "ID": "STMSN_01004M",
        "Text": "为了自己"
      },
      "STMSN_01004M_EXPLANATION": {
        "ID": "STMSN_01004M_EXPLANATION",
        "Text": "被问到来高专的理由，虎杖细细思索\n祖父的遗言……只有自己办得到的事情……\n最终他得出的结论是……！！"
      },
      "STMSN_01005M": {
        "ID": "STMSN_01005M",
        "Text": "铁娘子"
      },
      "STMSN_01005M_EXPLANATION": {
        "ID": "STMSN_01005M_EXPLANATION",
        "Text": "钉崎与虎杖接受祓除咒灵的考试！\n领队的五条其实有所意图……"
      },
      "STMSN_01006M": {
        "ID": "STMSN_01006M",
        "Text": "开始"
      },
      "STMSN_01006M_EXPLANATION": {
        "ID": "STMSN_01006M_EXPLANATION",
        "Text": "咒灵抓小孩当人质\n钉崎被迫陷入攸关人命的取舍\n纠结到最后，她的选择是……"
      },
      "STMSN_01007M": {
        "ID": "STMSN_01007M",
        "Text": "咒胎戴天"
      },
      "STMSN_01007M_EXPLANATION": {
        "ID": "STMSN_01007M_EXPLANATION",
        "Text": "少年院内发现咒胎\n从伊地知口中听闻现况的虎杖等人\n赶赴救助幸存者但院内却早已……"
      },
      "STMSN_01008M": {
        "ID": "STMSN_01008M",
        "Text": "逃出"
      },
      "STMSN_01008M_EXPLANATION": {
        "ID": "STMSN_01008M_EXPLANATION",
        "Text": "不慎落单于陌生环境的钉崎\n感受到附近出现异常的气息……\n「怎么会……这么多！！」"
      },
      "STMSN_01009M": {
        "ID": "STMSN_01009M",
        "Text": "诅咒之王"
      },
      "STMSN_01009M_EXPLANATION": {
        "ID": "STMSN_01009M_EXPLANATION",
        "Text": "生死关头之际虎杖收到伏黑的暗号\n本应是宿傩对抗特级咒灵的作战，然而……\n「走，去宰了那些小鬼头。」"
      },
      "STMSN_01010M": {
        "ID": "STMSN_01010M",
        "Text": "理由"
      },
      "STMSN_01010M_EXPLANATION": {
        "ID": "STMSN_01010M_EXPLANATION",
        "Text": "在外围等待虎杖的伏黑只等来了宿傩\n「我想到了现在能做什么……」\n暂时夺下身体主导权的宿傩打算……"
      },
      "STMSN_02011M": {
        "ID": "STMSN_02011M",
        "Text": "雨后"
      },
      "STMSN_02011M_EXPLANATION": {
        "ID": "STMSN_02011M_EXPLANATION",
        "Text": "伏黑向钉崎转达了虎杖的遗言\n「自己死了就没意义了啊……」\n此时一道身影接近正感伤虎杖之死的两人……"
      },
      "STMSN_02012M": {
        "ID": "STMSN_02012M",
        "Text": "企图"
      },
      "STMSN_02012M_EXPLANATION": {
        "ID": "STMSN_02012M_EXPLANATION",
        "Text": "漏瑚问起战胜咒术师的方法\n夏油回道……\n「只要满足2个条件就能赢喔。」"
      },
      "STMSN_02013M": {
        "ID": "STMSN_02013M",
        "Text": "束缚"
      },
      "STMSN_02013M_EXPLANATION": {
        "ID": "STMSN_02013M_EXPLANATION",
        "Text": "本该死去的虎杖和宿傩大眼瞪小眼\n「我们还没死呢」\n宿傩向他提出复活的条件，可是……"
      },
      "STMSN_02014M": {
        "ID": "STMSN_02014M",
        "Text": "某个梦想"
      },
      "STMSN_02014M_EXPLANATION": {
        "ID": "STMSN_02014M_EXPLANATION",
        "Text": "五条告诉伊地知自己的梦想……没想到\n「五五五五五条先生！！」\n伊地知究竟目击到什么！？"
      },
      "STMSN_02015M": {
        "ID": "STMSN_02015M",
        "Text": "电影鉴赏"
      },
      "STMSN_02015M_EXPLANATION": {
        "ID": "STMSN_02015M_EXPLANATION",
        "Text": "认知到自己弱点的虎杖\n接受五条提出的咒力控制修行\n「我想变强，快教我怎样成为『最强』」"
      },
      "STMSN_02016M": {
        "ID": "STMSN_02016M",
        "Text": "迈进"
      },
      "STMSN_02016M_EXPLANATION": {
        "ID": "STMSN_02016M_EXPLANATION",
        "Text": "钉崎被熊猫狠狠抛到天上……\n「唔……再来！！」\n大家朝交流会更进一步！"
      },
      "STMSN_02017M": {
        "ID": "STMSN_02017M",
        "Text": "迈进－贰－"
      },
      "STMSN_02017M_EXPLANATION": {
        "ID": "STMSN_02017M_EXPLANATION",
        "Text": "伏黑思索着咒具的使用及携带方式\n「你那个时候为什么逃走了」\n他想起当初宿傩的质问，有了灵感……"
      },
      "STMSN_02018S": {
        "ID": "STMSN_02018S",
        "Text": "迈进－参－"
      },
      "STMSN_02018S_EXPLANATION": {
        "ID": "STMSN_02018S_EXPLANATION",
        "Text": "不是什么时候都能一对一战斗……\n在少年院吃到苦头的钉崎\n找真希、狗卷一起进行特训！"
      },
      "STMSN_02019S": {
        "ID": "STMSN_02019S",
        "Text": "迈进－肆－"
      },
      "STMSN_02019S_EXPLANATION": {
        "ID": "STMSN_02019S_EXPLANATION",
        "Text": "迎战庞大的敌人……\n曾因巨形咒灵而身负重伤的伏黑\n与熊猫开始特训！"
      },
      "STMSN_02020S": {
        "ID": "STMSN_02020S",
        "Text": "迈进－伍－"
      },
      "STMSN_02020S_EXPLANATION": {
        "ID": "STMSN_02020S_EXPLANATION",
        "Text": "五条出现在特训后疲惫不堪\n正在休息的伏黑、钉崎的面前\n笑着要求他们……"
      },
      "STMSN_02021M": {
        "ID": "STMSN_02021M",
        "Text": "急袭"
      },
      "STMSN_02021M_EXPLANATION": {
        "ID": "STMSN_02021M_EXPLANATION",
        "Text": "移动中的五条突然遭遇奇袭！\n「你是什么人？」\n来袭者到底有何目的……"
      },
      "STMSN_02022M": {
        "ID": "STMSN_02022M",
        "Text": "领域"
      },
      "STMSN_02022M_EXPLANATION": {
        "ID": "STMSN_02022M_EXPLANATION",
        "Text": "具现化生得领域「领域展开」\n被视为咒术战最高形式的战斗即将开始……"
      },
      "STMSN_02023M": {
        "ID": "STMSN_02023M",
        "Text": "像个诅咒"
      },
      "STMSN_02023M_EXPLANATION": {
        "ID": "STMSN_02023M_EXPLANATION",
        "Text": "夏油对着受花御帮助而顺利逃生的漏瑚\n仔细说明战胜五条作战计画\n此时又一全新咒灵现身……"
      },
      "STMSN_02024M": {
        "ID": "STMSN_02024M",
        "Text": "咒力"
      },
      "STMSN_02024M_EXPLANATION": {
        "ID": "STMSN_02024M_EXPLANATION",
        "Text": "滥用咒术的「诅咒师」\n五条传授虎杖该如何应对这群人的同时\n也察觉到虎杖某个习惯……"
      },
      "STMSN_02025M": {
        "ID": "STMSN_02025M",
        "Text": "跑腿"
      },
      "STMSN_02025M_EXPLANATION": {
        "ID": "STMSN_02025M_EXPLANATION",
        "Text": "在特训中附加处罚的真希、伏黑和钉崎\n他们尚未得知有一群人\n正悄悄来访高专……"
      },
      "STMSN_02026M": {
        "ID": "STMSN_02026M",
        "Text": "无聊"
      },
      "STMSN_02026M_EXPLANATION": {
        "ID": "STMSN_02026M_EXPLANATION",
        "Text": "特地来评鉴伏黑和钉崎的东堂问道\n「你喜欢什么类型的女人」\n伏黑勉为其难地回答……可是！"
      },
      "STMSN_02027S": {
        "ID": "STMSN_02027S",
        "Text": "激励"
      },
      "STMSN_02027S_EXPLANATION": {
        "ID": "STMSN_02027S_EXPLANATION",
        "Text": "被真依教训一顿的钉崎迫切地想提升实力！\n「最后能相信的果然还是自己的肉体……」\n钉崎找来狗卷和熊猫……"
      },
      "STMSN_02028M": {
        "ID": "STMSN_02028M",
        "Text": "忠告"
      },
      "STMSN_02028M_EXPLANATION": {
        "ID": "STMSN_02028M_EXPLANATION",
        "Text": "保守派领袖乐岩寺与五条会面\n开始谈判虎杖的事情\n以及今后咒术界的发展……"
      },
      "STMSN_03029M": {
        "ID": "STMSN_03029M",
        "Text": "幼鱼与逆罚"
      },
      "STMSN_03029M_EXPLANATION": {
        "ID": "STMSN_03029M_EXPLANATION",
        "Text": "电影院内发现3名高中生的畸形尸体\n与被害者有「牵连」的少年\n与作案咒灵接触……"
      },
      "STMSN_03030M": {
        "ID": "STMSN_03030M",
        "Text": "离职咒术师"
      },
      "STMSN_03030M_EXPLANATION": {
        "ID": "STMSN_03030M_EXPLANATION",
        "Text": "虎杖与领队的七海一同\n调查畸形死亡案件\n两人一路追踪案发现场的残秽……"
      },
      "STMSN_03031M": {
        "ID": "STMSN_03031M",
        "Text": "径庭拳"
      },
      "STMSN_03031M_EXPLANATION": {
        "ID": "STMSN_03031M_EXPLANATION",
        "Text": "虎杖施展出在五条特训下学会的新招式\n另一方面，七海也有所发现……"
      },
      "STMSN_03032M": {
        "ID": "STMSN_03032M",
        "Text": "灵魂的形状"
      },
      "STMSN_03032M_EXPLANATION": {
        "ID": "STMSN_03032M_EXPLANATION",
        "Text": "顺利锁定真人的潜伏地点\n七海独自前往处理\n没想到现场却出现大量的……"
      },
      "STMSN_03033M": {
        "ID": "STMSN_03033M",
        "Text": "调查"
      },
      "STMSN_03033M_EXPLANATION": {
        "ID": "STMSN_03033M_EXPLANATION",
        "Text": "与前来调查的虎杖聊过后吉野思索着\n虎杖的言词……自己对妈妈的感情……\n但背地里真人与同伙也伸出魔掌……"
      },
      "STMSN_03034M": {
        "ID": "STMSN_03034M",
        "Text": "加班时间"
      },
      "STMSN_03034M_EXPLANATION": {
        "ID": "STMSN_03034M_EXPLANATION",
        "Text": "原本一昧防御真人猛烈攻势的七海\n终于解除对自己的限制\n开始全力反击！"
      },
      "STMSN_03035M": {
        "ID": "STMSN_03035M",
        "Text": "给将来的你"
      },
      "STMSN_03035M_EXPLANATION": {
        "ID": "STMSN_03035M_EXPLANATION",
        "Text": "母亲被咒杀的吉野\n为了找出犯人袭击里樱高中\n虎杖虽然出面想收拾善后……"
      },
      "STMSN_03036M": {
        "ID": "STMSN_03036M",
        "Text": "天敌"
      },
      "STMSN_03036M_EXPLANATION": {
        "ID": "STMSN_03036M_EXPLANATION",
        "Text": "七海赶到陷入困境的虎杖身边\n并察觉到真人状态不太对劲\n于是两人开始猛烈反击！"
      },
      "STMSN_03037M": {
        "ID": "STMSN_03037M",
        "Text": "成长"
      },
      "STMSN_03037M_EXPLANATION": {
        "ID": "STMSN_03037M_EXPLANATION",
        "Text": "面对改造人不停防守的虎杖\n「杀……了我……」\n听见对方开口求死……"
      },
      "STMSN_03038M": {
        "ID": "STMSN_03038M",
        "Text": "明天见"
      },
      "STMSN_03038M_EXPLANATION": {
        "ID": "STMSN_03038M_EXPLANATION",
        "Text": "在七海危急时虎杖及时赶到\n两人打算速战速决再次展开猛烈攻势\n不料真人却还有「杀手锏」……"
      },
      "STMSN_03039M": {
        "ID": "STMSN_03039M",
        "Text": "反省"
      },
      "STMSN_03039M_EXPLANATION": {
        "ID": "STMSN_03039M_EXPLANATION",
        "Text": "败逃的真人反省这次的失误\n与夏油讨论起今后的作战计画……"
      },
      "STMSN_03040S": {
        "ID": "STMSN_03040S",
        "Text": "姊妹淘聚会"
      },
      "STMSN_03040S_EXPLANATION": {
        "ID": "STMSN_03040S_EXPLANATION",
        "Text": "某次休假\n不知为何心情很差的钉崎来找真希\n一切原因要追溯到她出门逛街的时候……"
      },
      "STMSN_03041S": {
        "ID": "STMSN_03041S",
        "Text": "前辈与晚辈"
      },
      "STMSN_03041S_EXPLANATION": {
        "ID": "STMSN_03041S_EXPLANATION",
        "Text": "「回去以后好好休息吧」\n七海顺利在时间内完成任务\n不料五条却找上门有事相求"
      },
      "STMSN_03042S": {
        "ID": "STMSN_03042S",
        "Text": "熊猫与熊猫"
      },
      "STMSN_03042S_EXPLANATION": {
        "ID": "STMSN_03042S_EXPLANATION",
        "Text": "某次休假\n伏黑、狗卷和熊猫本来打算一起\n「去买新出的熊猫周边！」可是……"
      },
      "STMSN_03043S": {
        "ID": "STMSN_03043S",
        "Text": "前辈与晚辈－贰－"
      },
      "STMSN_03043S_EXPLANATION": {
        "ID": "STMSN_03043S_EXPLANATION",
        "Text": "「哎呀正好遇到你们～」\n被七海婉拒「恳求」的五条\n来到正在特训的钉崎、真希面前……"
      },
      "STMSN_04044M": {
        "ID": "STMSN_04044M",
        "Text": "惊喜"
      },
      "STMSN_04044M_EXPLANATION": {
        "ID": "STMSN_04044M_EXPLANATION",
        "Text": "时间来到京都姊妹校交流会开办当天！\n这天也是告诉大家虎杖活着的日子。\n究竟大家会有什么反应呢……"
      },
      "STMSN_04045M": {
        "ID": "STMSN_04045M",
        "Text": "作战会议"
      },
      "STMSN_04045M_EXPLANATION": {
        "ID": "STMSN_04045M_EXPLANATION",
        "Text": "被众人以为牺牲的虎杖变成额外战力……\n真希正困扰该如何安排他，\n却因为伏黑的一句话改变想法……"
      },
      "STMSN_04046M": {
        "ID": "STMSN_04046M",
        "Text": "京都姊妹校交流会"
      },
      "STMSN_04046M_EXPLANATION": {
        "ID": "STMSN_04046M_EXPLANATION",
        "Text": "京都姊妹校交流会第一天\n交杂无数盘算的团体战即将开始……"
      },
      "STMSN_04047M": {
        "ID": "STMSN_04047M",
        "Text": "鉴定"
      },
      "STMSN_04047M_EXPLANATION": {
        "ID": "STMSN_04047M_EXPLANATION",
        "Text": "独自打前锋的家伙\n现身于依照作战计画采取行动的\n东京校阵营！"
      },
      "STMSN_04048M": {
        "ID": "STMSN_04048M",
        "Text": "坏习惯"
      },
      "STMSN_04048M_EXPLANATION": {
        "ID": "STMSN_04048M_EXPLANATION",
        "Text": "虎杖在战斗中持续成长！\n但东堂却发现一件事……\n「那就是你的坏习惯吧？」"
      },
      "STMSN_04049M": {
        "ID": "STMSN_04049M",
        "Text": "入侵"
      },
      "STMSN_04049M_EXPLANATION": {
        "ID": "STMSN_04049M_EXPLANATION",
        "Text": "各处陆续开始对决的时候\n独自行动的狗卷面前\n却出现不详的气息……"
      },
      "STMSN_04050M": {
        "ID": "STMSN_04050M",
        "Text": "贤者"
      },
      "STMSN_04050M_EXPLANATION": {
        "ID": "STMSN_04050M_EXPLANATION",
        "Text": "诞生于人类对森林的敬畏\n远远超出一般程度的特级\n伏黑等人试图避免正面对决却……"
      },
      "STMSN_04051M": {
        "ID": "STMSN_04051M",
        "Text": "咒具"
      },
      "STMSN_04051M_EXPLANATION": {
        "ID": "STMSN_04051M_EXPLANATION",
        "Text": "伏黑等人在花御的猛烈攻击下硬撑\n但也已经快到极限了……"
      },
      "STMSN_04052M": {
        "ID": "STMSN_04052M",
        "Text": "黑闪"
      },
      "STMSN_04052M_EXPLANATION": {
        "ID": "STMSN_04052M_EXPLANATION",
        "Text": "「黑闪」\n咒力核心激发的黑色光芒……\n虎杖即将脱胎换骨……"
      },
      "STMSN_04053M": {
        "ID": "STMSN_04053M",
        "Text": "放不开"
      },
      "STMSN_04053M_EXPLANATION": {
        "ID": "STMSN_04053M_EXPLANATION",
        "Text": "虎杖学会黑闪后明显成长\n联手东堂开始猛攻！！\n「好了，开始料理吧」"
      },
      "STMSN_04054M": {
        "ID": "STMSN_04054M",
        "Text": "超乎常理"
      },
      "STMSN_04054M_EXPLANATION": {
        "ID": "STMSN_04054M_EXPLANATION",
        "Text": "东堂终于解放自己的术式！\nIQ53万（自称）所得出的结论会是……"
      },
      "STMSN_04055M": {
        "ID": "STMSN_04055M",
        "Text": "咒术甲子园"
      },
      "STMSN_04055M_EXPLANATION": {
        "ID": "STMSN_04055M_EXPLANATION",
        "Text": "交流会重新开始\n第2轮战斗是……棒球！？\n咒术甲子园，开打！"
      },
      "STMSN_04056S": {
        "ID": "STMSN_04056S",
        "Text": "联合实习课程"
      },
      "STMSN_04056S_EXPLANATION": {
        "ID": "STMSN_04056S_EXPLANATION",
        "Text": "（五条一时兴起的）1年级和2年级\n联合实习课程开始！\n高专逐渐恢复日常生活……"
      },
      "STMSN_04057S": {
        "ID": "STMSN_04057S",
        "Text": "开花"
      },
      "STMSN_04057S_EXPLANATION": {
        "ID": "STMSN_04057S_EXPLANATION",
        "Text": "成功执行作战却也身受重伤的花御\n了解到战斗的愉悦，进一步成长……\n「花御也越来越像个诅咒了」"
      },
      "STMSN_04058S": {
        "ID": "STMSN_04058S",
        "Text": "联合实习课程－贰－"
      },
      "STMSN_04058S_EXPLANATION": {
        "ID": "STMSN_04058S_EXPLANATION",
        "Text": "联合实习战第2回合\n不知为何冒出京都校的东堂！\n欠了东堂一次「人情」的伏黑会……"
      },
      "STMSN_05059M": {
        "ID": "STMSN_05059M",
        "Text": "起首雷同"
      },
      "STMSN_05059M_EXPLANATION": {
        "ID": "STMSN_05059M_EXPLANATION",
        "Text": "发生非咒术师被咒杀的案件\n虎杖等人出马调查之下\n却陆续挖掘出冲击事实……"
      },
      "STMSN_05060M": {
        "ID": "STMSN_05060M",
        "Text": "案外案"
      },
      "STMSN_05060M_EXPLANATION": {
        "ID": "STMSN_05060M_EXPLANATION",
        "Text": "闯进领域的虎杖等人迎战咒灵\n但入侵者却不只他们三个……"
      },
      "STMSN_05061M": {
        "ID": "STMSN_05061M",
        "Text": "任务在身"
      },
      "STMSN_05061M_EXPLANATION": {
        "ID": "STMSN_05061M_EXPLANATION",
        "Text": "钉崎突然被拉出领域\n眼前这个新的敌人身分与目的为何？\n而咒杀事件的真相又是……"
      },
      "STMSN_05062M": {
        "ID": "STMSN_05062M",
        "Text": "共振"
      },
      "STMSN_05062M_EXPLANATION": {
        "ID": "STMSN_05062M_EXPLANATION",
        "Text": "伏黑成功拔除眼前的咒灵\n领域却没关闭，反而和「某个事件」一样\n唤醒了某个家伙……"
      },
      "STMSN_05063M": {
        "ID": "STMSN_05063M",
        "Text": "突破极限"
      },
      "STMSN_05063M_EXPLANATION": {
        "ID": "STMSN_05063M_EXPLANATION",
        "Text": "觉醒的伏黑正打算使用「杀手锏」\n但脑中却晃过「简直是暴殄天物」\n宿傩的这句话，让他停下动作"
      },
      "STMSN_05064M": {
        "ID": "STMSN_05064M",
        "Text": "兄弟"
      },
      "STMSN_05064M_EXPLANATION": {
        "ID": "STMSN_05064M_EXPLANATION",
        "Text": "坏相感应到手指气息\n决定避开战斗优先回收手指\n然而「背后」冒出虎杖的那刻他瞬间变脸——"
      },
      "STMSN_05065M": {
        "ID": "STMSN_05065M",
        "Text": "共犯"
      },
      "STMSN_05065M_EXPLANATION": {
        "ID": "STMSN_05065M_EXPLANATION",
        "Text": "「只要中了就赢的术式，你们很强啊」\n虎杖与钉崎被坏相兄弟档逼入绝境\n究竟两人能否顺利逆转战况呢……"
      },
      "STMSN_05066M": {
        "ID": "STMSN_05066M",
        "Text": "推荐"
      },
      "STMSN_05066M_EXPLANATION": {
        "ID": "STMSN_05066M_EXPLANATION",
        "Text": "足以引领咒术界的崇高地位「1级」\n连同虎杖在内，东京校有5名学生获得推荐……"
      },
      "STMSN_05067S": {
        "ID": "STMSN_05067S",
        "Text": "中场休假"
      },
      "STMSN_05067S_EXPLANATION": {
        "ID": "STMSN_05067S_EXPLANATION",
        "Text": "某天假日，\n钉崎和真希一起去五条推荐的店\n但果然能被五条推荐的都不单纯……"
      },
      "STMSN_05068S": {
        "ID": "STMSN_05068S",
        "Text": "出老千"
      },
      "STMSN_05068S_EXPLANATION": {
        "ID": "STMSN_05068S_EXPLANATION",
        "Text": "真人打扑克牌每把都赢\n不敢置信的漏瑚和花御怀疑他出老千！\n真人矢口否认，但实际上……"
      },
      "STMSN_05069S": {
        "ID": "STMSN_05069S",
        "Text": "中场考试"
      },
      "STMSN_05069S_EXPLANATION": {
        "ID": "STMSN_05069S_EXPLANATION",
        "Text": "听见八十八桥的事情后\n狗卷和熊猫想确认伏黑的进步而约战！\n「让我看看你变得多强。」"
      },
      "STMSN_05070S": {
        "ID": "STMSN_05070S",
        "Text": "中场任务"
      },
      "STMSN_05070S_EXPLANATION": {
        "ID": "STMSN_05070S_EXPLANATION",
        "Text": "虎杖和五条擅自加入七海的任务\n但不太像平常的一时兴起\n五条似乎有什么打算……"
      },
      "STMSN_06071M": {
        "ID": "STMSN_06071M",
        "Text": "诅咒之子"
      },
      "STMSN_06071M_EXPLANATION": {
        "ID": "STMSN_06071M_EXPLANATION",
        "Text": "苦于诅咒希望自己能死去的少年……\n为了当好一个咒术师、当好一个人类\n转入高专学习诅咒，与诅咒对抗"
      },
      "STMSN_06072M": {
        "ID": "STMSN_06072M",
        "Text": "诅咒的女王"
      },
      "STMSN_06072M_EXPLANATION": {
        "ID": "STMSN_06072M_EXPLANATION",
        "Text": "真希问起乙骨来高专的理由\n少年回答了自己的愿望……"
      },
      "STMSN_06073S": {
        "ID": "STMSN_06073S",
        "Text": "担心"
      },
      "STMSN_06073S_EXPLANATION": {
        "ID": "STMSN_06073S_EXPLANATION",
        "Text": "狗卷、熊猫也一起组队参加实习！\n「棘，你很在意转学生吗？」\n狗卷会关注乙骨的原因是……"
      },
      "STMSN_06074M": {
        "ID": "STMSN_06074M",
        "Text": "解咒"
      },
      "STMSN_06074M_EXPLANATION": {
        "ID": "STMSN_06074M_EXPLANATION",
        "Text": "经历这次实习，乙骨决定要帮里香解咒\n「用这个吧」\n五条亲手交给他用来解咒的是……"
      },
      "STMSN_06075M": {
        "ID": "STMSN_06075M",
        "Text": "锻炼"
      },
      "STMSN_06075M_EXPLANATION": {
        "ID": "STMSN_06075M_EXPLANATION",
        "Text": "乙骨为了解咒而努力学习刀法\n接受五条特训后一切就能结束……才怪！\n被找来进行力量特训的人是……"
      },
      "STMSN_06076S": {
        "ID": "STMSN_06076S",
        "Text": "共斗实习"
      },
      "STMSN_06076S_EXPLANATION": {
        "ID": "STMSN_06076S_EXPLANATION",
        "Text": "纪念真希的伤治好\n举办组队参加的对战大赛！\n令人在意的配对结果是……"
      },
      "STMSN_06077M": {
        "ID": "STMSN_06077M",
        "Text": "处罚与否"
      },
      "STMSN_06077M_EXPLANATION": {
        "ID": "STMSN_06077M_EXPLANATION",
        "Text": "时间来到夏季\n透过上课和特训\n乙骨与真希等人的距离逐渐拉近"
      },
      "STMSN_06078M": {
        "ID": "STMSN_06078M",
        "Text": "黑之又黑"
      },
      "STMSN_06078M_EXPLANATION": {
        "ID": "STMSN_06078M_EXPLANATION",
        "Text": "这次狗卷出任务时会带上乙骨……\n但面对无法言语沟通的狗卷，\n乙骨觉得他有些可怕……"
      },
      "STMSN_06079S": {
        "ID": "STMSN_06079S",
        "Text": "共斗实习－贰－"
      },
      "STMSN_06079S_EXPLANATION": {
        "ID": "STMSN_06079S_EXPLANATION",
        "Text": "经历商店街事件后拉近距离的狗卷与乙骨\n两人要组队挑战二度举办的共斗实习！"
      },
      "STMSN_06080M": {
        "ID": "STMSN_06080M",
        "Text": "处罚弱者"
      },
      "STMSN_06080M_EXPLANATION": {
        "ID": "STMSN_06080M_EXPLANATION",
        "Text": "诅咒师，用诅咒报复人世间的群体……\n当中被认为最恶劣的夏油现身高专\n他高调对所有人宣告自己的「计画」……"
      },
      "STMSN_06081M": {
        "ID": "STMSN_06081M",
        "Text": "旧识"
      },
      "STMSN_06081M_EXPLANATION": {
        "ID": "STMSN_06081M_EXPLANATION",
        "Text": "五条回忆着不够成熟的学生时代\n与夏油一起渡过的每一天……\n以及两人诀别的时刻……"
      },
      "STMSN_06082M": {
        "ID": "STMSN_06082M",
        "Text": "坚强率直"
      },
      "STMSN_06082M_EXPLANATION": {
        "ID": "STMSN_06082M_EXPLANATION",
        "Text": "真希对思索着夏油那些言论的乙骨\n说起自己的家庭背景\n同时敌人的魔掌也伸向他们……"
      },
      "STMSN_06083M": {
        "ID": "STMSN_06083M",
        "Text": "死守"
      },
      "STMSN_06083M_EXPLANATION": {
        "ID": "STMSN_06083M_EXPLANATION",
        "Text": "五条对夏油不在前线这件事感到突兀\n紧急将狗卷和熊猫「传」回高专\n「你们要保护那两人。抱歉，是死守住那两人！！」"
      },
      "STMSN_06084M": {
        "ID": "STMSN_06084M",
        "Text": "完全显现"
      },
      "STMSN_06084M_EXPLANATION": {
        "ID": "STMSN_06084M_EXPLANATION",
        "Text": "乙骨目睹真希等人惨烈的模样……\n「我要杀了你！」\n迎战最恶劣的诅咒师"
      },
      "STMSN_06085M": {
        "ID": "STMSN_06085M",
        "Text": "耀眼的黑暗"
      },
      "STMSN_06085M_EXPLANATION": {
        "ID": "STMSN_06085M_EXPLANATION",
        "Text": "赌上自身存在意义战斗的人\n为大义拿起武器的人\n两人之间的决战即将开始……"
      },
      "STMSN_06086M": {
        "ID": "STMSN_06086M",
        "Text": "谢谢"
      },
      "STMSN_06086M_EXPLANATION": {
        "ID": "STMSN_06086M_EXPLANATION",
        "Text": "乙骨睁开眼就看见满脸担心盯着他的真希等人\n还有里香的身影\n对于献祭自己的乙骨，里香她……"
      },
      "STMSN_06087S": {
        "ID": "STMSN_06087S",
        "Text": "从今以后"
      },
      "STMSN_06087S_EXPLANATION": {
        "ID": "STMSN_06087S_EXPLANATION",
        "Text": "里香解咒后过了一段时间\n五条确认了乙骨「如今」的力量之后\n开口拜托他一件事情……"
      },
      "STMSN_06088S": {
        "ID": "STMSN_06088S",
        "Text": "师弟"
      },
      "STMSN_06088S_EXPLANATION": {
        "ID": "STMSN_06088S_EXPLANATION",
        "Text": "这也许是曾发生过的真实战斗……\n学生们合力挑战五条老师\n超越最强吧！年轻人们！"
      },
      "STMSN_06089S": {
        "ID": "STMSN_06089S",
        "Text": "冠上特级之名的诅咒"
      },
      "STMSN_06089S_EXPLANATION": {
        "ID": "STMSN_06089S_EXPLANATION",
        "Text": "由各式各样恐惧的情绪中诞生的\n最高等级的诅咒们……\n他们为了各自的本能、欲望及目的而行动"
      },
      "STMSN_08090M": {
        "ID": "STMSN_08090M",
        "Text": "怀玉"
      },
      "STMSN_08090M_EXPLANATION": {
        "ID": "STMSN_08090M_EXPLANATION",
        "Text": "年少时期的五条与夏油\n最强的两人\n已经回不去的青春时光即将开始"
      },
      "STMSN_08091M": {
        "ID": "STMSN_08091M",
        "Text": "术师杀手"
      },
      "STMSN_08091M_EXPLANATION": {
        "ID": "STMSN_08091M_EXPLANATION",
        "Text": "伏黑甚尔看准了一行人\n进入高专结界的瞬间袭击\n而甚尔超乎我方预料的秘密是？"
      },
      "STMSN_08092M": {
        "ID": "STMSN_08092M",
        "Text": "被摧毁的愿望"
      },
      "STMSN_08092M_EXPLANATION": {
        "ID": "STMSN_08092M_EXPLANATION",
        "Text": "在即将与天元同化前\n天内想忠于自己的内心\n夏油打算实现她的那个愿望……"
      },
      "STMSN_08093M": {
        "ID": "STMSN_08093M",
        "Text": "觉醒"
      },
      "STMSN_08093M_EXPLANATION": {
        "ID": "STMSN_08093M_EXPLANATION",
        "Text": "五条没有死\n他在将死之际掌握了操作咒力的奥秘\n再次阻挡在甚尔面前"
      },
      "STMSN_08094M": {
        "ID": "STMSN_08094M",
        "Text": "玉折"
      },
      "STMSN_08094M_EXPLANATION": {
        "ID": "STMSN_08094M_EXPLANATION",
        "Text": "变成最强的五条\n变成独自一人的夏油\n两人的道路逐渐分歧"
      },
      "STMSN_09095M": {
        "ID": "STMSN_09095M",
        "Text": "宵祭"
      },
      "STMSN_09095M_EXPLANATION": {
        "ID": "STMSN_09095M_EXPLANATION",
        "Text": "与咒灵串通的机械丸，也就是与幸吉\n为了实现「和大家相见」的愿望\n赌上至今为止的一切与真人战斗"
      },
      "STMSN_09096M": {
        "ID": "STMSN_09096M",
        "Text": "涩谷事变　开门"
      },
      "STMSN_09096M_EXPLANATION": {
        "ID": "STMSN_09096M_EXPLANATION",
        "Text": "2018年10月31日\n在万圣节这天，咒诅师们\n在涩谷着手实行某项计画"
      },
      "STMSN_09097M": {
        "ID": "STMSN_09097M",
        "Text": "对峙"
      },
      "STMSN_09097M_EXPLANATION": {
        "ID": "STMSN_09097M_EXPLANATION",
        "Text": "敌人与陷阱\n正等着抵达涩谷的五条悟\n五条展开与咒灵们的战斗"
      },
      "STMSN_09098M": {
        "ID": "STMSN_09098M",
        "Text": "狱门疆"
      },
      "STMSN_09098M_EXPLANATION": {
        "ID": "STMSN_09098M_EXPLANATION",
        "Text": "为了封印五条悟而准备的狱门疆\n出乎意料的人物与其开门同时现身\n"
      },
      "STMSN_09099M": {
        "ID": "STMSN_09099M",
        "Text": "昏乱"
      },
      "STMSN_09099M_EXPLANATION": {
        "ID": "STMSN_09099M_EXPLANATION",
        "Text": "迷你机械丸告知了五条被封印\n虎杖为了突破这个局面\n打算与七海会合"
      },
      "STMSN_09100M": {
        "ID": "STMSN_09100M",
        "Text": "降灵"
      },
      "STMSN_09100M_EXPLANATION": {
        "ID": "STMSN_09100M_EXPLANATION",
        "Text": "虎杖等人认为咒诅师们\n是在「显眼的地点」守护「帐」的根基\n于是以高层大楼屋顶为目标前进"
      },
      "STMSN_09101M": {
        "ID": "STMSN_09101M",
        "Text": "钝刀"
      },
      "STMSN_09101M_EXPLANATION": {
        "ID": "STMSN_09101M_EXPLANATION",
        "Text": "七海在负伤的钉崎与新田面前现身\n对重面表现出怒气并出拳攻击\n钉崎见识到了那压倒性的力量"
      },
      "STMSN_09102M": {
        "ID": "STMSN_09102M",
        "Text": "赫鳞"
      },
      "STMSN_09102M_EXPLANATION": {
        "ID": "STMSN_09102M_EXPLANATION",
        "Text": "胀相攻击抵达涩谷站地下的虎杖\n并且问他\n「弟弟最后有说了什么遗言吗？」"
      },
      "STMSN_09103M": {
        "ID": "STMSN_09103M",
        "Text": "摇荡"
      },
      "STMSN_09103M_EXPLANATION": {
        "ID": "STMSN_09103M_EXPLANATION",
        "Text": "直毗人、七海、真希进入了陀艮的领域\n在有如海浪永无止尽不断袭来的攻击下\n咒术师们渐渐疲惫"
      },
      "STMSN_09104M": {
        "ID": "STMSN_09104M",
        "Text": "霹雳"
      },
      "STMSN_09104M_EXPLANATION": {
        "ID": "STMSN_09104M_EXPLANATION",
        "Text": "两面宿傩夺走虎杖身体的主导权\n觉醒的他拒绝漏瑚缔结「束缚」的提案\n向他提出对决"
      },
      "STMSN_09105M": {
        "ID": "STMSN_09105M",
        "Text": "失控"
      },
      "STMSN_09105M_EXPLANATION": {
        "ID": "STMSN_09105M_EXPLANATION",
        "Text": "突然出现的神秘男人把伏黑视为下个目标\n面对他压倒性的力量\n陷入绝境的伏黑打算赌上性命应战"
      },
      "STMSN_09106M": {
        "ID": "STMSN_09106M",
        "Text": "异戒神将"
      },
      "STMSN_09106M_EXPLANATION": {
        "ID": "STMSN_09106M_EXPLANATION",
        "Text": "因重面春太的刀刃攻击而濒死的伏黑\n开始从自己的术式「十种影法术」中\n召唤某个式神，进行调伏之仪"
      },
      "STMSN_09107M": {
        "ID": "STMSN_09107M",
        "Text": "是非"
      },
      "STMSN_09107M_EXPLANATION": {
        "ID": "STMSN_09107M_EXPLANATION",
        "Text": "受了重伤的七海仍在涩谷徘徊战斗\n真人出现在他面前\n而赶到两人身边的虎杖看到的是……"
      },
      "STMSN_09108M": {
        "ID": "STMSN_09108M",
        "Text": "同心"
      },
      "STMSN_09108M_EXPLANATION": {
        "ID": "STMSN_09108M_EXPLANATION",
        "Text": "回到战线的钉崎遇到真人\n对于攻击不管用的真人\n钉崎具有胜算"
      },
      "STMSN_09109M": {
        "ID": "STMSN_09109M",
        "Text": "茫然"
      },
      "STMSN_09109M_EXPLANATION": {
        "ID": "STMSN_09109M_EXPLANATION",
        "Text": "即使是重创真人的钉崎\n仍在虎杖眼前因攻击倒下\n虎杖沮丧而失去自我时，某个男人出现了"
      },
      "STMSN_09110M": {
        "ID": "STMSN_09110M",
        "Text": "遗志"
      },
      "STMSN_09110M_EXPLANATION": {
        "ID": "STMSN_09110M_EXPLANATION",
        "Text": "虎杖怀抱伙伴们所托而站了起来\n接着东堂继虎杖、真人之后也使出黑闪\n三人的战斗更加剧烈了"
      },
      "STMSN_09111M": {
        "ID": "STMSN_09111M",
        "Text": "变身"
      },
      "STMSN_09111M_EXPLANATION": {
        "ID": "STMSN_09111M_EXPLANATION",
        "Text": "在与虎杖进行激战后\n真人终于掌握自己灵魂的本质\n以变身后的样貌挡在虎杖面前"
      },
      "STMSN_09112M": {
        "ID": "STMSN_09112M",
        "Text": "离愁"
      },
      "STMSN_09112M_EXPLANATION": {
        "ID": "STMSN_09112M_EXPLANATION",
        "Text": "在京都校众人前往涩谷途中\n机械丸在列车里以与幸吉的身分\n向三轮留下最后的话语"
      },
      "STMSN_09113M": {
        "ID": "STMSN_09113M",
        "Text": "血战"
      },
      "STMSN_09113M_EXPLANATION": {
        "ID": "STMSN_09113M_EXPLANATION",
        "Text": "胀相察觉设法让他杀死兄弟的\n那名男人的真面目\n他愤怒地拿出身为哥哥的全力对战\n"
      },
      "STMSN_09114M": {
        "ID": "STMSN_09114M",
        "Text": "涩谷事变　关门"
      },
      "STMSN_09114M_EXPLANATION": {
        "ID": "STMSN_09114M_EXPLANATION",
        "Text": "被称为加茂宪伦的男人表示\n今后的世界将会是令人恐惧的混沌\n与更加激烈的战斗开端"
      },
      "STR_DEMO_LABEL_0001": {
        "ID": "STR_DEMO_LABEL_0001",
        "Text": "原作　『咒术回战』Gege Akutami"
      },
