[
  {
    "Type": "DataTable",
    "Name": "DlcStoryDemoTextDataTable1_Ja",
    "Flags": "RF_Public | RF_Standalone | RF_Transactional | RF_WasLoaded | RF_LoadCompleted",
    "Class": "UScriptClass'DataTable'",
    "Properties": {
      "RowStruct": {
        "ObjectName": "Class'GameDataTableRow_GameText'",
        "ObjectPath": "/Script/Abrams"
      },
      "ImportKeyField": "Id"
    },
    "Rows": {
      "STDM_0809001_0010": {
        "ID": "STDM_0809001_0010",
        "Text": "まぁ大丈夫でしょ"
      },
      "STDM_0809001_0015": {
        "ID": "STDM_0809001_0015",
        "Text": "俺達最強だし"
      },
      "STDM_0809001_0020": {
        "ID": "STDM_0809001_0020",
        "Text": "静岡県浜松市\n２００６年"
      },
      "STDM_0809001_0030": {
        "ID": "STDM_0809001_0030",
        "Text": "助けに来たよ～"
      },
      "STDM_0809001_0040": {
        "ID": "STDM_0809001_0040",
        "Text": "呪術高専２年　五条悟"
      },
      "STDM_0809001_0050": {
        "ID": "STDM_0809001_0050",
        "Text": "弱い奴等に気を遣うのは疲れるよ\nホント"
      },
      "STDM_0809001_0060": {
        "ID": "STDM_0809001_0060",
        "Text": "悟　弱い者イジメは良くないよ"
      },
      "STDM_0809001_0070": {
        "ID": "STDM_0809001_0070",
        "Text": "呪術高専２年　夏油傑"
      },
      "STDM_0809001_0080": {
        "ID": "STDM_0809001_0080",
        "Text": "弱者生存　それがあるべき社会の姿さ"
      },
      "STDM_0809001_0090": {
        "ID": "STDM_0809001_0090",
        "Text": "この任務はオマエたち２人に行ってもらう\n依頼は２つ　星漿体　天元様との適合者\nその少女の護衛と――抹消だ"
      },
      "STDM_0809001_0100": {
        "ID": "STDM_0809001_0100",
        "Text": "失敗すればその影響は\n一般社会にまで及ぶ\n心してかかれ！！"
      },
      "STDM_0809001_0110": {
        "ID": "STDM_0809001_0110",
        "Text": "「Ｑ」最高戦力バイエル離脱から\n組織瓦解"
      },
      "STDM_0809001_0120": {
        "ID": "STDM_0809001_0120",
        "Text": "いいぜ\nその話受けてやる"
      },
      "STDM_0809001_0130": {
        "ID": "STDM_0809001_0130",
        "Text": "相手は五条家のボンだぞ\nのこのこ出て行ったところで\nなんもできねえさ"
      },
      "STDM_0809001_0140": {
        "ID": "STDM_0809001_0140",
        "Text": "まずはバカどもを使って削る"
      },
      "STDM_0809001_0150": {
        "ID": "STDM_0809001_0150",
        "Text": "ちっ！"
      },
      "STDM_0809001_0160": {
        "ID": "STDM_0809001_0160",
        "Text": "頼むぜ　術師殺し"
      },
      "STDM_0809001_0165": {
        "ID": "STDM_0809001_0165",
        "Text": "あぁ　そうだ　恵は元気か？"
      },
      "STDM_0809001_0170": {
        "ID": "STDM_0809001_0170",
        "Text": "……"
      },
      "STDM_0809001_0175": {
        "ID": "STDM_0809001_0175",
        "Text": "誰だっけ？"
      },
      "STDM_0809001_0180": {
        "ID": "STDM_0809001_0180",
        "Text": "五条　沖縄で黒井を救出"
      },
      "STDM_0809001_0190": {
        "ID": "STDM_0809001_0190",
        "Text": "めんそーれー！！"
      },
      "STDM_0809001_0200": {
        "ID": "STDM_0809001_0200",
        "Text": "沖縄\n護衛２日目"
      },
      "STDM_0809001_0210": {
        "ID": "STDM_0809001_0210",
        "Text": "都立　呪術高専　筵山麓"
      },
      "STDM_0809001_0220": {
        "ID": "STDM_0809001_0220",
        "Text": "護衛３日目　１５：００"
      },
      "STDM_0809001_0230": {
        "ID": "STDM_0809001_0230",
        "Text": "高専の結界内だ"
      },
      "STDM_0809001_0240": {
        "ID": "STDM_0809001_0240",
        "Text": "悟　本当にお疲れ"
      },
      "STDM_0809001_0250": {
        "ID": "STDM_0809001_0250",
        "Text": "ハァ～\n二度と御免だ　ガキのお守りは"
      },
      "STDM_0809001_0260": {
        "ID": "STDM_0809001_0260",
        "Text": "あ…ああっ…"
      },
      "STDM_0809001_0270": {
        "ID": "STDM_0809001_0270",
        "Text": "アンタ　どこかで会ったか？"
      },
      "STDM_0809001_0280": {
        "ID": "STDM_0809001_0280",
        "Text": "気にすんな　俺も苦手だ\n男の名前覚えんのは"
      },
      "STDM_0809101_0010": {
        "ID": "STDM_0809101_0010",
        "Text": "っ……！"
      },
      "STDM_0809101_0020": {
        "ID": "STDM_0809101_0020",
        "Text": "悟！"
      },
      "STDM_0809101_0030": {
        "ID": "STDM_0809101_0030",
        "Text": "ニットのセーターに\n安全ピン通したみたいなもんだよ\nマジで問題ない"
      },
      "STDM_0809101_0040": {
        "ID": "STDM_0809101_0040",
        "Text": "それより　天内優先\nアイツの相手は俺がする"
      },
      "STDM_0809101_0050": {
        "ID": "STDM_0809101_0050",
        "Text": "傑たちは先に天元様の所へ行ってくれ"
      },
      "STDM_0809101_0060": {
        "ID": "STDM_0809101_0060",
        "Text": "悟……"
      },
      "STDM_0809101_0070": {
        "ID": "STDM_0809101_0070",
        "Text": "油断するなよ"
      },
      "STDM_0809101_0080": {
        "ID": "STDM_0809101_0080",
        "Text": "誰に言ってんだよ"
      },
      "STDM_0809101_0090": {
        "ID": "STDM_0809101_0090",
        "Text": "できれば五条悟はさっきので仕留めたかったんだが……\nナマったかな"
      },
      "STDM_0809101_0100": {
        "ID": "STDM_0809101_0100",
        "Text": "天内の懸賞金はもう取り下げられたぞ　マヌケ"
      },
      "STDM_0809101_0110": {
        "ID": "STDM_0809101_0110",
        "Text": "俺が取り下げたんだよ　ヤセ我慢"
      },
      "STDM_0809101_0120": {
        "ID": "STDM_0809101_0120",
        "Text": "オマエみたいにスキがない奴には\n緩急つけて偽のゴールを\nいくつか作ってやるんだ"
      },
      "STDM_0809101_0130": {
        "ID": "STDM_0809101_0130",
        "Text": "懸賞金の時間制限がなければ\nオマエは最後まで\n術式解かなかったと思うぜ"
      },
      "STDM_0809101_0140": {
        "ID": "STDM_0809101_0140",
        "Text": "あっそ"
      },
      "STDM_0809102_0010": {
        "ID": "STDM_0809102_0010",
        "Text": "コイツ　何かおかしいと思ったら　呪力が全くない！"
      },
      "STDM_0809102_0020": {
        "ID": "STDM_0809102_0020",
        "Text": "天与呪縛のフィジカルギフテッド！！"
      },
      "STDM_0809103_0010": {
        "ID": "STDM_0809103_0010",
        "Text": "術式順転　出力最大"
      },
      "STDM_0809103_0020": {
        "ID": "STDM_0809103_0020",
        "Text": "「蒼」"
      },
      "STDM_0809103_0030": {
        "ID": "STDM_0809103_0030",
        "Text": "遮蔽物なし　奇襲はできない"
      },
      "STDM_0809103_0040": {
        "ID": "STDM_0809103_0040",
        "Text": "アレは…"
      },
      "STDM_0809103_0041": {
        "ID": "STDM_0809103_0041",
        "Text": "蠅頭！？"
      },
      "STDM_0809103_0050": {
        "ID": "STDM_0809103_0050",
        "Text": "チャフみてぇに使おうってわけね"
      },
      "STDM_0809103_0060": {
        "ID": "STDM_0809103_0060",
        "Text": "死角もできた\nもう一度「蒼」で……"
      },
      "STDM_0809103_0070": {
        "ID": "STDM_0809103_0070",
        "Text": "いやまて\nアイツの狙いは\n天内——"
      },
      "STDM_0809103_0080": {
        "ID": "STDM_0809103_0080",
        "Text": "手ぶらの俺も気取る勘の良さ"
      },
      "STDM_0809103_0090": {
        "ID": "STDM_0809103_0090",
        "Text": "だがようやく\n術式頼りの守りに回ったな"
      },
      "STDM_0809201_0010": {
        "ID": "STDM_0809201_0010",
        "Text": "ここが……"
      },
      "STDM_0809201_0020": {
        "ID": "STDM_0809201_0020",
        "Text": "あぁ\n天元様の膝下"
      },
      "STDM_0809201_0030": {
        "ID": "STDM_0809201_0030",
        "Text": "国内主要結界の基底\n薨星宮　本殿"
      },
      "STDM_0809201_0040": {
        "ID": "STDM_0809201_0040",
        "Text": "階段を降りたら門をくぐって\nあの大樹の根元まで行くんだ"
      },
      "STDM_0809201_0050": {
        "ID": "STDM_0809201_0050",
        "Text": "同化まで天元様が守ってくれる"
      },
      "STDM_0809201_0060": {
        "ID": "STDM_0809201_0060",
        "Text": "それか引き返して\n黒井さんと一緒に家に帰ろう"
      },
      "STDM_0809201_0070": {
        "ID": "STDM_0809201_0070",
        "Text": "……え？"
      },
      "STDM_0809201_0080": {
        "ID": "STDM_0809201_0080",
        "Text": "君と会う前に\n悟との話し合いは済んでる"
      },
      "STDM_0809201_0090": {
        "ID": "STDM_0809201_0090",
        "Text": "星漿体のガキが同化を拒んだ時ぃ？"
      },
      "STDM_0809201_0100": {
        "ID": "STDM_0809201_0100",
        "Text": "そん時は……同化はなし！！"
      },
      "STDM_0809201_0110": {
        "ID": "STDM_0809201_0110",
        "Text": "クックッ　いいのかい？"
      },
      "STDM_0809201_0120": {
        "ID": "STDM_0809201_0120",
        "Text": "天元様と戦うことになるかもしれないよ"
      },
      "STDM_0809201_0130": {
        "ID": "STDM_0809201_0130",
        "Text": "ビビってんの？"
      },
      "STDM_0809201_0140": {
        "ID": "STDM_0809201_0140",
        "Text": "大丈夫　何とかなるって"
      },
      "STDM_0809201_0150": {
        "ID": "STDM_0809201_0150",
        "Text": "私達は最強なんだ"
      },
      "STDM_0809201_0160": {
        "ID": "STDM_0809201_0160",
        "Text": "理子ちゃんがどんな選択をしようと\n君の未来は私たちが保障する"
      },
      "STDM_0809201_0170": {
        "ID": "STDM_0809201_0170",
        "Text": "……私は"
      },
      "STDM_0809201_0180": {
        "ID": "STDM_0809201_0180",
        "Text": "生まれた時から星漿体で\n皆とは違うって言われ続けて"
      },
      "STDM_0809201_0190": {
        "ID": "STDM_0809201_0190",
        "Text": "私にとっては星漿体が普通で"
      },
      "STDM_0809201_0200": {
        "ID": "STDM_0809201_0200",
        "Text": "危ない事はなるべく避けて\nこの日のために生きてきた"
      },
      "STDM_0809201_0210": {
        "ID": "STDM_0809201_0210",
        "Text": "だから同化でみんなと離れ離れになっても\n大丈夫って思ってた"
      },
      "STDM_0809201_0220": {
        "ID": "STDM_0809201_0220",
        "Text": "……でもっ\nでも　やっぱり"
      },
      "STDM_0809201_0230": {
        "ID": "STDM_0809201_0230",
        "Text": "もっとみんなと一緒にいたい"
      },
      "STDM_0809201_0240": {
        "ID": "STDM_0809201_0240",
        "Text": "もっと皆と色んな所に行って\n色んな物を見て……もっと！！"
      },
      "STDM_0809201_0250": {
        "ID": "STDM_0809201_0250",
        "Text": "帰ろう　理子ちゃん"
      },
      "STDM_0809201_0260": {
        "ID": "STDM_0809201_0260",
        "Text": "……うん！！"
      },
      "STDM_0809201_0270": {
        "ID": "STDM_0809201_0270",
        "Text": "理子ちゃん？"
      },
      "STDM_0809201_0280": {
        "ID": "STDM_0809201_0280",
        "Text": "ハイお疲れ　解散　解散"
      },
      "STDM_0809201_0290": {
        "ID": "STDM_0809201_0290",
        "Text": "なんでオマエがここにいる"
      },
      "STDM_0809201_0300": {
        "ID": "STDM_0809201_0300",
        "Text": "あぁ？　なんでって……"
      },
      "STDM_0809201_0310": {
        "ID": "STDM_0809201_0310",
        "Text": "あぁ　そういう意味ね"
      },
      "STDM_0809201_0320": {
        "ID": "STDM_0809201_0320",
        "Text": "五条悟は俺が殺した"
      },
      "STDM_0809201_0330": {
        "ID": "STDM_0809201_0330",
        "Text": "そうか"
      },
      "STDM_0809201_0340": {
        "ID": "STDM_0809201_0340",
        "Text": "死ね"
      },
      "STDM_0809202_0010": {
        "ID": "STDM_0809202_0010",
        "Text": "何故薨星宮へ続く扉が分かった\n私達は毛程も残穢を残さなかった"
      },
      "STDM_0809202_0020": {
        "ID": "STDM_0809202_0020",
        "Text": "人間が残す痕跡は残穢だけじゃねぇ"
      },
      "STDM_0809202_0030": {
        "ID": "STDM_0809202_0030",
        "Text": "臭跡　足跡\n五感も呪縛で底上げされてんだよ"
      },
      "STDM_0809202_0040": {
        "ID": "STDM_0809202_0040",
        "Text": "途中に女性が１人いたハズだ\n彼女はどうした"
      },
      "STDM_0809202_0050": {
        "ID": "STDM_0809202_0050",
        "Text": "ん？　あぁあのメイドか\n多分死んでる\n生かす気も殺す気もなかったけどな"
      },
      "STDM_0809202_0060": {
        "ID": "STDM_0809202_0060",
        "Text": "運良きゃ生きてんじゃね？"
      },
      "STDM_0809202_0070": {
        "ID": "STDM_0809202_0070",
        "Text": "そうか\nやはりオマエは　死ね"
      },
      "STDM_0809203_0010": {
        "ID": "STDM_0809203_0010",
        "Text": "馬鹿が……終わりだな"
      },
      "STDM_0809203_0020": {
        "ID": "STDM_0809203_0020",
        "Text": "オマエがな"
      },
      "STDM_0809203_0030": {
        "ID": "STDM_0809203_0030",
        "Text": "能力は特殊だが呪霊自体は強くない\n取り込める！！"
      },
      "STDM_0809203_0040": {
        "ID": "STDM_0809203_0040",
        "Text": "武器庫は押さえた\n後は物量でゴリ押し――"
      },
      "STDM_0809203_0050": {
        "ID": "STDM_0809203_0050",
        "Text": "なっ……！！"
      },
      "STDM_0809203_0060": {
        "ID": "STDM_0809203_0060",
        "Text": "術師なら死なねぇ程度に切った"
      },
      "STDM_0809203_0070": {
        "ID": "STDM_0809203_0070",
        "Text": "式神使いなら殺したが\n呪霊操術となるとな"
      },
      "STDM_0809203_0080": {
        "ID": "STDM_0809203_0080",
        "Text": "オマエの死後\n取り込んでた呪霊が\nどうなるか分からん"
      },
      "STDM_0809203_0090": {
        "ID": "STDM_0809203_0090",
        "Text": "ここで面倒事は避けたい\n親に恵まれたな"
      },
      "STDM_0809203_0100": {
        "ID": "STDM_0809203_0100",
        "Text": "だが　その恵まれたオマエらが\n呪術も使えねぇ俺みたいな\n猿に負けたってこと"
      },
      "STDM_0809203_0110": {
        "ID": "STDM_0809203_0110",
        "Text": "長生きしたきゃ忘れんな"
      },
      "STDM_0809203_0120": {
        "ID": "STDM_0809203_0120",
        "Text": "あーー"
      },
      "STDM_0809203_0130": {
        "ID": "STDM_0809203_0130",
        "Text": "恵って\nそうだったそうだった"
      },
      "STDM_0809203_0140": {
        "ID": "STDM_0809203_0140",
        "Text": "俺が名付けたんだった"
      },
      "STDM_0809301_0010": {
        "ID": "STDM_0809301_0010",
        "Text": "某日、殺害された星漿体　天内理子の遺体は、\n伏黒甚爾本人の手により盤星教本部である\n星の子の家へ持ち込まれた。"
      },
      "STDM_0809301_0020": {
        "ID": "STDM_0809301_0020",
        "Text": "盤星教　代表役員　園田茂と伏黒甚爾、\n仲介役である孔時雨の３名の元、\n遺体の引き渡しが行われた模様。"
      },
      "STDM_0809301_0030": {
        "ID": "STDM_0809301_0030",
        "Text": "よお　久しぶり"
      },
      "STDM_0809301_0040": {
        "ID": "STDM_0809301_0040",
        "Text": "マジか"
      },
      "STDM_0809301_0050": {
        "ID": "STDM_0809301_0050",
        "Text": "大マジ　元気ピンピンだよ"
      },
      "STDM_0809301_0060": {
        "ID": "STDM_0809301_0060",
        "Text": "反転術式！！"
      },
      "STDM_0809301_0070": {
        "ID": "STDM_0809301_0070",
        "Text": "正っ解っ！！"
      },
      "STDM_0809301_0080": {
        "ID": "STDM_0809301_0080",
        "Text": "俺も今までできたことねーよ"
      },
      "STDM_0809301_0090": {
        "ID": "STDM_0809301_0090",
        "Text": "だが　死に際で掴んだ\n呪力の核心！"
      },
      "STDM_0809301_0100": {
        "ID": "STDM_0809301_0100",
        "Text": "オマエの敗因は\n俺を首チョンパしなかったことと\n頭をブッ刺すのに\nあの呪具を使わなかったこと"
      },
      "STDM_0809301_0110": {
        "ID": "STDM_0809301_0110",
        "Text": "……敗因？"
      },
      "STDM_0809301_0120": {
        "ID": "STDM_0809301_0120",
        "Text": "勝負はこれからだろ"
      },
      "STDM_0809301_0130": {
        "ID": "STDM_0809301_0130",
        "Text": "あ゛ーー？　そうか？　そうだな"
      },
      "STDM_0809301_0140": {
        "ID": "STDM_0809301_0140",
        "Text": "…そーかもなあ！！"
      },
      "STDM_0809302_0010": {
        "ID": "STDM_0809302_0010",
        "Text": "ごめん　天内"
      },
      "STDM_0809302_0020": {
        "ID": "STDM_0809302_0020",
        "Text": "俺は今\nオマエのために怒ってない\n誰も憎んじゃいない"
      },
      "STDM_0809302_0030": {
        "ID": "STDM_0809302_0030",
        "Text": "今はただただこの世界が心地良い"
      },
      "STDM_0809302_0040": {
        "ID": "STDM_0809302_0040",
        "Text": "天上天下　唯我独尊"
      },
      "STDM_0809302_0050": {
        "ID": "STDM_0809302_0050",
        "Text": "順転と反転\nそれぞれの無限を衝突させることで生成される\n仮想の質量を押し出す"
      },
      "STDM_0809303_0010": {
        "ID": "STDM_0809303_0010",
        "Text": "違和感"
      },
      "STDM_0809303_0020": {
        "ID": "STDM_0809303_0020",
        "Text": "「タダ働きなんてゴメンだね」\nいつもの俺ならそう言ってトンズラこいた"
      },
      "STDM_0809303_0030": {
        "ID": "STDM_0809303_0030",
        "Text": "だが目の前には覚醒した無下限呪術の使い手\n恐らく現代最強と成った術師"
      },
      "STDM_0809303_0040": {
        "ID": "STDM_0809303_0040",
        "Text": "否定したくなった\n捩じ伏せてみたくなった"
      },
      "STDM_0809303_0050": {
        "ID": "STDM_0809303_0050",
        "Text": "俺を否定した禪院家　呪術界\nその頂点を"
      },
      "STDM_0809303_0060": {
        "ID": "STDM_0809303_0060",
        "Text": "自分を肯定するために\nいつもの自分を曲げちまった"
      },
      "STDM_0809303_0070": {
        "ID": "STDM_0809303_0070",
        "Text": "その時点で負けていた"
      },
      "STDM_0809303_0080": {
        "ID": "STDM_0809303_0080",
        "Text": "自尊心は捨てたろ"
      },
      "STDM_0809303_0090": {
        "ID": "STDM_0809303_0090",
        "Text": "自分も他人も尊ぶことない\nそういう生き方を選んだんだろうが"
      },
      "STDM_0809303_0100": {
        "ID": "STDM_0809303_0100",
        "Text": "最期に言い残すことはあるか？"
      },
      "STDM_0809303_0110": {
        "ID": "STDM_0809303_0110",
        "Text": "……ねぇよ"
      },
      "STDM_0809303_0120": {
        "ID": "STDM_0809303_0120",
        "Text": "２　３年もしたら\n俺の子供が禪院家に売られる"
      },
      "STDM_0809303_0130": {
        "ID": "STDM_0809303_0130",
        "Text": "好きにしろ"
      },
      "STDM_0809303_0140": {
        "ID": "STDM_0809303_0140",
        "Text": "その後、盤星教施設内にて呪術高専２年　五条悟が\n星漿体　天内理子の遺体を回収。"
      },
      "STDM_0809303_0150": {
        "ID": "STDM_0809303_0150",
        "Text": "ほどなくして、呪術高専２年　夏油傑も\nその場へ合流した。"
      },
      "STDM_0809303_0160": {
        "ID": "STDM_0809303_0160",
        "Text": "遅かったな　傑\nいや　早い方か"
      },
      "STDM_0809303_0170": {
        "ID": "STDM_0809303_0170",
        "Text": "……"
      },
      "STDM_0809303_0180": {
        "ID": "STDM_0809303_0180",
        "Text": "悟…だよな？"
      },
      "STDM_0809303_0190": {
        "ID": "STDM_0809303_0190",
        "Text": "何があった…！？"
      },
      "STDM_0809303_0200": {
        "ID": "STDM_0809303_0200",
        "Text": "硝子には会えたんだな"
      },
      "STDM_0809303_0210": {
        "ID": "STDM_0809303_0210",
        "Text": "あぁ　治してもらった\n私は問題ない"
      },
      "STDM_0809303_0220": {
        "ID": "STDM_0809303_0220",
        "Text": "いや　私に問題がなくても仕方ないな"
      },
      "STDM_0809303_0230": {
        "ID": "STDM_0809303_0230",
        "Text": "俺がしくった\nオマエは悪くない"
      },
      "STDM_0809303_0240": {
        "ID": "STDM_0809303_0240",
        "Text": "…戻ろう"
      },
      "STDM_0809303_0250": {
        "ID": "STDM_0809303_0250",
        "Text": "傑"
      },
      "STDM_0809303_0260": {
        "ID": "STDM_0809303_0260",
        "Text": "コイツら　殺すか？"
      },
      "STDM_0809303_0270": {
        "ID": "STDM_0809303_0270",
        "Text": "今の俺なら　多分何も感じない"
      },
      "STDM_0809303_0280": {
        "ID": "STDM_0809303_0280",
        "Text": "いい\n意味がない"
      },
      "STDM_0809303_0290": {
        "ID": "STDM_0809303_0290",
        "Text": "意味ね"
      },
      "STDM_0809303_0300": {
        "ID": "STDM_0809303_0300",
        "Text": "それ　本当に必要か？"
      },
      "STDM_0809303_0310": {
        "ID": "STDM_0809303_0310",
        "Text": "大事な事だ"
      },
      "STDM_0809303_0320": {
        "ID": "STDM_0809303_0320",
        "Text": "特に術師にはな"
      },
      "STDM_0809401_0010": {
        "ID": "STDM_0809401_0010",
        "Text": "その夏は忙しかった"
      },
      "STDM_0809401_0020": {
        "ID": "STDM_0809401_0020",
        "Text": "１年後\n２００７年　８月"
      },
      "STDM_0809401_0030": {
        "ID": "STDM_0809401_0030",
        "Text": "昨年頻発した災害の影響もあったのだろう\n蛆のように呪霊が湧いた"
      },
      "STDM_0809401_0040": {
        "ID": "STDM_0809401_0040",
        "Text": "祓う　取り込む　その繰り返し"
      },
      "STDM_0809401_0050": {
        "ID": "STDM_0809401_0050",
        "Text": "皆は知らない　呪霊の味\n吐瀉物を処理した雑巾を丸呑みにしているような"
      },
      "STDM_0809401_0060": {
        "ID": "STDM_0809401_0060",
        "Text": "誰のために？"
      },
      "STDM_0809401_0070": {
        "ID": "STDM_0809401_0070",
        "Text": "あの日から自分に言い聞かせている\n私が見たものは何も珍しくない\n周知の醜悪"
      },
      "STDM_0809401_0080": {
        "ID": "STDM_0809401_0080",
        "Text": "猿め"
      },
      "STDM_0809401_0090": {
        "ID": "STDM_0809401_0090",
        "Text": "自分にできることを精一杯頑張るのは\n気持ちがいいです"
      },
      "STDM_0809401_0100": {
        "ID": "STDM_0809401_0100",
        "Text": "知ってる？\n術師からは呪霊は生まれないんだよ"
      },
      "STDM_0809401_0110": {
        "ID": "STDM_0809401_0110",
        "Text": "はっ……"
      },
      "STDM_0809401_0120": {
        "ID": "STDM_0809401_0120",
        "Text": "じゃあ　非術師を皆殺しにすればいいじゃないですか"
      },
      "STDM_0809401_0130": {
        "ID": "STDM_0809401_0130",
        "Text": "夏油くん　それはありだ"
      },
      "STDM_0809401_0140": {
        "ID": "STDM_0809401_0140",
        "Text": "えっ……いや……"
      },
      "STDM_0809401_0150": {
        "ID": "STDM_0809401_0150",
        "Text": "非術師を間引き続け　生存戦略として術師に適応してもらう\n要は進化を促すの　鳥たちが翼を得たように"
      },
      "STDM_0809401_0160": {
        "ID": "STDM_0809401_0160",
        "Text": "だが残念ながら\n私はそこまでイカれてない"
      },
      "STDM_0809401_0170": {
        "ID": "STDM_0809401_0170",
        "Text": "非術師は嫌いかい？\n夏油君"
      },
      "STDM_0809401_0180": {
        "ID": "STDM_0809401_0180",
        "Text": "非術師を見下す君　それを否定する君"
      },
      "STDM_0809401_0185": {
        "ID": "STDM_0809401_0185",
        "Text": "どちらを本音にするのかは\n君がこれから選択するんだよ"
      },
      "STDM_0809401_0190": {
        "ID": "STDM_0809401_0190",
        "Text": "クソッ…！！"
      },
      "STDM_0809401_0200": {
        "ID": "STDM_0809401_0200",
        "Text": "産土神信仰…アレは土地神でした\n１級案件だ…！！"
      },
      "STDM_0809401_0210": {
        "ID": "STDM_0809401_0210",
        "Text": "術師というマラソンゲーム\nその果てにあるのが\n仲間の屍の山だとしたら？"
      },
      "STDM_0809401_0220": {
        "ID": "STDM_0809401_0220",
        "Text": "本校生徒における\n殺傷事件についての調査報告書"
      },
      "STDM_0809401_0230": {
        "ID": "STDM_0809401_0230",
        "Text": "これはなんですか？"
      },
      "STDM_0809401_0240": {
        "ID": "STDM_0809401_0240",
        "Text": "なにとは？\nこの２人が一連の事件の原因でしょう？"
      },
      "STDM_0809401_0250": {
        "ID": "STDM_0809401_0250",
        "Text": "違います"
      },
      "STDM_0809401_0260": {
        "ID": "STDM_0809401_0260",
        "Text": "調査対象生徒：東京校３年　夏油　傑"
      },
      "STDM_0809401_0270": {
        "ID": "STDM_0809401_0270",
        "Text": "皆さん　一旦外に出ましょうか"
      },
      "STDM_0809401_0280": {
        "ID": "STDM_0809401_0280",
        "Text": "夏油傑は現在も逃走中"
      },
      "STDM_0809401_0283": {
        "ID": "STDM_0809401_0283",
        "Text": "呪術規定９条に基づき、\n呪詛師として処刑対象となる。"
      },
      "STDM_0809401_0290": {
        "ID": "STDM_0809401_0290",
        "Text": "説明しろ　傑"
      },
      "STDM_0809401_0300": {
        "ID": "STDM_0809401_0300",
        "Text": "非術師殺して術師だけの世界を作る！？\n無理に決まってんだろ！！"
      },
      "STDM_0809401_0310": {
        "ID": "STDM_0809401_0310",
        "Text": "傲慢だな\n君にならできるだろ　悟"
      },
      "STDM_0809401_0320": {
        "ID": "STDM_0809401_0320",
        "Text": "自分にできることを\n他人には『できやしない』と言い聞かせるのか？"
      },
      "STDM_0809401_0330": {
        "ID": "STDM_0809401_0330",
        "Text": "君は五条悟だから最強なのか？\n最強だから五条悟なのか？"
      },
      "STDM_0809401_0340": {
        "ID": "STDM_0809401_0340",
        "Text": "何が言いてぇんだよ"
      },
      "STDM_0809401_0350": {
        "ID": "STDM_0809401_0350",
        "Text": "生き方は決めた\nあとは自分にできることを精一杯やるさ"
      },
      "STDM_0809401_0360": {
        "ID": "STDM_0809401_0360",
        "Text": "先生　俺強いよね"
      },
      "STDM_0809401_0370": {
        "ID": "STDM_0809401_0370",
        "Text": "あぁ　生意気にもな"
      },
      "STDM_0809401_0380": {
        "ID": "STDM_0809401_0380",
        "Text": "でも俺だけ強くても駄目らしいよ\n俺が救えるのは\n他人に救われる準備があるヤツだけだ"
      },
      "STDM_0809401_0390": {
        "ID": "STDM_0809401_0390",
        "Text": "伏黒　恵君だよね"
      },
      "STDM_0809401_0400": {
        "ID": "STDM_0809401_0400",
        "Text": "クックッ……オッケー"
      },
      "STDM_0809401_0405": {
        "ID": "STDM_0809401_0405",
        "Text": "後は任せなさい"
      },
      "STDM_0809401_0410": {
        "ID": "STDM_0809401_0410",
        "Text": "……"
      },
      "STDM_0809401_0420": {
        "ID": "STDM_0809401_0420",
        "Text": "強くなってよ\n僕に置いて行かれないくらい"
      },
      "STDM_0809401_0430": {
        "ID": "STDM_0809401_0430",
        "Text": "２０１８年　１０月１９日"
      },
      "STDM_0809401_0440": {
        "ID": "STDM_0809401_0440",
        "Text": "五条先生"
      },
      "STDM_0809401_0450": {
        "ID": "STDM_0809401_0450",
        "Text": "先生も寝るんだな"
      },
      "STDM_0809401_0460": {
        "ID": "STDM_0809401_0460",
        "Text": "当たり前でしょ　何言ってんのアンタ"
      },
      "STDM_0809401_0470": {
        "ID": "STDM_0809401_0470",
        "Text": "五条先生！！"
      },
      "STDM_0809401_0480": {
        "ID": "STDM_0809401_0480",
        "Text": "おっ　起きた"
      },
      "STDM_0809401_0490": {
        "ID": "STDM_0809401_0490",
        "Text": "ちょっとその椅子高いヤツでしょ"
      },
      "STDM_0809401_0500": {
        "ID": "STDM_0809401_0500",
        "Text": "呼びつけといて　居眠りしないでくださいよ"
      },
      "STDM_0809401_0510": {
        "ID": "STDM_0809401_0510",
        "Text": "……"
      },
      "STDM_0809401_0520": {
        "ID": "STDM_0809401_0520",
        "Text": "何笑ってんスか"
      },
      "STDM_0809401_0530": {
        "ID": "STDM_0809401_0530",
        "Text": "別に"
      }
    }
  }
]