[
  {
    "Type": "DataTable",
    "Name": "StampTextDataTable_It",
    "Flags": "RF_Public | RF_Standalone | RF_Transactional | RF_WasLoaded | RF_LoadCompleted",
    "Class": "UScriptClass'DataTable'",
    "Properties": {
      "RowStruct": {
        "ObjectName": "Class'GameDataTableRow_GameText'",
        "ObjectPath": "/Script/Abrams"
      },
      "ImportKeyField": "Id"
    },
    "Rows": {
      "CP_010_STAMP_001": {
        "ID": "CP_010_STAMP_001",
        "Text": "È un onore."
      },
      "CP_010_STAMP_002": {
        "ID": "CP_010_STAMP_002",
        "Text": "Grazie davvero."
      },
      "CP_020_STAMP_001": {
        "ID": "CP_020_STAMP_001",
        "Text": "Così mi piaci.\nImpegnati solo un po' di più."
      },
      "CP_030_STAMP_001": {
        "ID": "CP_030_STAMP_001",
        "Text": "Neanche io voglio perdere."
      },
      "CP_030_STAMP_002": {
        "ID": "CP_030_STAMP_002",
        "Text": "Ti faccio vedere."
      },
      "CP_040_STAMP_001": {
        "ID": "CP_040_STAMP_001",
        "Text": "Non dormi abbastanza?"
      },
      "CP_040_STAMP_002": {
        "ID": "CP_040_STAMP_002",
        "Text": "Centro."
      },
      "CP_050_STAMP_001": {
        "ID": "CP_050_STAMP_001",
        "Text": "Ehilà."
      },
      "CP_050_STAMP_002": {
        "ID": "CP_050_STAMP_002",
        "Text": "Così!"
      },
      "CP_060_STAMP_001": {
        "ID": "CP_060_STAMP_001",
        "Text": "Non ci andrò piano con te, lo sai."
      },
      "CP_070_STAMP_001": {
        "ID": "CP_070_STAMP_001",
        "Text": "Tonno pinna gialla. Uova di gambero."
      },
      "CP_080_STAMP_001": {
        "ID": "CP_080_STAMP_001",
        "Text": "Sono Panda. Piacere di conoscerti."
      },
      "CP_090_STAMP_001": {
        "ID": "CP_090_STAMP_001",
        "Text": "Lavorare fa schifo."
      },
      "CP_100_STAMP_001": {
        "ID": "CP_100_STAMP_001",
        "Text": "Com'è la tua\nragazza ideale?"
      },
      "CP_110_STAMP_001": {
        "ID": "CP_110_STAMP_001",
        "Text": "Facciamo del nostro meglio!"
      },
      "CP_120_STAMP_001": {
        "ID": "CP_120_STAMP_001",
        "Text": "Facciamoci una foto."
      },
      "CP_130_STAMP_001": {
        "ID": "CP_130_STAMP_001",
        "Text": "Ti sono molto grato."
      },
      "CP_140_STAMP_001": {
        "ID": "CP_140_STAMP_001",
        "Text": "Che è successo?"
      },
      "CP_150_STAMP_001": {
        "ID": "CP_150_STAMP_001",
        "Text": "Mi sto godendo la battaglia."
      },
      "CP_160_STAMP_001": {
        "ID": "CP_160_STAMP_001",
        "Text": "Vi uccimaledico!"
      },
      "CP_051_STAMP_001": {
        "ID": "CP_051_STAMP_001",
        "Text": "Stai piangendo?"
      },
      "CP_051_STAMP_002": {
        "ID": "CP_051_STAMP_002",
        "Text": "In tutto il creato, non c'è essere più prezioso di me."
      },
      "CP_121_STAMP_001": {
        "ID": "CP_121_STAMP_001",
        "Text": "Aiutare i deboli e tenere a bada i forti."
      },
      "CP_121_STAMP_002": {
        "ID": "CP_121_STAMP_002",
        "Text": "Siamo i più forti."
      },
      "CP_170_STAMP_001": {
        "ID": "CP_170_STAMP_001",
        "Text": "Per fortuna è andato a segno!"
      },
      "CP_170_STAMP_002": {
        "ID": "CP_170_STAMP_002",
        "Text": "Che egocentrico!"
      },
      "CP_170_STAMP_003": {
        "ID": "CP_170_STAMP_003",
        "Text": "Oh, poverino..."
      },
      "CP_180_STAMP_001": {
        "ID": "CP_180_STAMP_001",
        "Text": "Forza. Nessuno è più adorabile di te!"
      },
      "CP_180_STAMP_002": {
        "ID": "CP_180_STAMP_002",
        "Text": "Non c'è niente di carino..."
      },
      "CP_190_STAMP_001": {
        "ID": "CP_190_STAMP_001",
        "Text": "Non posso permettermi di perdere. Mi rifiuto."
      },
      "CP_190_STAMP_002": {
        "ID": "CP_190_STAMP_002",
        "Text": "Ho preso io questa decisione."
      },
      "CP_200_STAMP_001": {
        "ID": "CP_200_STAMP_001",
        "Text": "Bravo, missione compiuta. Ora puoi pure andartene."
      },
      "CP_200_STAMP_002": {
        "ID": "CP_200_STAMP_002",
        "Text": "Lo scontro deve ancora cominciare."
      },
      "CP_210_STAMP_001": {
        "ID": "CP_210_STAMP_001",
        "Text": "Non possiamo andare tutti d'accordo?"
      },
      "CP_210_STAMP_002": {
        "ID": "CP_210_STAMP_002",
        "Text": "Ciao! Sono Miwa l'inutile!"
      },
      "CP_220_STAMP_001": {
        "ID": "CP_220_STAMP_001",
        "Text": "Patto Celeste. Hai presente?"
      },
      "CP_220_STAMP_002": {
        "ID": "CP_220_STAMP_002",
        "Text": "Tu sei...?"
      },
      "CP_230_STAMP_001": {
        "ID": "CP_230_STAMP_001",
        "Text": "Compirò il mio dovere da fratellone, con tutta la mia forza!"
      },
      "CP_230_STAMP_002": {
        "ID": "CP_230_STAMP_002",
        "Text": "Sono il fratellone di Yuji!"
      },
      "CP_240_STAMP_001": {
        "ID": "CP_240_STAMP_001",
        "Text": "Muori per me, d'accordo?"
      },
      "CP_240_STAMP_002": {
        "ID": "CP_240_STAMP_002",
        "Text": "Sono dalla parte dei soldi, ovvio."
      },
      "CP_270_STAMP_001": {
        "ID": "CP_270_STAMP_001",
        "Text": "Scordatelo."
      },
      "CP_270_STAMP_002": {
        "ID": "CP_270_STAMP_002",
        "Text": "La pagherai."
      }
    }
  }
]