[
  {
    "Type": "DataTable",
    "Name": "DlcStoryDemoTextDataTable1_Zh_Hans",
    "Flags": "RF_Public | RF_Standalone | RF_Transactional | RF_WasLoaded | RF_LoadCompleted",
    "Class": "UScriptClass'DataTable'",
    "Properties": {
      "RowStruct": {
        "ObjectName": "Class'GameDataTableRow_GameText'",
        "ObjectPath": "/Script/Abrams"
      },
      "ImportKeyField": "Id"
    },
    "Rows": {
      "STDM_0809001_0010": {
        "ID": "STDM_0809001_0010",
        "Text": "没问题的吧"
      },
      "STDM_0809001_0015": {
        "ID": "STDM_0809001_0015",
        "Text": "因为我们是最强的"
      },
      "STDM_0809001_0020": {
        "ID": "STDM_0809001_0020",
        "Text": "静冈县滨松市\n2006年"
      },
      "STDM_0809001_0030": {
        "ID": "STDM_0809001_0030",
        "Text": "我来帮你啰～"
      },
      "STDM_0809001_0040": {
        "ID": "STDM_0809001_0040",
        "Text": "咒术高专二年级　五条悟"
      },
      "STDM_0809001_0050": {
        "ID": "STDM_0809001_0050",
        "Text": "要迁就那些弱者实在很累人耶"
      },
      "STDM_0809001_0060": {
        "ID": "STDM_0809001_0060",
        "Text": "悟，欺负弱者不好喔"
      },
      "STDM_0809001_0070": {
        "ID": "STDM_0809001_0070",
        "Text": "咒术高专二年级　夏油杰"
      },
      "STDM_0809001_0080": {
        "ID": "STDM_0809001_0080",
        "Text": "弱者生存，这才是社会应该有的面貌"
      },
      "STDM_0809001_0090": {
        "ID": "STDM_0809001_0090",
        "Text": "这任务由你们两人执行。委托有2个\n对于星浆体，身为天元大人合适者的少女\n加以护卫——和消除\n"
      },
      "STDM_0809001_0100": {
        "ID": "STDM_0809001_0100",
        "Text": "失败的话对一般社会也会造成影响\n执行时要记住这点！！"
      },
      "STDM_0809001_0110": {
        "ID": "STDM_0809001_0110",
        "Text": "因「Q」的最高战力拜尔脱队\n组织瓦解"
      },
      "STDM_0809001_0120": {
        "ID": "STDM_0809001_0120",
        "Text": "好啊，这工作我接了"
      },
      "STDM_0809001_0130": {
        "ID": "STDM_0809001_0130",
        "Text": "对手可是五条家的少爷\n大摇大摆地现身会什么事都做不了"
      },
      "STDM_0809001_0140": {
        "ID": "STDM_0809001_0140",
        "Text": "先用一些笨蛋削减他的精神"
      },
      "STDM_0809001_0150": {
        "ID": "STDM_0809001_0150",
        "Text": "啧！"
      },
      "STDM_0809001_0160": {
        "ID": "STDM_0809001_0160",
        "Text": "就拜托你了，术师杀手"
      },
      "STDM_0809001_0165": {
        "ID": "STDM_0809001_0165",
        "Text": "啊，对了，惠过得好吗？"
      },
      "STDM_0809001_0170": {
        "ID": "STDM_0809001_0170",
        "Text": "……"
      },
      "STDM_0809001_0175": {
        "ID": "STDM_0809001_0175",
        "Text": "你说谁？"
      },
      "STDM_0809001_0180": {
        "ID": "STDM_0809001_0180",
        "Text": "五条在冲绳救出黑井"
      },
      "STDM_0809001_0190": {
        "ID": "STDM_0809001_0190",
        "Text": "欢～迎～！！"
      },
      "STDM_0809001_0200": {
        "ID": "STDM_0809001_0200",
        "Text": "冲绳\n护卫第2天"
      },
      "STDM_0809001_0210": {
        "ID": "STDM_0809001_0210",
        "Text": "东京都立咒术高专　筵山麓"
      },
      "STDM_0809001_0220": {
        "ID": "STDM_0809001_0220",
        "Text": "护卫第3天　15:00"
      },
      "STDM_0809001_0230": {
        "ID": "STDM_0809001_0230",
        "Text": "这里是高专的结界内了"
      },
      "STDM_0809001_0240": {
        "ID": "STDM_0809001_0240",
        "Text": "悟，真的辛苦你了"
      },
      "STDM_0809001_0250": {
        "ID": "STDM_0809001_0250",
        "Text": "呼～我不想再当小鬼的保母了"
      },
      "STDM_0809001_0260": {
        "ID": "STDM_0809001_0260",
        "Text": "啊……啊啊……"
      },
      "STDM_0809001_0270": {
        "ID": "STDM_0809001_0270",
        "Text": "我有在哪里见过你吗？"
      },
      "STDM_0809001_0280": {
        "ID": "STDM_0809001_0280",
        "Text": "不必在意\n我也很不擅长记男人的名字"
      },
      "STDM_0809101_0010": {
        "ID": "STDM_0809101_0010",
        "Text": "唔……！"
      },
      "STDM_0809101_0020": {
        "ID": "STDM_0809101_0020",
        "Text": "悟！"
      },
      "STDM_0809101_0030": {
        "ID": "STDM_0809101_0030",
        "Text": "就像是安全别针穿过了针织毛衣一样\n真的没问题的"
      },
      "STDM_0809101_0040": {
        "ID": "STDM_0809101_0040",
        "Text": "更重要的是优先保护天内\n我来对付那家伙"
      },
      "STDM_0809101_0050": {
        "ID": "STDM_0809101_0050",
        "Text": "杰你们先到天元大人那里去"
      },
      "STDM_0809101_0060": {
        "ID": "STDM_0809101_0060",
        "Text": "悟……"
      },
      "STDM_0809101_0070": {
        "ID": "STDM_0809101_0070",
        "Text": "别大意了喔"
      },
      "STDM_0809101_0080": {
        "ID": "STDM_0809101_0080",
        "Text": "你以为你在对谁说话啊？"
      },
      "STDM_0809101_0090": {
        "ID": "STDM_0809101_0090",
        "Text": "可以的话希望在刚才那击就解决五条悟的……\n是我生疏了吗"
      },
      "STDM_0809101_0100": {
        "ID": "STDM_0809101_0100",
        "Text": "天内的悬赏金已经被取消了啊，你这笨蛋"
      },
      "STDM_0809101_0110": {
        "ID": "STDM_0809101_0110",
        "Text": "是我取消的，你这嘴硬的家伙"
      },
      "STDM_0809101_0120": {
        "ID": "STDM_0809101_0120",
        "Text": "像你这种没有破绽的家伙\n就是要分轻重缓急，制造几个假的终点"
      },
      "STDM_0809101_0130": {
        "ID": "STDM_0809101_0130",
        "Text": "悬赏金如果没有时间限制\n我想你到最后都不会解除术式的"
      },
      "STDM_0809101_0140": {
        "ID": "STDM_0809101_0140",
        "Text": "啊，是吗"
      },
      "STDM_0809102_0010": {
        "ID": "STDM_0809102_0010",
        "Text": "我就觉得这家伙哪里奇怪\n他完全没有咒力！"
      },
      "STDM_0809102_0020": {
        "ID": "STDM_0809102_0020",
        "Text": "是天与咒缚的肉体天赋！！"
      },
      "STDM_0809103_0010": {
        "ID": "STDM_0809103_0010",
        "Text": "术式顺转，最大输出"
      },
      "STDM_0809103_0020": {
        "ID": "STDM_0809103_0020",
        "Text": "「苍」"
      },
      "STDM_0809103_0030": {
        "ID": "STDM_0809103_0030",
        "Text": "没有遮蔽物，他没办法突袭"
      },
      "STDM_0809103_0040": {
        "ID": "STDM_0809103_0040",
        "Text": "那是……"
      },
      "STDM_0809103_0041": {
        "ID": "STDM_0809103_0041",
        "Text": "蝇头！？"
      },
      "STDM_0809103_0050": {
        "ID": "STDM_0809103_0050",
        "Text": "把它当成干扰来用是吗"
      },
      "STDM_0809103_0060": {
        "ID": "STDM_0809103_0060",
        "Text": "死角也出现了，再用一次「苍」……"
      },
      "STDM_0809103_0070": {
        "ID": "STDM_0809103_0070",
        "Text": "不，等等，他的目标是天内——"
      },
      "STDM_0809103_0080": {
        "ID": "STDM_0809103_0080",
        "Text": "直觉好到能察觉空手的我"
      },
      "STDM_0809103_0090": {
        "ID": "STDM_0809103_0090",
        "Text": "但你终于依靠术式防守了啊"
      },
      "STDM_0809201_0010": {
        "ID": "STDM_0809201_0010",
        "Text": "这里就是……"
      },
      "STDM_0809201_0020": {
        "ID": "STDM_0809201_0020",
        "Text": "对，天元大人膝下"
      },
      "STDM_0809201_0030": {
        "ID": "STDM_0809201_0030",
        "Text": "国内主要结界的根基，薨星宫本殿"
      },
      "STDM_0809201_0040": {
        "ID": "STDM_0809201_0040",
        "Text": "你要走下阶梯通过门\n到那棵大树的根部去"
      },
      "STDM_0809201_0050": {
        "ID": "STDM_0809201_0050",
        "Text": "到同化为止，天元大人会保护你"
      },
      "STDM_0809201_0060": {
        "ID": "STDM_0809201_0060",
        "Text": "或者你要在这里回头\n和黑井小姐一起回家"
      },
      "STDM_0809201_0070": {
        "ID": "STDM_0809201_0070",
        "Text": "……咦？"
      },
      "STDM_0809201_0080": {
        "ID": "STDM_0809201_0080",
        "Text": "在和你碰面前，我和悟谈过了"
      },
      "STDM_0809201_0090": {
        "ID": "STDM_0809201_0090",
        "Text": "你说星浆体小鬼拒绝同化的话？"
      },
      "STDM_0809201_0100": {
        "ID": "STDM_0809201_0100",
        "Text": "那时候就……不同化了！"
      },
      "STDM_0809201_0110": {
        "ID": "STDM_0809201_0110",
        "Text": "呵呵，可以吗？"
      },
      "STDM_0809201_0120": {
        "ID": "STDM_0809201_0120",
        "Text": "也许会演变成和天元大人对战喔"
      },
      "STDM_0809201_0130": {
        "ID": "STDM_0809201_0130",
        "Text": "你在怕吗？"
      },
      "STDM_0809201_0140": {
        "ID": "STDM_0809201_0140",
        "Text": "没问题，总会有办法啦"
      },
      "STDM_0809201_0150": {
        "ID": "STDM_0809201_0150",
        "Text": "我们是最强的"
      },
      "STDM_0809201_0160": {
        "ID": "STDM_0809201_0160",
        "Text": "不论理子你怎么选择\n我们都会保障你的未来"
      },
      "STDM_0809201_0170": {
        "ID": "STDM_0809201_0170",
        "Text": "……我"
      },
      "STDM_0809201_0180": {
        "ID": "STDM_0809201_0180",
        "Text": "从出生时就被说是特别的\n和大家不同"
      },
      "STDM_0809201_0190": {
        "ID": "STDM_0809201_0190",
        "Text": "对我来说，作为星浆体是很正常的"
      },
      "STDM_0809201_0200": {
        "ID": "STDM_0809201_0200",
        "Text": "尽量避开危险的事\n就为了这一天活到现在"
      },
      "STDM_0809201_0210": {
        "ID": "STDM_0809201_0210",
        "Text": "所以我本来以为就算同化了\n和大家分开也没有关系"
      },
      "STDM_0809201_0220": {
        "ID": "STDM_0809201_0220",
        "Text": "……可是\n可是我果然还是"
      },
      "STDM_0809201_0230": {
        "ID": "STDM_0809201_0230",
        "Text": "想多和大家在一起"
      },
      "STDM_0809201_0240": {
        "ID": "STDM_0809201_0240",
        "Text": "想和大家一起去更多地方\n去看各种事物……看更多！！"
      },
      "STDM_0809201_0250": {
        "ID": "STDM_0809201_0250",
        "Text": "我们回去吧，理子"
      },
      "STDM_0809201_0260": {
        "ID": "STDM_0809201_0260",
        "Text": "……嗯！！"
      },
      "STDM_0809201_0270": {
        "ID": "STDM_0809201_0270",
        "Text": "理子？"
      },
      "STDM_0809201_0280": {
        "ID": "STDM_0809201_0280",
        "Text": "好了，辛苦了\n解散解散"
      },
      "STDM_0809201_0290": {
        "ID": "STDM_0809201_0290",
        "Text": "你为什么会在这里"
      },
      "STDM_0809201_0300": {
        "ID": "STDM_0809201_0300",
        "Text": "啊啊？你说为什么……"
      },
      "STDM_0809201_0310": {
        "ID": "STDM_0809201_0310",
        "Text": "啊啊，是那个意思啊"
      },
      "STDM_0809201_0320": {
        "ID": "STDM_0809201_0320",
        "Text": "我杀了五条悟"
      },
      "STDM_0809201_0330": {
        "ID": "STDM_0809201_0330",
        "Text": "是吗"
      },
      "STDM_0809201_0340": {
        "ID": "STDM_0809201_0340",
        "Text": "那去死吧"
      },
      "STDM_0809202_0010": {
        "ID": "STDM_0809202_0010",
        "Text": "你为什么会知道通往薨星宫的门？\n我们完全没有留下残秽"
      },
      "STDM_0809202_0020": {
        "ID": "STDM_0809202_0020",
        "Text": "人类会留下的痕迹不是只有残秽"
      },
      "STDM_0809202_0030": {
        "ID": "STDM_0809202_0030",
        "Text": "味道，足迹\n我的五感也因为咒缚而大幅提升"
      },
      "STDM_0809202_0040": {
        "ID": "STDM_0809202_0040",
        "Text": "途中应该有一位女性在，她怎么了？"
      },
      "STDM_0809202_0050": {
        "ID": "STDM_0809202_0050",
        "Text": "嗯？喔，那个女仆吗，应该死了\n虽然我没有特别想放走她或杀她"
      },
      "STDM_0809202_0060": {
        "ID": "STDM_0809202_0060",
        "Text": "运气好的话还活着吧？"
      },
      "STDM_0809202_0070": {
        "ID": "STDM_0809202_0070",
        "Text": "是吗，果然你还是去死吧"
      },
      "STDM_0809203_0010": {
        "ID": "STDM_0809203_0010",
        "Text": "蠢蛋……你完了"
      },
      "STDM_0809203_0020": {
        "ID": "STDM_0809203_0020",
        "Text": "你才完了"
      },
      "STDM_0809203_0030": {
        "ID": "STDM_0809203_0030",
        "Text": "能力虽然特殊，但咒灵本身并不强\n我能吸收！！"
      },
      "STDM_0809203_0040": {
        "ID": "STDM_0809203_0040",
        "Text": "武器库已经扣押了\n再来只要靠数量硬攻——"
      },
      "STDM_0809203_0050": {
        "ID": "STDM_0809203_0050",
        "Text": "什么……！！"
      },
      "STDM_0809203_0060": {
        "ID": "STDM_0809203_0060",
        "Text": "我用术师不会因此死亡的程度砍的"
      },
      "STDM_0809203_0070": {
        "ID": "STDM_0809203_0070",
        "Text": "如果是式神使我就杀了\n但咒灵操术不一样"
      },
      "STDM_0809203_0080": {
        "ID": "STDM_0809203_0080",
        "Text": "我不确定你死了之后\n你吸收的咒灵会变成怎样"
      },
      "STDM_0809203_0090": {
        "ID": "STDM_0809203_0090",
        "Text": "我现在想尽量避免麻烦\n所以你应该感谢父母呢"
      },
      "STDM_0809203_0100": {
        "ID": "STDM_0809203_0100",
        "Text": "但是受遗传恩惠的你们\n输给了我这种连咒术都不会用的猴子"
      },
      "STDM_0809203_0110": {
        "ID": "STDM_0809203_0110",
        "Text": "想活得久就别忘了这点"
      },
      "STDM_0809203_0120": {
        "ID": "STDM_0809203_0120",
        "Text": "啊——"
      },
      "STDM_0809203_0130": {
        "ID": "STDM_0809203_0130",
        "Text": "说到惠，对了对了"
      },
      "STDM_0809203_0140": {
        "ID": "STDM_0809203_0140",
        "Text": "是我取名的啊"
      },
      "STDM_0809301_0010": {
        "ID": "STDM_0809301_0010",
        "Text": "某天，被杀害的星浆体——天内理子的遗体\n由伏黑甚尔本人送达盘星教本部，星之子之家"
      },
      "STDM_0809301_0020": {
        "ID": "STDM_0809301_0020",
        "Text": "盘星教代表园田茂、伏黑甚尔\n担任仲介的孔时雨\n三人进行了遗体的交付"
      },
      "STDM_0809301_0030": {
        "ID": "STDM_0809301_0030",
        "Text": "唷，好久不见"
      },
      "STDM_0809301_0040": {
        "ID": "STDM_0809301_0040",
        "Text": "真的假的"
      },
      "STDM_0809301_0050": {
        "ID": "STDM_0809301_0050",
        "Text": "真的真的，我超有精神"
      },
      "STDM_0809301_0060": {
        "ID": "STDM_0809301_0060",
        "Text": "反转术式！！"
      },
      "STDM_0809301_0070": {
        "ID": "STDM_0809301_0070",
        "Text": "答对了！！"
      },
      "STDM_0809301_0080": {
        "ID": "STDM_0809301_0080",
        "Text": "我到目前为止也都没成功过"
      },
      "STDM_0809301_0090": {
        "ID": "STDM_0809301_0090",
        "Text": "但在濒死的时候\n我掌握到了咒力的核心！"
      },
      "STDM_0809301_0100": {
        "ID": "STDM_0809301_0100",
        "Text": "你的败因就是没有把我的头砍下\n还有没用那把咒具刺进我的头"
      },
      "STDM_0809301_0110": {
        "ID": "STDM_0809301_0110",
        "Text": "……败因？"
      },
      "STDM_0809301_0120": {
        "ID": "STDM_0809301_0120",
        "Text": "胜负现在才要开始吧"
      },
      "STDM_0809301_0130": {
        "ID": "STDM_0809301_0130",
        "Text": "啊——？是吗？是啊"
      },
      "STDM_0809301_0140": {
        "ID": "STDM_0809301_0140",
        "Text": "……也许是吧！！"
      },
      "STDM_0809302_0010": {
        "ID": "STDM_0809302_0010",
        "Text": "抱歉，天内"
      },
      "STDM_0809302_0020": {
        "ID": "STDM_0809302_0020",
        "Text": "我现在没有为了你生气\n也没有憎恨任何人"
      },
      "STDM_0809302_0030": {
        "ID": "STDM_0809302_0030",
        "Text": "只是觉得这个世界很舒服"
      },
      "STDM_0809302_0040": {
        "ID": "STDM_0809302_0040",
        "Text": "天上天下，唯我独尊"
      },
      "STDM_0809302_0050": {
        "ID": "STDM_0809302_0050",
        "Text": "顺转和反转\n让它们彼此的无限互相冲突\n并推送出因此产生的虚幻质量"
      },
      "STDM_0809303_0010": {
        "ID": "STDM_0809303_0010",
        "Text": "不对劲"
      },
      "STDM_0809303_0020": {
        "ID": "STDM_0809303_0020",
        "Text": "「我才不想做白工」\n平常的我应该会这么说然后闪人"
      },
      "STDM_0809303_0030": {
        "ID": "STDM_0809303_0030",
        "Text": "但看到在眼前觉醒的无下限咒术高手\n大概已经成了现代最强的术师"
      },
      "STDM_0809303_0040": {
        "ID": "STDM_0809303_0040",
        "Text": "我变得想否定他\n想试着用力量压制他"
      },
      "STDM_0809303_0050": {
        "ID": "STDM_0809303_0050",
        "Text": "否定曾否定我的禅院家、咒术界\n否定他们之间的顶点"
      },
      "STDM_0809303_0060": {
        "ID": "STDM_0809303_0060",
        "Text": "为了肯定自己\n我扭曲了平常的自己"
      },
      "STDM_0809303_0070": {
        "ID": "STDM_0809303_0070",
        "Text": "在这时候我就已经输了"
      },
      "STDM_0809303_0080": {
        "ID": "STDM_0809303_0080",
        "Text": "我明明早就舍弃自尊心了才对"
      },
      "STDM_0809303_0090": {
        "ID": "STDM_0809303_0090",
        "Text": "不把自己和他人当一回事\n我应该早就选择了这种生活方式"
      },
      "STDM_0809303_0100": {
        "ID": "STDM_0809303_0100",
        "Text": "你在最后有想说的话吗？"
      },
      "STDM_0809303_0110": {
        "ID": "STDM_0809303_0110",
        "Text": "……没有"
      },
      "STDM_0809303_0120": {
        "ID": "STDM_0809303_0120",
        "Text": "再过2、3年\n我的小孩会被卖到禅院家"
      },
      "STDM_0809303_0130": {
        "ID": "STDM_0809303_0130",
        "Text": "随你处置吧"
      },
      "STDM_0809303_0140": {
        "ID": "STDM_0809303_0140",
        "Text": "之后，咒术高专二年级生五条悟\n在盘星教设施内回收星浆体天内理子的遗体"
      },
      "STDM_0809303_0150": {
        "ID": "STDM_0809303_0150",
        "Text": "不久后，咒术高专二年级生夏油杰也到场会合"
      },
      "STDM_0809303_0160": {
        "ID": "STDM_0809303_0160",
        "Text": "你真慢啊，杰\n不，是算快的了吗"
      },
      "STDM_0809303_0170": {
        "ID": "STDM_0809303_0170",
        "Text": "……"
      },
      "STDM_0809303_0180": {
        "ID": "STDM_0809303_0180",
        "Text": "你是……悟对吧？"
      },
      "STDM_0809303_0190": {
        "ID": "STDM_0809303_0190",
        "Text": "发生什么事了……！？"
      },
      "STDM_0809303_0200": {
        "ID": "STDM_0809303_0200",
        "Text": "你见到硝子了吧"
      },
      "STDM_0809303_0210": {
        "ID": "STDM_0809303_0210",
        "Text": "对，她医治我了\n我没事"
      },
      "STDM_0809303_0220": {
        "ID": "STDM_0809303_0220",
        "Text": "不对，我没事也没意义吧"
      },
      "STDM_0809303_0230": {
        "ID": "STDM_0809303_0230",
        "Text": "是我的失误，你没有错"
      },
      "STDM_0809303_0240": {
        "ID": "STDM_0809303_0240",
        "Text": "……我们回去吧"
      },
      "STDM_0809303_0250": {
        "ID": "STDM_0809303_0250",
        "Text": "杰"
      },
      "STDM_0809303_0260": {
        "ID": "STDM_0809303_0260",
        "Text": "要杀了这些家伙吗？"
      },
      "STDM_0809303_0270": {
        "ID": "STDM_0809303_0270",
        "Text": "现在的我，大概不会有任何感觉"
      },
      "STDM_0809303_0280": {
        "ID": "STDM_0809303_0280",
        "Text": "不必了，这样没有意义"
      },
      "STDM_0809303_0290": {
        "ID": "STDM_0809303_0290",
        "Text": "意义啊"
      },
      "STDM_0809303_0300": {
        "ID": "STDM_0809303_0300",
        "Text": "那种东西真的有需要吗？"
      },
      "STDM_0809303_0310": {
        "ID": "STDM_0809303_0310",
        "Text": "意义是很重要的"
      },
      "STDM_0809303_0320": {
        "ID": "STDM_0809303_0320",
        "Text": "尤其是对术师来说"
      },
      "STDM_0809401_0010": {
        "ID": "STDM_0809401_0010",
        "Text": "那年夏天很忙"
      },
      "STDM_0809401_0020": {
        "ID": "STDM_0809401_0020",
        "Text": "1年后\n2007年　8月"
      },
      "STDM_0809401_0030": {
        "ID": "STDM_0809401_0030",
        "Text": "可能是受去年频繁发生的灾害影响\n咒灵像蛆一样大量出现"
      },
      "STDM_0809401_0040": {
        "ID": "STDM_0809401_0040",
        "Text": "祓除、吸收，不断重复"
      },
      "STDM_0809401_0050": {
        "ID": "STDM_0809401_0050",
        "Text": "大家所不知道的咒灵味道\n是像把擦过呕吐物的抹布整条吞下去一样"
      },
      "STDM_0809401_0060": {
        "ID": "STDM_0809401_0060",
        "Text": "这是为了谁？"
      },
      "STDM_0809401_0070": {
        "ID": "STDM_0809401_0070",
        "Text": "从那天起，我就一直告诉自己\n我看到的东西并不稀奇\n是众所皆知的丑恶"
      },
      "STDM_0809401_0080": {
        "ID": "STDM_0809401_0080",
        "Text": "臭猴子"
      },
      "STDM_0809401_0090": {
        "ID": "STDM_0809401_0090",
        "Text": "尽力去做自己能做到的事，感觉很舒服"
      },
      "STDM_0809401_0100": {
        "ID": "STDM_0809401_0100",
        "Text": "你知道吗？术师不会产生咒灵"
      },
      "STDM_0809401_0110": {
        "ID": "STDM_0809401_0110",
        "Text": "啊……"
      },
      "STDM_0809401_0120": {
        "ID": "STDM_0809401_0120",
        "Text": "那么，只要把非术师都杀掉不就好了"
      },
      "STDM_0809401_0130": {
        "ID": "STDM_0809401_0130",
        "Text": "夏油，这是可行的"
      },
      "STDM_0809401_0140": {
        "ID": "STDM_0809401_0140",
        "Text": "咦……不是的……"
      },
      "STDM_0809401_0150": {
        "ID": "STDM_0809401_0150",
        "Text": "不断减少非术师，让他们为了生存战略而适应术师\n简单说就是促使进化，像鸟长出翅膀那样"
      },
      "STDM_0809401_0160": {
        "ID": "STDM_0809401_0160",
        "Text": "但很可惜，我还没有那么疯狂"
      },
      "STDM_0809401_0170": {
        "ID": "STDM_0809401_0170",
        "Text": "你讨厌非术师吗？夏油"
      },
      "STDM_0809401_0180": {
        "ID": "STDM_0809401_0180",
        "Text": "瞧不起非术师的你\n还有否定这点的你\n"
      },
      "STDM_0809401_0185": {
        "ID": "STDM_0809401_0185",
        "Text": "要把哪一边当成你的真心话\n是你今后要选择的"
      },
      "STDM_0809401_0190": {
        "ID": "STDM_0809401_0190",
        "Text": "可恶……！！"
      },
      "STDM_0809401_0200": {
        "ID": "STDM_0809401_0200",
        "Text": "产土神信仰……那是土地神\n是一级案件……！！"
      },
      "STDM_0809401_0210": {
        "ID": "STDM_0809401_0210",
        "Text": "术师这场马拉松比赛\n如果尽头是伙伴堆积成山的尸体呢？"
      },
      "STDM_0809401_0220": {
        "ID": "STDM_0809401_0220",
        "Text": "关于本校学生杀伤事件的调查报告书"
      },
      "STDM_0809401_0230": {
        "ID": "STDM_0809401_0230",
        "Text": "这是怎么回事？"
      },
      "STDM_0809401_0240": {
        "ID": "STDM_0809401_0240",
        "Text": "怎么回事？\n这两人就是这一连串事件的原因吧？"
      },
      "STDM_0809401_0250": {
        "ID": "STDM_0809401_0250",
        "Text": "不是的"
      },
      "STDM_0809401_0260": {
        "ID": "STDM_0809401_0260",
        "Text": "调查对象学生：东京校3年级　夏油杰"
      },
      "STDM_0809401_0270": {
        "ID": "STDM_0809401_0270",
        "Text": "各位，我们先到外面去一下吧"
      },
      "STDM_0809401_0280": {
        "ID": "STDM_0809401_0280",
        "Text": "夏油杰现在也正在逃亡"
      },
      "STDM_0809401_0283": {
        "ID": "STDM_0809401_0283",
        "Text": "依咒术规定第9条\n视为咒诅师列入处刑对象"
      },
      "STDM_0809401_0290": {
        "ID": "STDM_0809401_0290",
        "Text": "快说明啊，杰"
      },
      "STDM_0809401_0300": {
        "ID": "STDM_0809401_0300",
        "Text": "杀掉非术师创造只有术师的世界！？\n那种事怎么可能做到！！"
      },
      "STDM_0809401_0310": {
        "ID": "STDM_0809401_0310",
        "Text": "这么说太傲慢了\n是你的话就有可能做到吧，悟"
      },
      "STDM_0809401_0320": {
        "ID": "STDM_0809401_0320",
        "Text": "自己能做到的事\n却要说服别人「不可能办到」吗？"
      },
      "STDM_0809401_0330": {
        "ID": "STDM_0809401_0330",
        "Text": "因为你是五条悟所以最强？\n还是因为最强所以才是五条悟？"
      },
      "STDM_0809401_0340": {
        "ID": "STDM_0809401_0340",
        "Text": "你到底想说什么"
      },
      "STDM_0809401_0350": {
        "ID": "STDM_0809401_0350",
        "Text": "生存之道已定\n之后就是尽量去做自己能做到的"
      },
      "STDM_0809401_0360": {
        "ID": "STDM_0809401_0360",
        "Text": "老师，我很强对吧"
      },
      "STDM_0809401_0370": {
        "ID": "STDM_0809401_0370",
        "Text": "嗯，强到很嚣张"
      },
      "STDM_0809401_0380": {
        "ID": "STDM_0809401_0380",
        "Text": "但看来只有我强是不行的\n我能拯救的\n只有准备好被他人拯救的人而已"
      },
      "STDM_0809401_0390": {
        "ID": "STDM_0809401_0390",
        "Text": "你是伏黑惠小弟弟对吧"
      },
      "STDM_0809401_0400": {
        "ID": "STDM_0809401_0400",
        "Text": "呵呵……OK"
      },
      "STDM_0809401_0405": {
        "ID": "STDM_0809401_0405",
        "Text": "之后就交给我"
      },
      "STDM_0809401_0410": {
        "ID": "STDM_0809401_0410",
        "Text": "……"
      },
      "STDM_0809401_0420": {
        "ID": "STDM_0809401_0420",
        "Text": "你要变强喔\n强到不会被我抛下"
      },
      "STDM_0809401_0430": {
        "ID": "STDM_0809401_0430",
        "Text": "2018年　10月19日"
      },
      "STDM_0809401_0440": {
        "ID": "STDM_0809401_0440",
        "Text": "五条老师"
      },
      "STDM_0809401_0450": {
        "ID": "STDM_0809401_0450",
        "Text": "老师也会睡觉啊"
      },
      "STDM_0809401_0460": {
        "ID": "STDM_0809401_0460",
        "Text": "当然的啊，你在说什么"
      },
      "STDM_0809401_0470": {
        "ID": "STDM_0809401_0470",
        "Text": "五条老师！！"
      },
      "STDM_0809401_0480": {
        "ID": "STDM_0809401_0480",
        "Text": "哦，醒来了"
      },
      "STDM_0809401_0490": {
        "ID": "STDM_0809401_0490",
        "Text": "拜托，那张椅子很贵吧"
      },
      "STDM_0809401_0500": {
        "ID": "STDM_0809401_0500",
        "Text": "请不要叫我们来却在打瞌睡"
      },
      "STDM_0809401_0510": {
        "ID": "STDM_0809401_0510",
        "Text": "……"
      },
      "STDM_0809401_0520": {
        "ID": "STDM_0809401_0520",
        "Text": "你在笑什么？"
      },
      "STDM_0809401_0530": {
        "ID": "STDM_0809401_0530",
        "Text": "没什么"
      }
    }
  }
]