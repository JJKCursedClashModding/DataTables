[
  {
    "Type": "DataTable",
    "Name": "DlcStoryDemoTextDataTable1_Zh_Hant",
    "Flags": "RF_Public | RF_Standalone | RF_Transactional | RF_WasLoaded | RF_LoadCompleted",
    "Class": "UScriptClass'DataTable'",
    "Properties": {
      "RowStruct": {
        "ObjectName": "Class'GameDataTableRow_GameText'",
        "ObjectPath": "/Script/Abrams"
      },
      "ImportKeyField": "Id"
    },
    "Rows": {
      "STDM_0809001_0010": {
        "ID": "STDM_0809001_0010",
        "Text": "沒問題的吧"
      },
      "STDM_0809001_0015": {
        "ID": "STDM_0809001_0015",
        "Text": "因為我們是最強的"
      },
      "STDM_0809001_0020": {
        "ID": "STDM_0809001_0020",
        "Text": "靜岡縣濱松市\n2006年"
      },
      "STDM_0809001_0030": {
        "ID": "STDM_0809001_0030",
        "Text": "我來幫你囉～"
      },
      "STDM_0809001_0040": {
        "ID": "STDM_0809001_0040",
        "Text": "咒術高專二年級　五條悟"
      },
      "STDM_0809001_0050": {
        "ID": "STDM_0809001_0050",
        "Text": "要遷就那些弱者實在很累人耶"
      },
      "STDM_0809001_0060": {
        "ID": "STDM_0809001_0060",
        "Text": "悟，欺負弱者不好喔"
      },
      "STDM_0809001_0070": {
        "ID": "STDM_0809001_0070",
        "Text": "咒術高專二年級　夏油傑"
      },
      "STDM_0809001_0080": {
        "ID": "STDM_0809001_0080",
        "Text": "弱者生存，這才是社會應該有的面貌"
      },
      "STDM_0809001_0090": {
        "ID": "STDM_0809001_0090",
        "Text": "這任務由你們兩人執行。委託有2個\n對於星漿體，身為天元大人合適者的少女\n加以護衛——和消除\n"
      },
      "STDM_0809001_0100": {
        "ID": "STDM_0809001_0100",
        "Text": "失敗的話對一般社會也會造成影響\n執行時要記住這點！！"
      },
      "STDM_0809001_0110": {
        "ID": "STDM_0809001_0110",
        "Text": "因「Q」的最高戰力拜爾脫隊\n組織瓦解"
      },
      "STDM_0809001_0120": {
        "ID": "STDM_0809001_0120",
        "Text": "好啊，這工作我接了"
      },
      "STDM_0809001_0130": {
        "ID": "STDM_0809001_0130",
        "Text": "對手可是五條家的少爺\n大搖大擺地現身會什麼事都做不了"
      },
      "STDM_0809001_0140": {
        "ID": "STDM_0809001_0140",
        "Text": "先用一些笨蛋削減他的精神"
      },
      "STDM_0809001_0150": {
        "ID": "STDM_0809001_0150",
        "Text": "嘖！"
      },
      "STDM_0809001_0160": {
        "ID": "STDM_0809001_0160",
        "Text": "就拜託你了，術師殺手"
      },
      "STDM_0809001_0165": {
        "ID": "STDM_0809001_0165",
        "Text": "啊，對了，惠過得好嗎？"
      },
      "STDM_0809001_0170": {
        "ID": "STDM_0809001_0170",
        "Text": "……"
      },
      "STDM_0809001_0175": {
        "ID": "STDM_0809001_0175",
        "Text": "你說誰？"
      },
      "STDM_0809001_0180": {
        "ID": "STDM_0809001_0180",
        "Text": "五條在沖繩救出黑井"
      },
      "STDM_0809001_0190": {
        "ID": "STDM_0809001_0190",
        "Text": "歡～迎～！！"
      },
      "STDM_0809001_0200": {
        "ID": "STDM_0809001_0200",
        "Text": "沖繩\n護衛第2天"
      },
      "STDM_0809001_0210": {
        "ID": "STDM_0809001_0210",
        "Text": "東京都立咒術高專　筵山麓"
      },
      "STDM_0809001_0220": {
        "ID": "STDM_0809001_0220",
        "Text": "護衛第3天　15:00"
      },
      "STDM_0809001_0230": {
        "ID": "STDM_0809001_0230",
        "Text": "這裡是高專的結界內了"
      },
      "STDM_0809001_0240": {
        "ID": "STDM_0809001_0240",
        "Text": "悟，真的辛苦你了"
      },
      "STDM_0809001_0250": {
        "ID": "STDM_0809001_0250",
        "Text": "呼～我不想再當小鬼的保母了"
      },
      "STDM_0809001_0260": {
        "ID": "STDM_0809001_0260",
        "Text": "啊……啊啊……"
      },
      "STDM_0809001_0270": {
        "ID": "STDM_0809001_0270",
        "Text": "我有在哪裡見過你嗎？"
      },
      "STDM_0809001_0280": {
        "ID": "STDM_0809001_0280",
        "Text": "不必在意\n我也很不擅長記男人的名字"
      },
      "STDM_0809101_0010": {
        "ID": "STDM_0809101_0010",
        "Text": "唔……！"
      },
      "STDM_0809101_0020": {
        "ID": "STDM_0809101_0020",
        "Text": "悟！"
      },
      "STDM_0809101_0030": {
        "ID": "STDM_0809101_0030",
        "Text": "就像是安全別針穿過了針織毛衣一樣\n真的沒問題的"
      },
      "STDM_0809101_0040": {
        "ID": "STDM_0809101_0040",
        "Text": "更重要的是優先保護天內\n我來對付那傢伙"
      },
      "STDM_0809101_0050": {
        "ID": "STDM_0809101_0050",
        "Text": "傑你們先到天元大人那裡去"
      },
      "STDM_0809101_0060": {
        "ID": "STDM_0809101_0060",
        "Text": "悟……"
      },
      "STDM_0809101_0070": {
        "ID": "STDM_0809101_0070",
        "Text": "別大意了喔"
      },
      "STDM_0809101_0080": {
        "ID": "STDM_0809101_0080",
        "Text": "你以為你在對誰說話啊？"
      },
      "STDM_0809101_0090": {
        "ID": "STDM_0809101_0090",
        "Text": "可以的話希望在剛才那擊就解決五條悟的……\n是我生疏了嗎"
      },
      "STDM_0809101_0100": {
        "ID": "STDM_0809101_0100",
        "Text": "天內的懸賞金已經被取消了啊，你這笨蛋"
      },
      "STDM_0809101_0110": {
        "ID": "STDM_0809101_0110",
        "Text": "是我取消的，你這嘴硬的傢伙"
      },
      "STDM_0809101_0120": {
        "ID": "STDM_0809101_0120",
        "Text": "像你這種沒有破綻的傢伙\n就是要分輕重緩急，製造幾個假的終點"
      },
      "STDM_0809101_0130": {
        "ID": "STDM_0809101_0130",
        "Text": "懸賞金如果沒有時間限制\n我想你到最後都不會解除術式的"
      },
      "STDM_0809101_0140": {
        "ID": "STDM_0809101_0140",
        "Text": "啊，是嗎"
      },
      "STDM_0809102_0010": {
        "ID": "STDM_0809102_0010",
        "Text": "我就覺得這傢伙哪裡奇怪\n他完全沒有咒力！"
      },
      "STDM_0809102_0020": {
        "ID": "STDM_0809102_0020",
        "Text": "是天與咒縛的肉體天賦！！"
      },
      "STDM_0809103_0010": {
        "ID": "STDM_0809103_0010",
        "Text": "術式順轉，最大輸出"
      },
      "STDM_0809103_0020": {
        "ID": "STDM_0809103_0020",
        "Text": "「蒼」"
      },
      "STDM_0809103_0030": {
        "ID": "STDM_0809103_0030",
        "Text": "沒有遮蔽物，他沒辦法突襲"
      },
      "STDM_0809103_0040": {
        "ID": "STDM_0809103_0040",
        "Text": "那是……"
      },
      "STDM_0809103_0041": {
        "ID": "STDM_0809103_0041",
        "Text": "蠅頭！？"
      },
      "STDM_0809103_0050": {
        "ID": "STDM_0809103_0050",
        "Text": "把它當成干擾來用是嗎"
      },
      "STDM_0809103_0060": {
        "ID": "STDM_0809103_0060",
        "Text": "死角也出現了，再用一次「蒼」……"
      },
      "STDM_0809103_0070": {
        "ID": "STDM_0809103_0070",
        "Text": "不，等等，他的目標是天內——"
      },
      "STDM_0809103_0080": {
        "ID": "STDM_0809103_0080",
        "Text": "直覺好到能察覺空手的我"
      },
      "STDM_0809103_0090": {
        "ID": "STDM_0809103_0090",
        "Text": "但你終於依靠術式防守了啊"
      },
      "STDM_0809201_0010": {
        "ID": "STDM_0809201_0010",
        "Text": "這裡就是……"
      },
      "STDM_0809201_0020": {
        "ID": "STDM_0809201_0020",
        "Text": "對，天元大人膝下"
      },
      "STDM_0809201_0030": {
        "ID": "STDM_0809201_0030",
        "Text": "國內主要結界的根基，薨星宮本殿"
      },
      "STDM_0809201_0040": {
        "ID": "STDM_0809201_0040",
        "Text": "你要走下階梯通過門\n到那棵大樹的根部去"
      },
      "STDM_0809201_0050": {
        "ID": "STDM_0809201_0050",
        "Text": "到同化為止，天元大人會保護你"
      },
      "STDM_0809201_0060": {
        "ID": "STDM_0809201_0060",
        "Text": "或者你要在這裡回頭\n和黑井小姐一起回家"
      },
      "STDM_0809201_0070": {
        "ID": "STDM_0809201_0070",
        "Text": "……咦？"
      },
      "STDM_0809201_0080": {
        "ID": "STDM_0809201_0080",
        "Text": "在和你碰面前，我和悟談過了"
      },
      "STDM_0809201_0090": {
        "ID": "STDM_0809201_0090",
        "Text": "你說星漿體小鬼拒絕同化的話？"
      },
      "STDM_0809201_0100": {
        "ID": "STDM_0809201_0100",
        "Text": "那時候就……不同化了！"
      },
      "STDM_0809201_0110": {
        "ID": "STDM_0809201_0110",
        "Text": "呵呵，可以嗎？"
      },
      "STDM_0809201_0120": {
        "ID": "STDM_0809201_0120",
        "Text": "也許會演變成和天元大人對戰喔"
      },
      "STDM_0809201_0130": {
        "ID": "STDM_0809201_0130",
        "Text": "你在怕嗎？"
      },
      "STDM_0809201_0140": {
        "ID": "STDM_0809201_0140",
        "Text": "沒問題，總會有辦法啦"
      },
      "STDM_0809201_0150": {
        "ID": "STDM_0809201_0150",
        "Text": "我們是最強的"
      },
      "STDM_0809201_0160": {
        "ID": "STDM_0809201_0160",
        "Text": "不論理子你怎麼選擇\n我們都會保障你的未來"
      },
      "STDM_0809201_0170": {
        "ID": "STDM_0809201_0170",
        "Text": "……我"
      },
      "STDM_0809201_0180": {
        "ID": "STDM_0809201_0180",
        "Text": "從出生時就被說是特別的\n和大家不同"
      },
      "STDM_0809201_0190": {
        "ID": "STDM_0809201_0190",
        "Text": "對我來說，作為星漿體是很正常的"
      },
      "STDM_0809201_0200": {
        "ID": "STDM_0809201_0200",
        "Text": "盡量避開危險的事\n就為了這一天活到現在"
      },
      "STDM_0809201_0210": {
        "ID": "STDM_0809201_0210",
        "Text": "所以我本來以為就算同化了\n和大家分開也沒有關係"
      },
      "STDM_0809201_0220": {
        "ID": "STDM_0809201_0220",
        "Text": "……可是\n可是我果然還是"
      },
      "STDM_0809201_0230": {
        "ID": "STDM_0809201_0230",
        "Text": "想多和大家在一起"
      },
      "STDM_0809201_0240": {
        "ID": "STDM_0809201_0240",
        "Text": "想和大家一起去更多地方\n去看各種事物……看更多！！"
      },
      "STDM_0809201_0250": {
        "ID": "STDM_0809201_0250",
        "Text": "我們回去吧，理子"
      },
      "STDM_0809201_0260": {
        "ID": "STDM_0809201_0260",
        "Text": "……嗯！！"
      },
      "STDM_0809201_0270": {
        "ID": "STDM_0809201_0270",
        "Text": "理子？"
      },
      "STDM_0809201_0280": {
        "ID": "STDM_0809201_0280",
        "Text": "好了，辛苦了\n解散解散"
      },
      "STDM_0809201_0290": {
        "ID": "STDM_0809201_0290",
        "Text": "你為什麼會在這裡"
      },
      "STDM_0809201_0300": {
        "ID": "STDM_0809201_0300",
        "Text": "啊啊？你說為什麼……"
      },
      "STDM_0809201_0310": {
        "ID": "STDM_0809201_0310",
        "Text": "啊啊，是那個意思啊"
      },
      "STDM_0809201_0320": {
        "ID": "STDM_0809201_0320",
        "Text": "我殺了五條悟"
      },
      "STDM_0809201_0330": {
        "ID": "STDM_0809201_0330",
        "Text": "是嗎"
      },
      "STDM_0809201_0340": {
        "ID": "STDM_0809201_0340",
        "Text": "那去死吧"
      },
      "STDM_0809202_0010": {
        "ID": "STDM_0809202_0010",
        "Text": "你為什麼會知道通往薨星宮的門？\n我們完全沒有留下殘穢"
      },
      "STDM_0809202_0020": {
        "ID": "STDM_0809202_0020",
        "Text": "人類會留下的痕跡不是只有殘穢"
      },
      "STDM_0809202_0030": {
        "ID": "STDM_0809202_0030",
        "Text": "味道，足跡\n我的五感也因為咒縛而大幅提升"
      },
      "STDM_0809202_0040": {
        "ID": "STDM_0809202_0040",
        "Text": "途中應該有一位女性在，她怎麼了？"
      },
      "STDM_0809202_0050": {
        "ID": "STDM_0809202_0050",
        "Text": "嗯？喔，那個女僕嗎，應該死了\n雖然我沒有特別想放走她或殺她"
      },
      "STDM_0809202_0060": {
        "ID": "STDM_0809202_0060",
        "Text": "運氣好的話還活著吧？"
      },
      "STDM_0809202_0070": {
        "ID": "STDM_0809202_0070",
        "Text": "是嗎，果然你還是去死吧"
      },
      "STDM_0809203_0010": {
        "ID": "STDM_0809203_0010",
        "Text": "蠢蛋……你完了"
      },
      "STDM_0809203_0020": {
        "ID": "STDM_0809203_0020",
        "Text": "你才完了"
      },
      "STDM_0809203_0030": {
        "ID": "STDM_0809203_0030",
        "Text": "能力雖然特殊，但咒靈本身並不強\n我能吸收！！"
      },
      "STDM_0809203_0040": {
        "ID": "STDM_0809203_0040",
        "Text": "武器庫已經扣押了\n再來只要靠數量硬攻——"
      },
      "STDM_0809203_0050": {
        "ID": "STDM_0809203_0050",
        "Text": "什麼……！！"
      },
      "STDM_0809203_0060": {
        "ID": "STDM_0809203_0060",
        "Text": "我用術師不會因此死亡的程度砍的"
      },
      "STDM_0809203_0070": {
        "ID": "STDM_0809203_0070",
        "Text": "如果是式神使我就殺了\n但咒靈操術不一樣"
      },
      "STDM_0809203_0080": {
        "ID": "STDM_0809203_0080",
        "Text": "我不確定你死了之後\n你吸收的咒靈會變成怎樣"
      },
      "STDM_0809203_0090": {
        "ID": "STDM_0809203_0090",
        "Text": "我現在想盡量避免麻煩\n所以你應該感謝父母呢"
      },
      "STDM_0809203_0100": {
        "ID": "STDM_0809203_0100",
        "Text": "但是受遺傳恩惠的你們\n輸給了我這種連咒術都不會用的猴子"
      },
      "STDM_0809203_0110": {
        "ID": "STDM_0809203_0110",
        "Text": "想活得久就別忘了這點"
      },
      "STDM_0809203_0120": {
        "ID": "STDM_0809203_0120",
        "Text": "啊——"
      },
      "STDM_0809203_0130": {
        "ID": "STDM_0809203_0130",
        "Text": "說到惠，對了對了"
      },
      "STDM_0809203_0140": {
        "ID": "STDM_0809203_0140",
        "Text": "是我取名的啊"
      },
      "STDM_0809301_0010": {
        "ID": "STDM_0809301_0010",
        "Text": "某天，被殺害的星漿體——天內理子的遺體\n由伏黑甚爾本人送達盤星教本部，星之子之家"
      },
      "STDM_0809301_0020": {
        "ID": "STDM_0809301_0020",
        "Text": "盤星教代表園田茂、伏黑甚爾\n擔任仲介的孔時雨\n三人進行了遺體的交付"
      },
      "STDM_0809301_0030": {
        "ID": "STDM_0809301_0030",
        "Text": "唷，好久不見"
      },
      "STDM_0809301_0040": {
        "ID": "STDM_0809301_0040",
        "Text": "真的假的"
      },
      "STDM_0809301_0050": {
        "ID": "STDM_0809301_0050",
        "Text": "真的真的，我超有精神"
      },
      "STDM_0809301_0060": {
        "ID": "STDM_0809301_0060",
        "Text": "反轉術式！！"
      },
      "STDM_0809301_0070": {
        "ID": "STDM_0809301_0070",
        "Text": "答對了！！"
      },
      "STDM_0809301_0080": {
        "ID": "STDM_0809301_0080",
        "Text": "我到目前為止也都沒成功過"
      },
      "STDM_0809301_0090": {
        "ID": "STDM_0809301_0090",
        "Text": "但在瀕死的時候\n我掌握到了咒力的核心！"
      },
      "STDM_0809301_0100": {
        "ID": "STDM_0809301_0100",
        "Text": "你的敗因就是沒有把我的頭砍下\n還有沒用那把咒具刺進我的頭"
      },
      "STDM_0809301_0110": {
        "ID": "STDM_0809301_0110",
        "Text": "……敗因？"
      },
      "STDM_0809301_0120": {
        "ID": "STDM_0809301_0120",
        "Text": "勝負現在才要開始吧"
      },
      "STDM_0809301_0130": {
        "ID": "STDM_0809301_0130",
        "Text": "啊——？是嗎？是啊"
      },
      "STDM_0809301_0140": {
        "ID": "STDM_0809301_0140",
        "Text": "……也許是吧！！"
      },
      "STDM_0809302_0010": {
        "ID": "STDM_0809302_0010",
        "Text": "抱歉，天內"
      },
      "STDM_0809302_0020": {
        "ID": "STDM_0809302_0020",
        "Text": "我現在沒有為了你生氣\n也沒有憎恨任何人"
      },
      "STDM_0809302_0030": {
        "ID": "STDM_0809302_0030",
        "Text": "只是覺得這個世界很舒服"
      },
      "STDM_0809302_0040": {
        "ID": "STDM_0809302_0040",
        "Text": "天上天下，唯我獨尊"
      },
      "STDM_0809302_0050": {
        "ID": "STDM_0809302_0050",
        "Text": "順轉和反轉\n讓它們彼此的無限互相衝突\n並推送出因此產生的虛幻質量"
      },
      "STDM_0809303_0010": {
        "ID": "STDM_0809303_0010",
        "Text": "不對勁"
      },
      "STDM_0809303_0020": {
        "ID": "STDM_0809303_0020",
        "Text": "「我才不想做白工」\n平常的我應該會這麼說然後閃人"
      },
      "STDM_0809303_0030": {
        "ID": "STDM_0809303_0030",
        "Text": "但看到在眼前覺醒的無下限咒術高手\n大概已經成了現代最強的術師"
      },
      "STDM_0809303_0040": {
        "ID": "STDM_0809303_0040",
        "Text": "我變得想否定他\n想試著用力量壓制他"
      },
      "STDM_0809303_0050": {
        "ID": "STDM_0809303_0050",
        "Text": "否定曾否定我的禪院家、咒術界\n否定他們之間的頂點"
      },
      "STDM_0809303_0060": {
        "ID": "STDM_0809303_0060",
        "Text": "為了肯定自己\n我扭曲了平常的自己"
      },
      "STDM_0809303_0070": {
        "ID": "STDM_0809303_0070",
        "Text": "在這時候我就已經輸了"
      },
      "STDM_0809303_0080": {
        "ID": "STDM_0809303_0080",
        "Text": "我明明早就捨棄自尊心了才對"
      },
      "STDM_0809303_0090": {
        "ID": "STDM_0809303_0090",
        "Text": "不把自己和他人當一回事\n我應該早就選擇了這種生活方式"
      },
      "STDM_0809303_0100": {
        "ID": "STDM_0809303_0100",
        "Text": "你在最後有想說的話嗎？"
      },
      "STDM_0809303_0110": {
        "ID": "STDM_0809303_0110",
        "Text": "……沒有"
      },
      "STDM_0809303_0120": {
        "ID": "STDM_0809303_0120",
        "Text": "再過2、3年\n我的小孩會被賣到禪院家"
      },
      "STDM_0809303_0130": {
        "ID": "STDM_0809303_0130",
        "Text": "隨你處置吧"
      },
      "STDM_0809303_0140": {
        "ID": "STDM_0809303_0140",
        "Text": "之後，咒術高專二年級生五條悟\n在盤星教設施內回收星漿體天內理子的遺體"
      },
      "STDM_0809303_0150": {
        "ID": "STDM_0809303_0150",
        "Text": "不久後，咒術高專二年級生夏油傑也到場會合"
      },
      "STDM_0809303_0160": {
        "ID": "STDM_0809303_0160",
        "Text": "你真慢啊，傑\n不，是算快的了嗎"
      },
      "STDM_0809303_0170": {
        "ID": "STDM_0809303_0170",
        "Text": "……"
      },
      "STDM_0809303_0180": {
        "ID": "STDM_0809303_0180",
        "Text": "你是……悟對吧？"
      },
      "STDM_0809303_0190": {
        "ID": "STDM_0809303_0190",
        "Text": "發生什麼事了……！？"
      },
      "STDM_0809303_0200": {
        "ID": "STDM_0809303_0200",
        "Text": "你見到硝子了吧"
      },
      "STDM_0809303_0210": {
        "ID": "STDM_0809303_0210",
        "Text": "對，她醫治我了\n我沒事"
      },
      "STDM_0809303_0220": {
        "ID": "STDM_0809303_0220",
        "Text": "不對，我沒事也沒意義吧"
      },
      "STDM_0809303_0230": {
        "ID": "STDM_0809303_0230",
        "Text": "是我的失誤，你沒有錯"
      },
      "STDM_0809303_0240": {
        "ID": "STDM_0809303_0240",
        "Text": "……我們回去吧"
      },
      "STDM_0809303_0250": {
        "ID": "STDM_0809303_0250",
        "Text": "傑"
      },
      "STDM_0809303_0260": {
        "ID": "STDM_0809303_0260",
        "Text": "要殺了這些傢伙嗎？"
      },
      "STDM_0809303_0270": {
        "ID": "STDM_0809303_0270",
        "Text": "現在的我，大概不會有任何感覺"
      },
      "STDM_0809303_0280": {
        "ID": "STDM_0809303_0280",
        "Text": "不必了，這樣沒有意義"
      },
      "STDM_0809303_0290": {
        "ID": "STDM_0809303_0290",
        "Text": "意義啊"
      },
      "STDM_0809303_0300": {
        "ID": "STDM_0809303_0300",
        "Text": "那種東西真的有需要嗎？"
      },
      "STDM_0809303_0310": {
        "ID": "STDM_0809303_0310",
        "Text": "意義是很重要的"
      },
      "STDM_0809303_0320": {
        "ID": "STDM_0809303_0320",
        "Text": "尤其是對術師來說"
      },
      "STDM_0809401_0010": {
        "ID": "STDM_0809401_0010",
        "Text": "那年夏天很忙"
      },
      "STDM_0809401_0020": {
        "ID": "STDM_0809401_0020",
        "Text": "1年後\n2007年　8月"
      },
      "STDM_0809401_0030": {
        "ID": "STDM_0809401_0030",
        "Text": "可能是受去年頻繁發生的災害影響\n咒靈像蛆一樣大量出現"
      },
      "STDM_0809401_0040": {
        "ID": "STDM_0809401_0040",
        "Text": "祓除、吸收，不斷重複"
      },
      "STDM_0809401_0050": {
        "ID": "STDM_0809401_0050",
        "Text": "大家所不知道的咒靈味道\n是像把擦過嘔吐物的抹布整條吞下去一樣"
      },
      "STDM_0809401_0060": {
        "ID": "STDM_0809401_0060",
        "Text": "這是為了誰？"
      },
      "STDM_0809401_0070": {
        "ID": "STDM_0809401_0070",
        "Text": "從那天起，我就一直告訴自己\n我看到的東西並不稀奇\n是眾所皆知的醜惡"
      },
      "STDM_0809401_0080": {
        "ID": "STDM_0809401_0080",
        "Text": "臭猴子"
      },
      "STDM_0809401_0090": {
        "ID": "STDM_0809401_0090",
        "Text": "盡力去做自己能做到的事，感覺很舒服"
      },
      "STDM_0809401_0100": {
        "ID": "STDM_0809401_0100",
        "Text": "你知道嗎？術師不會產生咒靈"
      },
      "STDM_0809401_0110": {
        "ID": "STDM_0809401_0110",
        "Text": "啊……"
      },
      "STDM_0809401_0120": {
        "ID": "STDM_0809401_0120",
        "Text": "那麼，只要把非術師都殺掉不就好了"
      },
      "STDM_0809401_0130": {
        "ID": "STDM_0809401_0130",
        "Text": "夏油，這是可行的"
      },
      "STDM_0809401_0140": {
        "ID": "STDM_0809401_0140",
        "Text": "咦……不是的……"
      },
      "STDM_0809401_0150": {
        "ID": "STDM_0809401_0150",
        "Text": "不斷減少非術師，讓他們為了生存戰略而適應術師\n簡單說就是促使進化，像鳥長出翅膀那樣"
      },
      "STDM_0809401_0160": {
        "ID": "STDM_0809401_0160",
        "Text": "但很可惜，我還沒有那麼瘋狂"
      },
      "STDM_0809401_0170": {
        "ID": "STDM_0809401_0170",
        "Text": "你討厭非術師嗎？夏油"
      },
      "STDM_0809401_0180": {
        "ID": "STDM_0809401_0180",
        "Text": "瞧不起非術師的你\n還有否定這點的你\n"
      },
      "STDM_0809401_0185": {
        "ID": "STDM_0809401_0185",
        "Text": "要把哪一邊當成你的真心話\n是你今後要選擇的"
      },
      "STDM_0809401_0190": {
        "ID": "STDM_0809401_0190",
        "Text": "可惡……！！"
      },
      "STDM_0809401_0200": {
        "ID": "STDM_0809401_0200",
        "Text": "產土神信仰……那是土地神\n是一級案件……！！"
      },
      "STDM_0809401_0210": {
        "ID": "STDM_0809401_0210",
        "Text": "術師這場馬拉松比賽\n如果盡頭是夥伴堆積成山的屍體呢？"
      },
      "STDM_0809401_0220": {
        "ID": "STDM_0809401_0220",
        "Text": "關於本校學生殺傷事件的調查報告書"
      },
      "STDM_0809401_0230": {
        "ID": "STDM_0809401_0230",
        "Text": "這是怎麼回事？"
      },
      "STDM_0809401_0240": {
        "ID": "STDM_0809401_0240",
        "Text": "怎麼回事？\n這兩人就是這一連串事件的原因吧？"
      },
      "STDM_0809401_0250": {
        "ID": "STDM_0809401_0250",
        "Text": "不是的"
      },
      "STDM_0809401_0260": {
        "ID": "STDM_0809401_0260",
        "Text": "調查對象學生：東京校3年級　夏油傑"
      },
      "STDM_0809401_0270": {
        "ID": "STDM_0809401_0270",
        "Text": "各位，我們先到外面去一下吧"
      },
      "STDM_0809401_0280": {
        "ID": "STDM_0809401_0280",
        "Text": "夏油傑現在也正在逃亡"
      },
      "STDM_0809401_0283": {
        "ID": "STDM_0809401_0283",
        "Text": "依咒術規定第9條\n視為咒詛師列入處刑對象"
      },
      "STDM_0809401_0290": {
        "ID": "STDM_0809401_0290",
        "Text": "快說明啊，傑"
      },
      "STDM_0809401_0300": {
        "ID": "STDM_0809401_0300",
        "Text": "殺掉非術師創造只有術師的世界！？\n那種事怎麼可能做到！！"
      },
      "STDM_0809401_0310": {
        "ID": "STDM_0809401_0310",
        "Text": "這麼說太傲慢了\n是你的話就有可能做到吧，悟"
      },
      "STDM_0809401_0320": {
        "ID": "STDM_0809401_0320",
        "Text": "自己能做到的事\n卻要說服別人「不可能辦到」嗎？"
      },
      "STDM_0809401_0330": {
        "ID": "STDM_0809401_0330",
        "Text": "因為你是五條悟所以最強？\n還是因為最強所以才是五條悟？"
      },
      "STDM_0809401_0340": {
        "ID": "STDM_0809401_0340",
        "Text": "你到底想說什麼"
      },
      "STDM_0809401_0350": {
        "ID": "STDM_0809401_0350",
        "Text": "生存之道已定\n之後就是盡量去做自己能做到的"
      },
      "STDM_0809401_0360": {
        "ID": "STDM_0809401_0360",
        "Text": "老師，我很強對吧"
      },
      "STDM_0809401_0370": {
        "ID": "STDM_0809401_0370",
        "Text": "嗯，強到很囂張"
      },
      "STDM_0809401_0380": {
        "ID": "STDM_0809401_0380",
        "Text": "但看來只有我強是不行的\n我能拯救的\n只有準備好被他人拯救的人而已"
      },
      "STDM_0809401_0390": {
        "ID": "STDM_0809401_0390",
        "Text": "你是伏黑惠小弟弟對吧"
      },
      "STDM_0809401_0400": {
        "ID": "STDM_0809401_0400",
        "Text": "呵呵……OK"
      },
      "STDM_0809401_0405": {
        "ID": "STDM_0809401_0405",
        "Text": "之後就交給我"
      },
      "STDM_0809401_0410": {
        "ID": "STDM_0809401_0410",
        "Text": "……"
      },
      "STDM_0809401_0420": {
        "ID": "STDM_0809401_0420",
        "Text": "你要變強喔\n強到不會被我拋下"
      },
      "STDM_0809401_0430": {
        "ID": "STDM_0809401_0430",
        "Text": "2018年　10月19日"
      },
      "STDM_0809401_0440": {
        "ID": "STDM_0809401_0440",
        "Text": "五條老師"
      },
      "STDM_0809401_0450": {
        "ID": "STDM_0809401_0450",
        "Text": "老師也會睡覺啊"
      },
      "STDM_0809401_0460": {
        "ID": "STDM_0809401_0460",
        "Text": "當然的啊，你在說什麼"
      },
      "STDM_0809401_0470": {
        "ID": "STDM_0809401_0470",
        "Text": "五條老師！！"
      },
      "STDM_0809401_0480": {
        "ID": "STDM_0809401_0480",
        "Text": "哦，醒來了"
      },
      "STDM_0809401_0490": {
        "ID": "STDM_0809401_0490",
        "Text": "拜託，那張椅子很貴吧"
      },
      "STDM_0809401_0500": {
        "ID": "STDM_0809401_0500",
        "Text": "請不要叫我們來卻在打瞌睡"
      },
      "STDM_0809401_0510": {
        "ID": "STDM_0809401_0510",
        "Text": "……"
      },
      "STDM_0809401_0520": {
        "ID": "STDM_0809401_0520",
        "Text": "你在笑什麼？"
      },
      "STDM_0809401_0530": {
        "ID": "STDM_0809401_0530",
        "Text": "沒什麼"
      }
    }
  }
]