    "Class": "UScriptClass'DataTable'",
    "Properties": {
      "RowStruct": {
        "ObjectName": "Class'GameDataTableRow_GameText'",
        "ObjectPath": "/Script/Abrams"
      },
      "ImportKeyField": "Id"
    },
    "Rows": {
      "CHAP_0001": {
        "ID": "CHAP_0001",
        "Text": "주태대천: 전편"
      },
      "CHAP_0002": {
        "ID": "CHAP_0002",
        "Text": "주태대천: 후편"
      },
      "CHAP_0003": {
        "ID": "CHAP_0003",
        "Text": "어린 물고기와 역벌"
      },
      "CHAP_0004": {
        "ID": "CHAP_0004",
        "Text": "교토 자매 학교 교류회"
      },
      "CHAP_0005": {
        "ID": "CHAP_0005",
        "Text": "기수뇌동"
      },
      "CHAP_0006": {
        "ID": "CHAP_0006",
        "Text": "주술회전 0"
      },
      "CHAP_0007": {
        "ID": "CHAP_0007",
        "Text": "EX 배틀"
      },
      "CHAP_0008": {
        "ID": "CHAP_0008",
        "Text": "회옥·옥절"
      },
      "CHAP_0009": {
        "ID": "CHAP_0009",
        "Text": "시부야 사변"
      },
      "STMSN_01000M": {
        "ID": "STMSN_01000M",
        "Text": "「최강」의 전수"
      },
      "STMSN_01000M_EXPLANATION": {
        "ID": "STMSN_01000M_EXPLANATION",
        "Text": "자신의 나약함을 깨닫고\n소년은 강해지고자 결의한다…\n\"올바른 죽음\"을 위해."
      },
      "STMSN_01001M": {
        "ID": "STMSN_01001M",
        "Text": "양면 스쿠나"
      },
      "STMSN_01001M_EXPLANATION": {
        "ID": "STMSN_01001M_EXPLANATION",
        "Text": "흉악한 주물의 봉인이 풀려 저주가 모여든다.\n「나한테 주력이 있으면 되는 거지?!」\n이타도리는 저주에 맞서기 위해…"
      },
      "STMSN_01002M": {
        "ID": "STMSN_01002M",
        "Text": "비밀 사형"
      },
      "STMSN_01002M_EXPLANATION": {
        "ID": "STMSN_01002M_EXPLANATION",
        "Text": "특급 주술사 \"고죠 사토루\"가 스쿠나의 수육을\n확인, 이타도리에게 교체할 것을 지시한다…\n최강과 최악의 싸움이 시작된다!"
      },
      "STMSN_01003M": {
        "ID": "STMSN_01003M",
        "Text": "유언"
      },
      "STMSN_01003M_EXPLANATION": {
        "ID": "STMSN_01003M_EXPLANATION",
        "Text": "지금 당장 죽을 것인가, 스쿠나의 손가락을\n전부 삼키고 죽을 것인가. 할아버지의 유언을\n떠올리며 이타도리는 선택한다…"
      },
      "STMSN_01004M": {
        "ID": "STMSN_01004M",
        "Text": "자신을 위해"
      },
      "STMSN_01004M_EXPLANATION": {
        "ID": "STMSN_01004M_EXPLANATION",
        "Text": "주술고전에 온 이유를 묻자 고민하는 이타도리.\n할아버지의 유언… 자신밖에 할 수 없는 일…\n이타도리가 내놓은 답은…!!"
      },
      "STMSN_01005M": {
        "ID": "STMSN_01005M",
        "Text": "철골 소녀"
      },
      "STMSN_01005M_EXPLANATION": {
        "ID": "STMSN_01005M_EXPLANATION",
        "Text": "쿠기사키와 이타도리는\n주령 퇴치 시험에 도전한다!\n인솔하는 고죠에겐 목적이 있었는데…"
      },
      "STMSN_01006M": {
        "ID": "STMSN_01006M",
        "Text": "시작"
      },
      "STMSN_01006M_EXPLANATION": {
        "ID": "STMSN_01006M_EXPLANATION",
        "Text": "주령이 아이를 인질 삼아 쿠기사키에게\n목숨을 건 저울을 들이댄다.\n갈등 끝에 쿠기사키가 내놓은 답은…"
      },
      "STMSN_01007M": {
        "ID": "STMSN_01007M",
        "Text": "주태대천"
      },
      "STMSN_01007M_EXPLANATION": {
        "ID": "STMSN_01007M_EXPLANATION",
        "Text": "소년원에서 주태가 확인됐다.\n이지치에게서 상황을 들은 이타도리 일행이\n생존자를 구출하러 가지만 내부는 이미…"
      },
      "STMSN_01008M": {
        "ID": "STMSN_01008M",
        "Text": "탈출"
      },
      "STMSN_01008M_EXPLANATION": {
        "ID": "STMSN_01008M_EXPLANATION",
        "Text": "혼자 다른 장소에서 헤매던 쿠기사키는\n근처에서 수상한 기척을 감지한다…\n「뭐가… 이렇게 많아?!」"
      },
      "STMSN_01009M": {
        "ID": "STMSN_01009M",
        "Text": "저주의 왕"
      },
      "STMSN_01009M_EXPLANATION": {
        "ID": "STMSN_01009M_EXPLANATION",
        "Text": "죽음의 문턱에 선 이타도리에게 들린 후시구로의\n신호. 스쿠나와 특급 주령을 맞붙이려 했으나…\n「어이, 그 꼬맹이들을 죽이러 가자」"
      },
      "STMSN_01010M": {
        "ID": "STMSN_01010M",
        "Text": "이유"
      },
      "STMSN_01010M_EXPLANATION": {
        "ID": "STMSN_01010M_EXPLANATION",
        "Text": "밖에서 기다리는 후시구로 앞에 나타난 스쿠나.\n「지금 내가 할 수 있는 걸 생각해 봤어」\n일시적으로 몸의 주도권을 얻은 스쿠나는…"
      },
      "STMSN_02011M": {
        "ID": "STMSN_02011M",
        "Text": "비가 온 뒤"
      },
      "STMSN_02011M_EXPLANATION": {
        "ID": "STMSN_02011M_EXPLANATION",
        "Text": "쿠기사키에게 이타도리의 유언을 전한 후시구로.\n「그런 말을 하고 자기가 죽으면 어떡해…」\n그의 죽음을 슬퍼하는 둘에게 다가오는 그림자…"
      },
      "STMSN_02012M": {
        "ID": "STMSN_02012M",
        "Text": "계략"
      },
      "STMSN_02012M_EXPLANATION": {
        "ID": "STMSN_02012M_EXPLANATION",
        "Text": "죠고가 주술사를 이길 방법을 묻자\n게토의 대답은…\n「두 가지 조건을 충족하면 이길 수 있어」"
      },
      "STMSN_02013M": {
        "ID": "STMSN_02013M",
        "Text": "구속"
      },
      "STMSN_02013M_EXPLANATION": {
        "ID": "STMSN_02013M_EXPLANATION",
        "Text": "죽었던 이타도리는 스쿠나와 노려보고 있었다.\n「우린 아직 죽지 않았어」\n스쿠나는 되살아나기 위한 조건을 제시하는데…"
      },
      "STMSN_02014M": {
        "ID": "STMSN_02014M",
        "Text": "어떤 몽상"
      },
      "STMSN_02014M_EXPLANATION": {
        "ID": "STMSN_02014M_EXPLANATION",
        "Text": "고죠는 이지치에게 자신의 꿈을 이야기하는데…\n「고, 고, 고죠 씨!!」\n이지치가 목격한 것은?!"
      },
      "STMSN_02015M": {
        "ID": "STMSN_02015M",
        "Text": "영화 감상"
      },
      "STMSN_02015M_EXPLANATION": {
        "ID": "STMSN_02015M_EXPLANATION",
        "Text": "자신의 나약함을 깨달은 이타도리에게\n고죠는 주력을 제어하는 수행을 시킨다.\n「강해지고 싶어요. \"최강\"을 가르쳐 주세요」"
      },
      "STMSN_02016M": {
        "ID": "STMSN_02016M",
        "Text": "매진하다 -1-"
      },
      "STMSN_02016M_EXPLANATION": {
        "ID": "STMSN_02016M_EXPLANATION",
        "Text": "판다에게 내던져져 하늘을 나는 쿠기사키…\n「큭… 아니거든요!」\n교류회를 향해 매진한다!"
      },
      "STMSN_02017M": {
        "ID": "STMSN_02017M",
        "Text": "매진하다 -2-"
      },
      "STMSN_02017M_EXPLANATION": {
        "ID": "STMSN_02017M_EXPLANATION",
        "Text": "후시구로는 주구 사용과 소지 방법을 고민한다.\n「너 그때 왜 도망친 거냐?」\n문득 떠오른 스쿠나의 말에 무언가를 깨닫는데…"
      },
      "STMSN_02018S": {
        "ID": "STMSN_02018S",
        "Text": "매진하다 -3-"
      },
      "STMSN_02018S_EXPLANATION": {
        "ID": "STMSN_02018S_EXPLANATION",
        "Text": "항상 1 대 1로 싸운다는 보장은 없다…\n소년원에서 그것을 통감한 쿠기사키는\n마키, 이누마키와 함께 특훈을 시작한다!"
      },
      "STMSN_02019S": {
        "ID": "STMSN_02019S",
        "Text": "매진하다 -4-"
      },
      "STMSN_02019S_EXPLANATION": {
        "ID": "STMSN_02019S_EXPLANATION",
        "Text": "거대한 적과의 싸움… 일전에 거대한\n주령과 싸워서 부상을 입었던 후시구로는\n판다와 함께 특훈을 시작한다!"
      },
      "STMSN_02020S": {
        "ID": "STMSN_02020S",
        "Text": "매진하다 -5-"
      },
      "STMSN_02020S_EXPLANATION": {
        "ID": "STMSN_02020S_EXPLANATION",
        "Text": "특훈으로 피폐해져 휴식을 취하던\n후시구로와 쿠기사키 앞에\n웃는 얼굴로 등장한 고죠가 둘에게…"
      },
      "STMSN_02021M": {
        "ID": "STMSN_02021M",
        "Text": "급습"
      },
      "STMSN_02021M_EXPLANATION": {
        "ID": "STMSN_02021M_EXPLANATION",
        "Text": "이동 중인 고죠가 급습당한다!\n「넌 누구지?」\n습격자의 목적은 대체…"
      },
      "STMSN_02022M": {
        "ID": "STMSN_02022M",
        "Text": "영역"
      },
      "STMSN_02022M_EXPLANATION": {
        "ID": "STMSN_02022M_EXPLANATION",
        "Text": "생득 영역의 구현화 \"영역 전개\".\n주술전의 정점이라고 불리는 싸움이 시작된다…"
      },
      "STMSN_02023M": {
        "ID": "STMSN_02023M",
        "Text": "저주답게"
      },
      "STMSN_02023M_EXPLANATION": {
        "ID": "STMSN_02023M_EXPLANATION",
        "Text": "하나미의 도움으로 도주에 성공한 죠고에게\n게토가 고죠를 이길 수 있는 작전을 설명한다.\n그곳에는 새로운 주령의 모습이…"
      },
      "STMSN_02024M": {
        "ID": "STMSN_02024M",
        "Text": "주력"
      },
      "STMSN_02024M_EXPLANATION": {
        "ID": "STMSN_02024M_EXPLANATION",
        "Text": "주술을 악용하는 자, \"주저사\".\n그 대처 방법을 이타도리에게 가르치던 고죠는\n이타도리의 어떤 습관을 알아차리는데…"
      },
      "STMSN_02025M": {
        "ID": "STMSN_02025M",
        "Text": "사자"
      },
      "STMSN_02025M_EXPLANATION": {
        "ID": "STMSN_02025M_EXPLANATION",
        "Text": "벌칙 게임을 만들어 특훈하는 마키,\n후시구로, 쿠기사키. 셋은 아직 모른다.\n어떤 자들이 주술고전을 방문했다는 사실을…"
      },
      "STMSN_02026M": {
        "ID": "STMSN_02026M",
        "Text": "지루함"
      },
      "STMSN_02026M_EXPLANATION": {
        "ID": "STMSN_02026M_EXPLANATION",
        "Text": "후시구로, 쿠기사키를 평가하러 온\n토도의 질문. 「어떤 여자가 취향이지?」\n마지못해 대답하는 후시구로…였으나!"
      },
      "STMSN_02027S": {
        "ID": "STMSN_02027S",
        "Text": "분발"
      },
      "STMSN_02027S_EXPLANATION": {
        "ID": "STMSN_02027S_EXPLANATION",
        "Text": "마이에게 당한 쿠기사키는 더 큰 힘을 원했다!\n「마지막으로 믿을 건 자기 육체란 말이지…」\n쿠기사키는 이누마키와 판다를 발견하고는…"
      },
      "STMSN_02028M": {
        "ID": "STMSN_02028M",
        "Text": "충고"
      },
      "STMSN_02028M_EXPLANATION": {
        "ID": "STMSN_02028M_EXPLANATION",
        "Text": "보수파 우두머리인 가쿠간지와 고죠의 대면.\n이타도리와 관련된 사건, 그리고 앞으로의\n주술계에 관해 이야기하기 시작하는데…"
      },
      "STMSN_03029M": {
        "ID": "STMSN_03029M",
        "Text": "어린 물고기와 역벌"
      },
      "STMSN_03029M_EXPLANATION": {
        "ID": "STMSN_03029M_EXPLANATION",
        "Text": "영화관에서 고등학생 3명의 변사체가 발견된다.\n피해자와 \"관계\"가 있던 소년은\n범인인 주령과 접촉하고…"
      },
      "STMSN_03030M": {
        "ID": "STMSN_03030M",
        "Text": "샐러리맨을 탈출한 주술사"
      },
      "STMSN_03030M_EXPLANATION": {
        "ID": "STMSN_03030M_EXPLANATION",
        "Text": "이타도리는 인솔자인 나나미와 함께\n변사 사건을 조사하러 간다.\n현장에서 발견한 잔예 앞에서 두 사람은…"
      },
      "STMSN_03031M": {
        "ID": "STMSN_03031M",
        "Text": "경정권"
      },
      "STMSN_03031M_EXPLANATION": {
        "ID": "STMSN_03031M_EXPLANATION",
        "Text": "이타도리는 고죠와의 특훈으로\n습득한 기술을 발휘한다.\n한편, 나나미는 어떤 것을 눈치채고…"
      },
      "STMSN_03032M": {
        "ID": "STMSN_03032M",
        "Text": "영혼의 형태"
      },
      "STMSN_03032M_EXPLANATION": {
        "ID": "STMSN_03032M_EXPLANATION",
        "Text": "마히토의 잠복 장소를 알아내서\n단독으로 그곳을 향하는 나나미.\n하지만 잠복 장소에는 대량의…"
      },
      "STMSN_03033M": {
        "ID": "STMSN_03033M",
        "Text": "조사"
      },
      "STMSN_03033M_EXPLANATION": {
        "ID": "STMSN_03033M_EXPLANATION",
        "Text": "조사하러 온 이타도리와 대화한 요시노는\n엄마를 떠올리며 고민한다. 하지만 뒤에서\n마히토 일당이 계획대로 움직이기 시작하는데…"
      },
      "STMSN_03034M": {
        "ID": "STMSN_03034M",
        "Text": "시간 외 노동"
      },
      "STMSN_03034M_EXPLANATION": {
        "ID": "STMSN_03034M_EXPLANATION",
        "Text": "마히토의 맹공에 방어만 하던 나나미는\n자신에게 걸려 있던 제한을 해제하여\n반격을 시작한다!"
      },
      "STMSN_03035M": {
        "ID": "STMSN_03035M",
        "Text": "언젠가 그날의 너에게"
      },
      "STMSN_03035M_EXPLANATION": {
        "ID": "STMSN_03035M_EXPLANATION",
        "Text": "엄마를 주살당한 요시노는\n범인을 찾으려 사토자쿠라 고등학교를 습격한다.\n이타도리가 사태를 수습하기 위해 나서지만…"
      },
      "STMSN_03036M": {
        "ID": "STMSN_03036M",
        "Text": "천적"
      },
      "STMSN_03036M_EXPLANATION": {
        "ID": "STMSN_03036M_EXPLANATION",
        "Text": "이타도리의 위기에 나나미가 달려온다.\n마히토의 변화를 눈치채고\n둘은 맹공을 퍼붓기 시작한다!"
      },
      "STMSN_03037M": {
        "ID": "STMSN_03037M",
        "Text": "성장"
      },
      "STMSN_03037M_EXPLANATION": {
        "ID": "STMSN_03037M_EXPLANATION",
        "Text": "개조 인간에게 방어로 일관하던 이타도리.\n「죽여…줘…」\n죽여달라고 부탁하는 말을 듣자…"
      },
      "STMSN_03038M": {
        "ID": "STMSN_03038M",
        "Text": "내일 보자"
      },
      "STMSN_03038M_EXPLANATION": {
        "ID": "STMSN_03038M_EXPLANATION",
        "Text": "나나미의 위기에 달려온 이타도리.\n둘은 결착을 짓고자 맹공을 재개하지만\n마히토는 \"비기\"를…"
      },
      "STMSN_03039M": {
        "ID": "STMSN_03039M",
        "Text": "반성"
      },
      "STMSN_03039M_EXPLANATION": {
        "ID": "STMSN_03039M_EXPLANATION",
        "Text": "패주한 마히토는 이번 실패를 반성하고\n게토는 앞으로의 작전에 관해 얘기를 시작한다…"
      },
      "STMSN_03040S": {
        "ID": "STMSN_03040S",
        "Text": "여자 모임"
      },
      "STMSN_03040S_EXPLANATION": {
        "ID": "STMSN_03040S_EXPLANATION",
        "Text": "어느 휴일. 왠지 기분이 나빠 보이는\n쿠기사키가 마키를 찾아온다. 그 원인은\n쿠기사키가 쇼핑하러 갔을 때로 거슬러 올라가…"
      },
      "STMSN_03041S": {
        "ID": "STMSN_03041S",
        "Text": "선배와 후배 -1-"
      },
      "STMSN_03041S_EXPLANATION": {
        "ID": "STMSN_03041S_EXPLANATION",
        "Text": "「돌아가면 느긋하게 쉬어야겠어」\n시간 내에 임무를 끝낸 나나미 앞에\n고죠가 무언가를 부탁하러 나타난다…"
      },
      "STMSN_03042S": {
        "ID": "STMSN_03042S",
        "Text": "판다와 판다"
      },
      "STMSN_03042S_EXPLANATION": {
        "ID": "STMSN_03042S_EXPLANATION",
        "Text": "어느 휴일. 후시구로, 이누마키는\n판다와 함께 새로 나온 판다 상품을\n사러 가기로 하는데…"
      },
      "STMSN_03043S": {
        "ID": "STMSN_03043S",
        "Text": "선배와 후배 -2-"
      },
      "STMSN_03043S_EXPLANATION": {
        "ID": "STMSN_03043S_EXPLANATION",
        "Text": "「오, 마침 잘 만났다」\n특훈 중인 쿠기사키와 마키 앞에\n나나미에게 \"부탁\"을 거절당한 고죠가 나타나…"
      },
      "STMSN_04044M": {
        "ID": "STMSN_04044M",
        "Text": "서프라이즈"
      },
      "STMSN_04044M_EXPLANATION": {
        "ID": "STMSN_04044M_EXPLANATION",
        "Text": "교토 자매 학교 교류회, 개최 당일!\n그리고 이타도리의 생존을 공표하는\n날이기도 했다. 과연 모두의 반응은…"
      },
      "STMSN_04045M": {
        "ID": "STMSN_04045M",
        "Text": "작전 회의"
      },
      "STMSN_04045M_EXPLANATION": {
        "ID": "STMSN_04045M_EXPLANATION",
        "Text": "죽은 줄 알았던 이타도리는 예상외의 전력…\n어떻게 이용할지 고민하던 마키는\n후시구로의 한마디에 생각을 바꾼다…"
      },
      "STMSN_04046M": {
        "ID": "STMSN_04046M",
        "Text": "교토 자매 학교 교류회"
      },
      "STMSN_04046M_EXPLANATION": {
        "ID": "STMSN_04046M_EXPLANATION",
        "Text": "교토 자매 학교 교류회 첫째 날,\n저마다의 속셈이 뒤엉킨 단체전이 시작된다…"
      },
      "STMSN_04047M": {
        "ID": "STMSN_04047M",
        "Text": "평가"
      },
      "STMSN_04047M_EXPLANATION": {
        "ID": "STMSN_04047M_EXPLANATION",
        "Text": "작전대로 행동을 개시한 도쿄고 진영에\n단독으로 공격에 나선 자가 모습을 드러낸다!"
      },
      "STMSN_04048M": {
        "ID": "STMSN_04048M",
        "Text": "나쁜 습관"
      },
      "STMSN_04048M_EXPLANATION": {
        "ID": "STMSN_04048M_EXPLANATION",
        "Text": "전투 중에 성장을 거듭하는 이타도리!\n하지만 토도는 어떤 것을 알아차린다…\n「그건 네 나쁜 습관이야!」"
      },
      "STMSN_04049M": {
        "ID": "STMSN_04049M",
        "Text": "침입"
      },
      "STMSN_04049M_EXPLANATION": {
        "ID": "STMSN_04049M_EXPLANATION",
        "Text": "각각의 싸움이 결착을 짓는 와중에\n단독으로 행동하던 이누마키 앞에\n불온한 기척이 다가온다…"
      },
      "STMSN_04050M": {
        "ID": "STMSN_04050M",
        "Text": "현자"
      },
      "STMSN_04050M_EXPLANATION": {
        "ID": "STMSN_04050M_EXPLANATION",
        "Text": "숲을 두려워하는 마음에서 태어난 자,\n격이 다른 특급 주령.\n후시구로 일행은 전투를 피하려 하지만…"
      },
      "STMSN_04051M": {
        "ID": "STMSN_04051M",
        "Text": "주구"
      },
      "STMSN_04051M_EXPLANATION": {
        "ID": "STMSN_04051M_EXPLANATION",
        "Text": "하나미의 맹공을 버틴 후시구로 일행.\n하지만 그 종이 한 장의 균형이\n깨지려 하고 있었다…"
      },
      "STMSN_04052M": {
        "ID": "STMSN_04052M",
        "Text": "흑섬"
      },
      "STMSN_04052M_EXPLANATION": {
        "ID": "STMSN_04052M_EXPLANATION",
        "Text": "\"흑섬\".\n주력의 핵심을 몰아붙이는 검은 섬광…\n이타도리는 진화하기 시작한다…"
      },
      "STMSN_04053M": {
        "ID": "STMSN_04053M",
        "Text": "답답함"
      },
      "STMSN_04053M_EXPLANATION": {
        "ID": "STMSN_04053M_EXPLANATION",
        "Text": "흑섬을 익히고 성장한 이타도리.\n토도와 함께 맹공을 개시한다!!\n「자, 조리를 시작해 볼까?」"
      },
      "STMSN_04054M": {
        "ID": "STMSN_04054M",
        "Text": "규격 외"
      },
      "STMSN_04054M_EXPLANATION": {
        "ID": "STMSN_04054M_EXPLANATION",
        "Text": "드디어 토도가 술식을 해금한다!\n자칭 IQ 53만이 도출해낸 결론은…"
      },
      "STMSN_04055M": {
        "ID": "STMSN_04055M",
        "Text": "주술 야구 대회"
      },
      "STMSN_04055M_EXPLANATION": {
        "ID": "STMSN_04055M_EXPLANATION",
        "Text": "교류회가 재개되고\n2회전은… 야구?!\n주술 야구 대회, 플레이 볼!"
      },
      "STMSN_04056S": {
        "ID": "STMSN_04056S",
        "Text": "합동 실습수업 -1-"
      },
      "STMSN_04056S_EXPLANATION": {
        "ID": "STMSN_04056S_EXPLANATION",
        "Text": "(고죠의 변덕으로)1학년과 2학년의\n합동 실습수업이 시작된다!\n주술고전은 일상을 되찾아 가고 있었다…"
      },
      "STMSN_04057S": {
        "ID": "STMSN_04057S",
        "Text": "개화"
      },
      "STMSN_04057S_EXPLANATION": {
        "ID": "STMSN_04057S_EXPLANATION",
        "Text": "작전은 성공했지만 중상인 하나미는\n싸움의 희열을 알고 더욱 성장한다…\n「하나미도 저주다워졌네」"
      },
      "STMSN_04058S": {
        "ID": "STMSN_04058S",
        "Text": "합동 실습수업 -2-"
      },
      "STMSN_04058S_EXPLANATION": {
        "ID": "STMSN_04058S_EXPLANATION",
        "Text": "합동 실습 2회전,\n어째서인지 교토고의 토도가 참전!\n토도에게 \"빚\"이 있는 후시구로는…"
      },
      "STMSN_05059M": {
        "ID": "STMSN_05059M",
        "Text": "기수뇌동"
      },
      "STMSN_05059M_EXPLANATION": {
        "ID": "STMSN_05059M_EXPLANATION",
        "Text": "비주술사가 주살당하는 사건이 발생한다.\n이타도리 일행이 조사를 진행하면서\n점차 충격적인 사실이 밝혀지는데…"
      },
      "STMSN_05060M": {
        "ID": "STMSN_05060M",
        "Text": "다른 사건"
      },
      "STMSN_05060M_EXPLANATION": {
        "ID": "STMSN_05060M_EXPLANATION",
        "Text": "영역 내로 들어온 이타도리 일행은\n주령과 대치한다.\n하지만 침입자는 셋 뿐만이 아니었다…"
      },
      "STMSN_05061M": {
        "ID": "STMSN_05061M",
        "Text": "심부름"
      },
      "STMSN_05061M_EXPLANATION": {
        "ID": "STMSN_05061M_EXPLANATION",
        "Text": "갑자기 영역 밖으로 끌려 나온 쿠기사키.\n새로운 적의 정체와 목적은?\n그리고 주살 사건의 진상은…"
      },
      "STMSN_05062M": {
        "ID": "STMSN_05062M",
        "Text": "공진"
      },
      "STMSN_05062M_EXPLANATION": {
        "ID": "STMSN_05062M_EXPLANATION",
        "Text": "후시구로는 눈앞의 주령 퇴치에 성공하지만\n영역은 닫히지 않고, \"어떤 사건\"에 공명해\n깨어난 것이 그 모습을 드러낸다…"
      },
      "STMSN_05063M": {
        "ID": "STMSN_05063M",
        "Text": "한계 너머"
      },
      "STMSN_05063M_EXPLANATION": {
        "ID": "STMSN_05063M_EXPLANATION",
        "Text": "눈을 뜬 후시구로는 \"비기\"를 쓰려고 하지만\n「보물을 가지고도 썩히는 꼴이군」\n뇌리를 스친 스쿠나의 말에 손을 거둔다."
      },
      "STMSN_05064M": {
        "ID": "STMSN_05064M",
        "Text": "형제"
      },
      "STMSN_05064M_EXPLANATION": {
        "ID": "STMSN_05064M_EXPLANATION",
        "Text": "손가락의 기척을 느낀 에소우는\n교전을 피해 손가락 회수를 우선하지만\n\"배후\"에 이타도리가 나타나자 돌변하는데…"
      },
      "STMSN_05065M": {
        "ID": "STMSN_05065M",
        "Text": "공범"
      },
      "STMSN_05065M_EXPLANATION": {
        "ID": "STMSN_05065M_EXPLANATION",
        "Text": "「적중하면 이기는 술식이라. 너희, 강하구나」\n에소우 일당에게 밀리는 이타도리와 쿠기사키.\n과연 둘은 절망적인 상황을 뒤집을 수 있을까…"
      },
      "STMSN_05066M": {
        "ID": "STMSN_05066M",
        "Text": "추천"
      },
      "STMSN_05066M_EXPLANATION": {
        "ID": "STMSN_05066M_EXPLANATION",
        "Text": "주술계를 인솔해 나갈 존재인 \"1급\"에\n이타도리를 포함한 도쿄고의 5명이 추천되고…"
      },
      "STMSN_05067S": {
        "ID": "STMSN_05067S",
        "Text": "막간의 휴일"
      },
      "STMSN_05067S_EXPLANATION": {
        "ID": "STMSN_05067S_EXPLANATION",
        "Text": "어느 휴일, 쿠기사키와 마키는\n고죠가 추천해준 가게로 향하지만\n그 추천에는 당연히 속셈이 있었고…"
      },
      "STMSN_05068S": {
        "ID": "STMSN_05068S",
        "Text": "속임수"
      },
      "STMSN_05068S_EXPLANATION": {
        "ID": "STMSN_05068S_EXPLANATION",
        "Text": "카드 게임에서 연승하는 마히토. 수상하게 여긴\n죠고와 하나미는 속임수를 의심한다!\n마히토는 부정하지만 진상은…"
      },
      "STMSN_05069S": {
        "ID": "STMSN_05069S",
        "Text": "막간의 시험"
      },
      "STMSN_05069S_EXPLANATION": {
        "ID": "STMSN_05069S_EXPLANATION",
        "Text": "야소하치 다리 사건을 들은 이누마키와 판다는\n후시구로의 성장을 확인하기 위해 대련한다!\n「얼마나 강해졌는지 보여줘」"
      },
      "STMSN_05070S": {
        "ID": "STMSN_05070S",
        "Text": "막간의 임무"
      },
      "STMSN_05070S_EXPLANATION": {
        "ID": "STMSN_05070S_EXPLANATION",
        "Text": "나나미의 임무에 멋대로 동행하는\n이타도리와 고죠. 평소 같은 변덕이 아니라\n고죠에겐 뭔가 속셈이 있는 듯한데…"
      },
      "STMSN_06071M": {
        "ID": "STMSN_06071M",
        "Text": "저주받은 아이"
      },
      "STMSN_06071M_EXPLANATION": {
        "ID": "STMSN_06071M_EXPLANATION",
        "Text": "저주로 고통받아 죽음을 원하는 소년…\n주술사로서, 인간으로서 성장하기 위해\n주술고전에서 저주를 배우고, 저주와 싸운다."
      },
      "STMSN_06072M": {
        "ID": "STMSN_06072M",
        "Text": "저주의 여왕"
      },
      "STMSN_06072M_EXPLANATION": {
        "ID": "STMSN_06072M_EXPLANATION",
        "Text": "옷코츠에게 주술고전에 온 이유를 묻는 마키.\n소년은 대답한다. 자신의 소망을…"
      },
      "STMSN_06073S": {
        "ID": "STMSN_06073S",
        "Text": "걱정"
      },
      "STMSN_06073S_EXPLANATION": {
        "ID": "STMSN_06073S_EXPLANATION",
        "Text": "이누마키, 판다도 팀 대전 실습에 도전!\n「토게, 넌 전학생이 마음에 걸려?」\n이누마키가 옷코츠를 걱정하는 이유는…"
      },
      "STMSN_06074M": {
        "ID": "STMSN_06074M",
        "Text": "해주"
      },
      "STMSN_06074M_EXPLANATION": {
        "ID": "STMSN_06074M_EXPLANATION",
        "Text": "실습 후, 옷코츠는 리카의 해주를 결의한다.\n「이걸 사용하도록」\n해주를 위해 고죠가 건네준 것은…"
      },
      "STMSN_06075M": {
        "ID": "STMSN_06075M",
        "Text": "단련"
      },
      "STMSN_06075M_EXPLANATION": {
        "ID": "STMSN_06075M_EXPLANATION",
        "Text": "해주를 위해 칼 사용법을 배우는 옷코츠.\n고죠와의 특훈으로 끝…이 아니었다!\n파워 특훈의 상대로 선택된 것은…"
      },
      "STMSN_06076S": {
        "ID": "STMSN_06076S",
        "Text": "합동 전투 실습 -1-"
      },
      "STMSN_06076S_EXPLANATION": {
        "ID": "STMSN_06076S_EXPLANATION",
        "Text": "마키의 부상이 완치된 기념으로\n팀 대전 형식의 대회가 개최!\n궁금한 팀 편성 결과는…"
      },
      "STMSN_06077M": {
        "ID": "STMSN_06077M",
        "Text": "벌의 유무"
      },
      "STMSN_06077M_EXPLANATION": {
        "ID": "STMSN_06077M_EXPLANATION",
        "Text": "계절이 바뀌어 여름이 되었을 무렵,\n수업과 특훈을 통해 옷코츠와\n마키 일행의 거리는 조금씩 가까워졌다."
      },
      "STMSN_06078M": {
        "ID": "STMSN_06078M",
        "Text": "까맣게, 까맣게"
      },
      "STMSN_06078M_EXPLANATION": {
        "ID": "STMSN_06078M_EXPLANATION",
        "Text": "이누마키의 임무에 옷코츠도 동행하게 되고…\n옷코츠는 의사소통이 불가능한 이누마키를\n아직은 조금 무서워하고 있었다…"
      },
      "STMSN_06079S": {
        "ID": "STMSN_06079S",
        "Text": "합동 전투 실습 -2-"
      },
      "STMSN_06079S_EXPLANATION": {
        "ID": "STMSN_06079S_EXPLANATION",
        "Text": "상점가 사건으로 거리가 좁혀진\n이누마키와 옷코츠. 다시금 개최된\n팀 대전 실습에 함께 참전한다!"
      },
      "STMSN_06080M": {
        "ID": "STMSN_06080M",
        "Text": "약자에게 벌을"
      },
      "STMSN_06080M_EXPLANATION": {
        "ID": "STMSN_06080M_EXPLANATION",
        "Text": "주저사. 저주를 이용해 세상을 위협하는 자…\n특히나 최악이라는 게토가 주술고전에 나타난다.\n게토는 자신의 \"계획\"을 소리 높여 선언한다…"
      },
      "STMSN_06081M": {
        "ID": "STMSN_06081M",
        "Text": "구면"
      },
      "STMSN_06081M_EXPLANATION": {
        "ID": "STMSN_06081M_EXPLANATION",
        "Text": "고죠는 미숙했던 학창 시절을 회상한다.\n게토와 함께 보낸 날들…\n그리고 결별한 날을…"
      },
      "STMSN_06082M": {
        "ID": "STMSN_06082M",
        "Text": "강하고 솔직하게"
      },
      "STMSN_06082M_EXPLANATION": {
        "ID": "STMSN_06082M_EXPLANATION",
        "Text": "게토가 한 말을 생각하는 옷코츠에게\n마키가 자신의 성장배경을 얘기한다.\n그런 둘에게 독니가 다가오는데…"
      },
      "STMSN_06083M": {
        "ID": "STMSN_06083M",
        "Text": "사수"
      },
      "STMSN_06083M_EXPLANATION": {
        "ID": "STMSN_06083M_EXPLANATION",
        "Text": "전선에 나오지 않는 게토에게 위화감을 느낀\n고죠는 이누마키, 판다를 주술고전으로 보낸다.\n「두 사람을 지켜. 미안하지만 사수해라!!」"
      },
      "STMSN_06084M": {
        "ID": "STMSN_06084M",
        "Text": "완전 현현"
      },
      "STMSN_06084M_EXPLANATION": {
        "ID": "STMSN_06084M_EXPLANATION",
        "Text": "마키 일행의 무참한 모습을 목격한 옷코츠…\n「죽여버리겠어」\n최악의 주저사와 맞서게 된다."
      },
      "STMSN_06085M": {
        "ID": "STMSN_06085M",
        "Text": "눈부신 어둠"
      },
      "STMSN_06085M_EXPLANATION": {
        "ID": "STMSN_06085M_EXPLANATION",
        "Text": "자신의 존재를 걸고 싸우는 자.\n대의를 위해 싸우는 자.\n두 사람의 최후의 싸움이 시작된다…"
      },
      "STMSN_06086M": {
        "ID": "STMSN_06086M",
        "Text": "고마워"
      },
      "STMSN_06086M_EXPLANATION": {
        "ID": "STMSN_06086M_EXPLANATION",
        "Text": "옷코츠가 눈을 뜨자 걱정스레 바라보는\n마키 일행과 리카의 모습이 있었다.\n자신을 희생한 옷코츠에게 리카는…"
      },
      "STMSN_06087S": {
        "ID": "STMSN_06087S",
        "Text": "이제부터"
      },
      "STMSN_06087S_EXPLANATION": {
        "ID": "STMSN_06087S_EXPLANATION",
        "Text": "리카의 해주를 달성하고 한참이 지났을 무렵,\n옷코츠의 \"지금\"의 힘을 확인한 고죠는\n부탁이 있다고 하는데…"
      },
      "STMSN_06088S": {
        "ID": "STMSN_06088S",
        "Text": "사제"
      },
      "STMSN_06088S_EXPLANATION": {
        "ID": "STMSN_06088S_EXPLANATION",
        "Text": "이것은 존재했을지도 모르는 싸움…\n고죠 선생님에게 제자들이 도전한다.\n최강을 뛰어넘어라! 젊은이들이여!"
      },
      "STMSN_06089S": {
        "ID": "STMSN_06089S",
        "Text": "특급의 칭호를 지닌 저주"
      },
      "STMSN_06089S_EXPLANATION": {
        "ID": "STMSN_06089S_EXPLANATION",
        "Text": "여러 가지 공포로부터 태어난\n최상위 저주들…\n그들은 본능, 욕망, 목적을 위해 약동한다."
      },
      "STMSN_08090M": {
        "ID": "STMSN_08090M",
        "Text": "회옥"
      },
      "STMSN_08090M_EXPLANATION": {
        "ID": "STMSN_08090M_EXPLANATION",
        "Text": "젊은 시절의 고죠와 게토.\n최강의 두 사람의\n더는 돌아갈 수 없는 푸른 봄이 시작된다."
      },
      "STMSN_08091M": {
        "ID": "STMSN_08091M",
        "Text": "주술사 킬러"
      },
      "STMSN_08091M_EXPLANATION": {
        "ID": "STMSN_08091M_EXPLANATION",
        "Text": "주술고전 결계에 들어간 순간을 노려\n후시구로 토우지가 습격한다.\n예상을 뛰어넘는 토우지의 비밀이란?"
      },
      "STMSN_08092M": {
        "ID": "STMSN_08092M",
        "Text": "무너지는 소원"
      },
      "STMSN_08092M_EXPLANATION": {
        "ID": "STMSN_08092M_EXPLANATION",
        "Text": "텐겐과 동화하기 직전에\n아마나이는 자신의 마음을 따르려 한다.\n게토가 이뤄주려고 한 그 소원은…"
      },
      "STMSN_08093M": {
        "ID": "STMSN_08093M",
        "Text": "각성"
      },
      "STMSN_08093M_EXPLANATION": {
        "ID": "STMSN_08093M_EXPLANATION",
        "Text": "고죠는 죽지 않았다.\n죽기 직전에 깨우친 주력 조작의 핵심과 함께\n다시 토우지의 앞을 막아선다."
      },
      "STMSN_08094M": {
        "ID": "STMSN_08094M",
        "Text": "옥절"
      },
      "STMSN_08094M_EXPLANATION": {
        "ID": "STMSN_08094M_EXPLANATION",
        "Text": "최강이 된 고죠.\n혼자가 된 게토.\n갈라져 가는 두 사람의 길."
      },
      "STMSN_09095M": {
        "ID": "STMSN_09095M",
        "Text": "전야제"
      },
      "STMSN_09095M_EXPLANATION": {
        "ID": "STMSN_09095M_EXPLANATION",
        "Text": "주령 측과 내통했던 메카마루(무타 코키치).\n\"모두와 만나겠다\"는 소원을 이루기 위해\n이제껏 쌓아온 모든 걸 걸고 마히토와 싸운다."
      },
      "STMSN_09096M": {
        "ID": "STMSN_09096M",
        "Text": "시부야 사변: 개문"
      },
      "STMSN_09096M_EXPLANATION": {
        "ID": "STMSN_09096M_EXPLANATION",
        "Text": "2018년 10월 31일.\n핼러윈의 시부야에서 주저사들이\n어떤 계획을 실행에 옮긴다."
      },
      "STMSN_09097M": {
        "ID": "STMSN_09097M",
        "Text": "대치"
      },
      "STMSN_09097M_EXPLANATION": {
        "ID": "STMSN_09097M_EXPLANATION",
        "Text": "시부야에 도착한 고죠 사토루를\n기다리는 적과 함정.\n고죠와 주령들의 싸움이 시작된다."
      },
      "STMSN_09098M": {
        "ID": "STMSN_09098M",
        "Text": "옥문강"
      },
      "STMSN_09098M_EXPLANATION": {
        "ID": "STMSN_09098M_EXPLANATION",
        "Text": "고죠 사토루를 봉인하기 위해 준비된 옥문강.\n그 개문과 동시에 등장한 것은\n의외의 인물이었다."
      },
      "STMSN_09099M": {
        "ID": "STMSN_09099M",
        "Text": "혼란"
      },
      "STMSN_09099M_EXPLANATION": {
        "ID": "STMSN_09099M_EXPLANATION",
        "Text": "미니 메카마루가 고죠의 봉인을 알리자\n이타도리는 국면을 타개하기 위해\n나나미와 합류하기로 한다."
      },
      "STMSN_09100M": {
        "ID": "STMSN_09100M",
        "Text": "강령"
      },
      "STMSN_09100M_EXPLANATION": {
        "ID": "STMSN_09100M_EXPLANATION",
        "Text": "주저사들이 \"눈에 띄는 장소\"에서\n\"장막\"의 토대를 지키리라 생각한\n이타도리 일행은 높은 빌딩의 옥상으로 향한다."
      },
      "STMSN_09101M": {
        "ID": "STMSN_09101M",
        "Text": "무딘 칼"
      },
      "STMSN_09101M_EXPLANATION": {
        "ID": "STMSN_09101M_EXPLANATION",
        "Text": "부상당한 쿠기사키와 닛타 앞에 나타난 나나미는\n시게모를 향해 분노의 주먹을 휘둘렀다.\n그 압도적인 힘을 목격하는 쿠기사키."
      },
      "STMSN_09102M": {
        "ID": "STMSN_09102M",
        "Text": "혁린"
      },
      "STMSN_09102M_EXPLANATION": {
        "ID": "STMSN_09102M_EXPLANATION",
        "Text": "시부야 역 지하에 도착한 이타도리를\n공격하며 쵸소우가 묻는다.\n「내 동생이 마지막에 뭔가 남긴 말이 있나?」"
      },
      "STMSN_09103M": {
        "ID": "STMSN_09103M",
        "Text": "동요"
      },
      "STMSN_09103M_EXPLANATION": {
        "ID": "STMSN_09103M_EXPLANATION",
        "Text": "다곤의 영역에 들어간 나오비토, 나나미, 마키.\n큰 바다의 파도처럼 끝없이 몰아치는 공격에\n주술사들은 피폐해져 간다."
      },
      "STMSN_09104M": {
        "ID": "STMSN_09104M",
        "Text": "벽력"
      },
      "STMSN_09104M_EXPLANATION": {
        "ID": "STMSN_09104M_EXPLANATION",
        "Text": "이타도리에게서 육체의 주도권을 빼앗은\n양면 스쿠나는 \"구속\"을 맺으라는\n죠고의 제안을 거절하고, 대결을 제안한다."
      },
      "STMSN_09105M": {
        "ID": "STMSN_09105M",
        "Text": "폭주"
      },
      "STMSN_09105M_EXPLANATION": {
        "ID": "STMSN_09105M_EXPLANATION",
        "Text": "갑자기 나타난 수수께끼의 사내는 후시구로를\n다음 표적으로 정한다. 그 압도적인 힘 앞에서\n궁지에 몰린 후시구로는 필사적으로 싸운다."
      },
      "STMSN_09106M": {
        "ID": "STMSN_09106M",
        "Text": "이계신장"
      },
      "STMSN_09106M_EXPLANATION": {
        "ID": "STMSN_09106M_EXPLANATION",
        "Text": "시게모 하루타의 공격으로 위기에 처한\n후시구로는 자신의 술식 「십종영법술」 중\n어떤 식신을 소환하여 조복 의식을 시작한다."
      },
      "STMSN_09107M": {
        "ID": "STMSN_09107M",
        "Text": "이비"
      },
      "STMSN_09107M_EXPLANATION": {
        "ID": "STMSN_09107M_EXPLANATION",
        "Text": "큰 상처를 입고도 시부야를 방황하며 싸우는\n나나미 앞에 마히토가 나타난다.\n둘을 향해 달려온 이타도리가 목격한 것은…"
      },
      "STMSN_09108M": {
        "ID": "STMSN_09108M",
        "Text": "동심"
      },
      "STMSN_09108M_EXPLANATION": {
        "ID": "STMSN_09108M_EXPLANATION",
        "Text": "전선에 복귀한 쿠기사키는 마히토와 조우한다.\n공격이 안 통하는 마히토를 상대하면서도\n쿠기사키에겐 승산이 있었다."
      },
      "STMSN_09109M": {
        "ID": "STMSN_09109M",
        "Text": "상심"
      },
      "STMSN_09109M_EXPLANATION": {
        "ID": "STMSN_09109M_EXPLANATION",
        "Text": "마히토에게 큰 상흔을 남긴 쿠기사키도\n이타도리 앞에서 쓰러지고 만다. 이타도리는\n실의에 빠지고, 그곳에 한 남자가 나타난다."
      },
      "STMSN_09110M": {
        "ID": "STMSN_09110M",
        "Text": "유지"
      },
      "STMSN_09110M_EXPLANATION": {
        "ID": "STMSN_09110M_EXPLANATION",
        "Text": "동료에게서 맡은 것을 품고 일어선 이타도리.\n이타도리, 마히토에 이어 토도도 흑섬을 날리며\n세 명의 싸움은 더욱 치열해져 간다."
      },
      "STMSN_09111M": {
        "ID": "STMSN_09111M",
        "Text": "변신"
      },
      "STMSN_09111M_EXPLANATION": {
        "ID": "STMSN_09111M_EXPLANATION",
        "Text": "이타도리와의 사투 끝에\n마히토는 마침내 자기 영혼의 본질을 파악한다.\n변모한 마히토는 이타도리의 앞을 막아선다."
      },
      "STMSN_09112M": {
        "ID": "STMSN_09112M",
        "Text": "이수"
      },
      "STMSN_09112M_EXPLANATION": {
        "ID": "STMSN_09112M_EXPLANATION",
        "Text": "교토고 전원이 시부야로 향하고,\n그 열차 안에서 메카마루는 무타 코키치로서\n미와에게 마지막 유언을 남긴다."
      },
      "STMSN_09113M": {
        "ID": "STMSN_09113M",
        "Text": "혈전"
      },
      "STMSN_09113M_EXPLANATION": {
        "ID": "STMSN_09113M_EXPLANATION",
        "Text": "형제를 죽이게끔 조장한 남자의\n정체를 깨닫고 분노한 쵸소우는\n형으로서 전력을 다해 전투에 임한다."
      },
      "STMSN_09114M": {
        "ID": "STMSN_09114M",
        "Text": "시부야 사변: 폐문"
      },
      "STMSN_09114M_EXPLANATION": {
        "ID": "STMSN_09114M_EXPLANATION",
        "Text": "카모 노리토시라고 불린 남자가 말하는\n앞으로 펼쳐질 세계. 그것은\n끔찍한 혼돈과 더 큰 싸움의 시작이었다."
      },
      "STR_DEMO_LABEL_0001": {
        "ID": "STR_DEMO_LABEL_0001",
        "Text": "원작: 「주술회전」 Gege Akutami"
      },
      "STR_DEMO_LABEL_0002": {
        "ID": "STR_DEMO_LABEL_0002",
        "Text": "(Shueisha 「주간 소년 점프」 연재)"
      },
      "STR_DEMO_LABEL_0003": {
        "ID": "STR_DEMO_LABEL_0003",
        "Text": "제작: Bandai Namco Entertainment Inc."
      },
      "STR_STDM_SS_001": {
        "ID": "STR_STDM_SS_001",
        "Text": "후시구로의 편식"
      },
      "STR_STDM_SS_002": {
        "ID": "STR_STDM_SS_002",
        "Text": "지난날의…"
      },
      "STR_STDM_SS_003": {
        "ID": "STR_STDM_SS_003",
        "Text": "쿠기사키의 마음"
      },
      "STR_STDM_SS_004": {
        "ID": "STR_STDM_SS_004",
        "Text": "GT 고죠"
      },
      "STR_STDM_SS_005": {
        "ID": "STR_STDM_SS_005",
        "Text": "연례행사"
      },
      "STR_STDM_SS_006": {
        "ID": "STR_STDM_SS_006",
        "Text": "나나미의 요리"
      },
      "STR_STDM_SS_007": {
        "ID": "STR_STDM_SS_007",
        "Text": "사회란…"
      },
      "STR_STDM_SS_008": {
        "ID": "STR_STDM_SS_008",
        "Text": "모름지기 남자란!"
      },
      "STR_STDM_SS_009": {
        "ID": "STR_STDM_SS_009",
        "Text": "리서치"
      },
      "STR_STDM_SS_010": {
        "ID": "STR_STDM_SS_010",
        "Text": "알려줘요! 나나밍!"
      },
      "STR_STDM_SS_011": {
        "ID": "STR_STDM_SS_011",
        "Text": "초상화 배틀"
      },
      "STR_STDM_SS_012": {
        "ID": "STR_STDM_SS_012",
        "Text": "브라더"
      },
      "STR_STDM_SS_013": {
        "ID": "STR_STDM_SS_013",
        "Text": "다음 세대"
      },
      "STR_STDM_SS_014": {
        "ID": "STR_STDM_SS_014",
        "Text": "후시구로의 추천"
      },
      "STR_STDM_SS_015": {
        "ID": "STR_STDM_SS_015",
        "Text": "단련법…?"
      },
      "STR_STDM_SS_016": {
        "ID": "STR_STDM_SS_016",
        "Text": "무술의 재능"
      },
      "STR_STDM_SS_017": {
        "ID": "STR_STDM_SS_017",
        "Text": "이누마키 셀렉션"
      },
      "STR_STDM_SS_018": {
        "ID": "STR_STDM_SS_018",
        "Text": "선배의 친절"
      },
      "STR_STDM_SS_019": {
        "ID": "STR_STDM_SS_019",
        "Text": "꿍꿍이"
      },
      "STR_STDM_SS_020": {
        "ID": "STR_STDM_SS_020",
        "Text": "후시구로의 취향"
      },
      "STR_STDM_SS_021": {
        "ID": "STR_STDM_SS_021",
        "Text": "느낌"
      },
      "STR_STDM_SS_022": {
        "ID": "STR_STDM_SS_022",
        "Text": "달콤한 주술사"
      },
      "STR_STDM_SS_023": {
        "ID": "STR_STDM_SS_023",
        "Text": "아름다움의 비결"
      },
      "STR_STDM_SS_024": {
        "ID": "STR_STDM_SS_024",
        "Text": "코디네이터 쿠기사키"
      },
      "STR_STDM_SS_025": {
        "ID": "STR_STDM_SS_025",
        "Text": "이누마키어 터득?"
      },
      "STR_STDM_SS_026": {
        "ID": "STR_STDM_SS_026",
        "Text": "이미지 체인지"
      },
      "STR_STDM_SS_027": {
        "ID": "STR_STDM_SS_027",
        "Text": "판다는 판다?"
      },
      "STR_STDM_SS_028": {
        "ID": "STR_STDM_SS_028",
        "Text": "판다는 쿠션?"
      },
      "STR_STDM_SS_029": {
        "ID": "STR_STDM_SS_029",
        "Text": "사회인으로서"
      },
      "STR_STDM_SS_030": {
        "ID": "STR_STDM_SS_030",
        "Text": "고죠 선생님의 성서"
      },
      "STR_STDM_SS_031": {
        "ID": "STR_STDM_SS_031",
        "Text": "옛날과 지금"
      },
      "STR_STDM_SS_032": {
        "ID": "STR_STDM_SS_032",
        "Text": "하나미의 걱정"
      },
      "STR_STDM_SS_033": {
        "ID": "STR_STDM_SS_033",
        "Text": "신입"
