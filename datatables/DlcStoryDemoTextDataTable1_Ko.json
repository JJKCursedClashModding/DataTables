[
  {
    "Type": "DataTable",
    "Name": "DlcStoryDemoTextDataTable1_Ko",
    "Flags": "RF_Public | RF_Standalone | RF_Transactional | RF_WasLoaded | RF_LoadCompleted",
    "Class": "UScriptClass'DataTable'",
    "Properties": {
      "RowStruct": {
        "ObjectName": "Class'GameDataTableRow_GameText'",
        "ObjectPath": "/Script/Abrams"
      },
      "ImportKeyField": "Id"
    },
    "Rows": {
      "STDM_0809001_0010": {
        "ID": "STDM_0809001_0010",
        "Text": "뭐, 괜찮겠지"
      },
      "STDM_0809001_0015": {
        "ID": "STDM_0809001_0015",
        "Text": "우린 최강이니까"
      },
      "STDM_0809001_0020": {
        "ID": "STDM_0809001_0020",
        "Text": "시즈오카현 하마마츠시\n2006년"
      },
      "STDM_0809001_0030": {
        "ID": "STDM_0809001_0030",
        "Text": "구하러 왔어~"
      },
      "STDM_0809001_0040": {
        "ID": "STDM_0809001_0040",
        "Text": "주술고전 2학년 고죠 사토루"
      },
      "STDM_0809001_0050": {
        "ID": "STDM_0809001_0050",
        "Text": "약한 녀석들을 신경 쓰는 건\n정말 피곤해"
      },
      "STDM_0809001_0060": {
        "ID": "STDM_0809001_0060",
        "Text": "사토루, 약자를 괴롭히는 건 좋지 않아"
      },
      "STDM_0809001_0070": {
        "ID": "STDM_0809001_0070",
        "Text": "주술고전 2학년 게토 스구루"
      },
      "STDM_0809001_0080": {
        "ID": "STDM_0809001_0080",
        "Text": "약자 생존. 그게 사회의 합당한 모습이니까"
      },
      "STDM_0809001_0090": {
        "ID": "STDM_0809001_0090",
        "Text": "이 임무는 너희 둘이 가줘야겠어.\n의뢰는 두 가지. 성장체 텐겐 님과의 적합자인\n그 소녀의 호위와―― 말소다"
      },
      "STDM_0809001_0100": {
        "ID": "STDM_0809001_0100",
        "Text": "실패하면 그 영향은\n일반 사회에까지 미칠 테니\n명심하고 임해라!!"
      },
      "STDM_0809001_0110": {
        "ID": "STDM_0809001_0110",
        "Text": "「Ｑ」 최고 전력인 바이엘의 이탈로\n조직 와해"
      },
      "STDM_0809001_0120": {
        "ID": "STDM_0809001_0120",
        "Text": "좋아.\n그 제안, 받아들이지"
      },
      "STDM_0809001_0130": {
        "ID": "STDM_0809001_0130",
        "Text": "상대는 고죠 가문의 도련님이야.\n대놓고 나서 봤자\n아무것도 할 수 없어"
      },
      "STDM_0809001_0140": {
        "ID": "STDM_0809001_0140",
        "Text": "우선은 바보들을 이용해서 소모시켜야지"
      },
      "STDM_0809001_0150": {
        "ID": "STDM_0809001_0150",
        "Text": "쳇!"
      },
      "STDM_0809001_0160": {
        "ID": "STDM_0809001_0160",
        "Text": "잘 부탁한다, 주술사 킬러"
      },
      "STDM_0809001_0165": {
        "ID": "STDM_0809001_0165",
        "Text": "참, 그렇지. 메구미는 잘 지내?"
      },
      "STDM_0809001_0170": {
        "ID": "STDM_0809001_0170",
        "Text": "……"
      },
      "STDM_0809001_0175": {
        "ID": "STDM_0809001_0175",
        "Text": "그게 누구더라?"
      },
      "STDM_0809001_0180": {
        "ID": "STDM_0809001_0180",
        "Text": "고죠, 오키나와에서 쿠로이를 구출"
      },
      "STDM_0809001_0190": {
        "ID": "STDM_0809001_0190",
        "Text": "멘소레——!!"
      },
      "STDM_0809001_0200": {
        "ID": "STDM_0809001_0200",
        "Text": "오키나와\n호위 이틀째"
      },
      "STDM_0809001_0210": {
        "ID": "STDM_0809001_0210",
        "Text": "도립 주술고전 무시로야마 산기슭"
      },
      "STDM_0809001_0220": {
        "ID": "STDM_0809001_0220",
        "Text": "호위 사흘째 15:00"
      },
      "STDM_0809001_0230": {
        "ID": "STDM_0809001_0230",
        "Text": "주술고전 결계 안이야"
      },
      "STDM_0809001_0240": {
        "ID": "STDM_0809001_0240",
        "Text": "사토루, 정말 고생이 많았다"
      },
      "STDM_0809001_0250": {
        "ID": "STDM_0809001_0250",
        "Text": "하아~\n두 번 다시는 사양하겠어.\n어린애 보모 노릇은 말이야"
      },
      "STDM_0809001_0260": {
        "ID": "STDM_0809001_0260",
        "Text": "아… 아윽…"
      },
      "STDM_0809001_0270": {
        "ID": "STDM_0809001_0270",
        "Text": "당신, 어디선가 만났던가?"
      },
      "STDM_0809001_0280": {
        "ID": "STDM_0809001_0280",
        "Text": "신경 쓰지 마. 나도 서투니까 말이야.\n남자 이름을 외우는 건 말이지"
      },
      "STDM_0809101_0010": {
        "ID": "STDM_0809101_0010",
        "Text": "윽…!"
      },
      "STDM_0809101_0020": {
        "ID": "STDM_0809101_0020",
        "Text": "사토루!"
      },
      "STDM_0809101_0030": {
        "ID": "STDM_0809101_0030",
        "Text": "니트 스웨터에 옷핀 하나가\n꽂힌 거나 마찬가지야.\n정말 아무렇지도 않아"
      },
      "STDM_0809101_0040": {
        "ID": "STDM_0809101_0040",
        "Text": "그러니까 너는 아마나이를 우선시해.\n저 녀석은 내가 상대할게"
      },
      "STDM_0809101_0050": {
        "ID": "STDM_0809101_0050",
        "Text": "너희 먼저 텐겐 님이 계신 곳으로 가"
      },
      "STDM_0809101_0060": {
        "ID": "STDM_0809101_0060",
        "Text": "사토루…"
      },
      "STDM_0809101_0070": {
        "ID": "STDM_0809101_0070",
        "Text": "방심하지 마"
      },
      "STDM_0809101_0080": {
        "ID": "STDM_0809101_0080",
        "Text": "누구한테 하는 소리야?"
      },
      "STDM_0809101_0090": {
        "ID": "STDM_0809101_0090",
        "Text": "되도록이면 조금 전 그 공격으로\n고죠 사토루의 숨통은 끊어놓고 싶었는데…\n내 솜씨가 녹슬었나?"
      },
      "STDM_0809101_0100": {
        "ID": "STDM_0809101_0100",
        "Text": "아마나이의 현상금은 이미 철회됐어,\n이 멍청아"
      },
      "STDM_0809101_0110": {
        "ID": "STDM_0809101_0110",
        "Text": "현상금은 내가 철회시킨 거다,\n이 허세나 부리는 녀석아"
      },
      "STDM_0809101_0120": {
        "ID": "STDM_0809101_0120",
        "Text": "너처럼 빈틈없는 녀석한테는\n완급을 줘서 가짜 골 지점을\n여러 개 만들어놔야 하거든"
      },
      "STDM_0809101_0130": {
        "ID": "STDM_0809101_0130",
        "Text": "만약 현상금에 시간제한이 없었다면\n너는 끝까지\n술식을 풀지 않았을 테니까"
      },
      "STDM_0809101_0140": {
        "ID": "STDM_0809101_0140",
        "Text": "아, 그러셔?"
      },
      "STDM_0809102_0010": {
        "ID": "STDM_0809102_0010",
        "Text": "이 자식, 뭔가 이상하다 했더니만"
      },
      "STDM_0809102_0020": {
        "ID": "STDM_0809102_0020",
        "Text": "천여주박에 의한 피지컬 기프티드!!"
      },
      "STDM_0809103_0010": {
        "ID": "STDM_0809103_0010",
        "Text": "술식 순전.\n출력 최대!"
      },
      "STDM_0809103_0020": {
        "ID": "STDM_0809103_0020",
        "Text": "「창」"
      },
      "STDM_0809103_0030": {
        "ID": "STDM_0809103_0030",
        "Text": "이제 시야를 막는 장애물이 없으니\n기습은 불가능해"
      },
      "STDM_0809103_0040": {
        "ID": "STDM_0809103_0040",
        "Text": "저건…"
      },
      "STDM_0809103_0041": {
        "ID": "STDM_0809103_0041",
        "Text": "승두?!"
      },
      "STDM_0809103_0050": {
        "ID": "STDM_0809103_0050",
        "Text": "승두를 채프처럼 써먹겠다는 거군"
      },
      "STDM_0809103_0060": {
        "ID": "STDM_0809103_0060",
        "Text": "사각지대도 생겨났고 말이지.\n다시 한번 「창」으로…"
      },
      "STDM_0809103_0070": {
        "ID": "STDM_0809103_0070",
        "Text": "아니, 잠깐만.\n그 녀석의 목적은\n아마나이——"
      },
      "STDM_0809103_0080": {
        "ID": "STDM_0809103_0080",
        "Text": "비무장일 때의 내 기척도\n알아차리는 예리한 육감"
      },
      "STDM_0809103_0090": {
        "ID": "STDM_0809103_0090",
        "Text": "그렇지만 드디어\n술식에 의존하는\n방어 태세로 돌아섰군"
      },
      "STDM_0809201_0010": {
        "ID": "STDM_0809201_0010",
        "Text": "여기가…"
      },
      "STDM_0809201_0020": {
        "ID": "STDM_0809201_0020",
        "Text": "그래.\n텐겐 님이 계신 곳이자"
      },
      "STDM_0809201_0030": {
        "ID": "STDM_0809201_0030",
        "Text": "국내 주요 결계의 근간인\n훙성궁 본전이야"
      },
      "STDM_0809201_0040": {
        "ID": "STDM_0809201_0040",
        "Text": "계단을 내려간 뒤 문을 지나서\n저 거목의 뿌리까지 가면 돼"
      },
      "STDM_0809201_0050": {
        "ID": "STDM_0809201_0050",
        "Text": "동화할 때까지\n텐겐 님이 널 지켜주실 거야"
      },
      "STDM_0809201_0060": {
        "ID": "STDM_0809201_0060",
        "Text": "그게 싫으면, 발길을 돌려서\n쿠로이 씨와 함께 집으로 돌아가든가"
      },
      "STDM_0809201_0070": {
        "ID": "STDM_0809201_0070",
        "Text": "…뭐?"
      },
      "STDM_0809201_0080": {
        "ID": "STDM_0809201_0080",
        "Text": "너를 만나기 전에\n사토루하고는 이미 얘기가 끝났어"
      },
      "STDM_0809201_0090": {
        "ID": "STDM_0809201_0090",
        "Text": "성장체 꼬맹이가 동화를 거부했을 때~?"
      },
      "STDM_0809201_0100": {
        "ID": "STDM_0809201_0100",
        "Text": "그땐… 동화도 없는 거지!!"
      },
      "STDM_0809201_0110": {
        "ID": "STDM_0809201_0110",
        "Text": "킥킥. 괜찮겠어?"
      },
      "STDM_0809201_0120": {
        "ID": "STDM_0809201_0120",
        "Text": "텐겐 님과 싸우게 될지도 모르는데?"
      },
      "STDM_0809201_0130": {
        "ID": "STDM_0809201_0130",
        "Text": "겁먹었냐?"
      },
      "STDM_0809201_0140": {
        "ID": "STDM_0809201_0140",
        "Text": "걱정하지 마. 어떻게든 될 거야"
      },
      "STDM_0809201_0150": {
        "ID": "STDM_0809201_0150",
        "Text": "우린 최강이니까"
      },
      "STDM_0809201_0160": {
        "ID": "STDM_0809201_0160",
        "Text": "네가 어떤 선택을 하든\n네 미래는 우리가 보장할게"
      },
      "STDM_0809201_0170": {
        "ID": "STDM_0809201_0170",
        "Text": "…나는"
      },
      "STDM_0809201_0180": {
        "ID": "STDM_0809201_0180",
        "Text": "태어났을 때부터 성장체라서\n모두와는 다르다는 말을 듣고 자랐어"
      },
      "STDM_0809201_0190": {
        "ID": "STDM_0809201_0190",
        "Text": "그래서 성장체라는 특별함은\n내겐 평범한 거였고"
      },
      "STDM_0809201_0200": {
        "ID": "STDM_0809201_0200",
        "Text": "위험한 일은 최대한 피하며\n이날을 위해 살아왔지"
      },
      "STDM_0809201_0210": {
        "ID": "STDM_0809201_0210",
        "Text": "그래서 동화로 인해\n다른 사람들과 영영 헤어지더라도\n괜찮을 거라고 생각했어"
      },
      "STDM_0809201_0220": {
        "ID": "STDM_0809201_0220",
        "Text": "…그런데\n그런데, 역시"
      },
      "STDM_0809201_0230": {
        "ID": "STDM_0809201_0230",
        "Text": "모두와 좀 더 같이 있고 싶어"
      },
      "STDM_0809201_0240": {
        "ID": "STDM_0809201_0240",
        "Text": "모두와 좀 더 많은 곳을 가보고\n많은 것을 보고… 좀 더!!"
      },
      "STDM_0809201_0250": {
        "ID": "STDM_0809201_0250",
        "Text": "돌아가자. 리코"
      },
      "STDM_0809201_0260": {
        "ID": "STDM_0809201_0260",
        "Text": "…응!!"
      },
      "STDM_0809201_0270": {
        "ID": "STDM_0809201_0270",
        "Text": "리코?"
      },
      "STDM_0809201_0280": {
        "ID": "STDM_0809201_0280",
        "Text": "자, 수고했습니다.\n해산, 해산"
      },
      "STDM_0809201_0290": {
        "ID": "STDM_0809201_0290",
        "Text": "네가 왜 여기에 있는 거지?"
      },
      "STDM_0809201_0300": {
        "ID": "STDM_0809201_0300",
        "Text": "어? 왜냐니…"
      },
      "STDM_0809201_0310": {
        "ID": "STDM_0809201_0310",
        "Text": "아아, 그런 뜻인가?"
      },
      "STDM_0809201_0320": {
        "ID": "STDM_0809201_0320",
        "Text": "고죠 사토루는 내가 죽였다"
      },
      "STDM_0809201_0330": {
        "ID": "STDM_0809201_0330",
        "Text": "그래?"
      },
      "STDM_0809201_0340": {
        "ID": "STDM_0809201_0340",
        "Text": "그럼, 죽어"
      },
      "STDM_0809202_0010": {
        "ID": "STDM_0809202_0010",
        "Text": "어떻게 훙성궁으로 가는 문을 알아낸 거지?\n우린 털끝만큼도 잔예를 남기지 않았는데"
      },
      "STDM_0809202_0020": {
        "ID": "STDM_0809202_0020",
        "Text": "인간이 남기는 흔적은 잔예뿐만이 아니야"
      },
      "STDM_0809202_0030": {
        "ID": "STDM_0809202_0030",
        "Text": "냄새나 발자국도 있어.\n나는 주박으로 인해서\n오감도 능력치가 향상되어 있거든"
      },
      "STDM_0809202_0040": {
        "ID": "STDM_0809202_0040",
        "Text": "오는 길에 여성이 한 명 있었을 텐데,\n그녀는 어떻게 했지?"
      },
      "STDM_0809202_0050": {
        "ID": "STDM_0809202_0050",
        "Text": "뭐? 아아, 그 메이드?\n아마 죽었을걸?\n살려둘 생각도, 죽일 생각도 없었지만"
      },
      "STDM_0809202_0060": {
        "ID": "STDM_0809202_0060",
        "Text": "운이 좋으면 살아있지 않을까?"
      },
      "STDM_0809202_0070": {
        "ID": "STDM_0809202_0070",
        "Text": "그렇군.\n역시 넌, 죽어라"
      },
      "STDM_0809203_0010": {
        "ID": "STDM_0809203_0010",
        "Text": "멍청한 녀석… 끝났군"
      },
      "STDM_0809203_0020": {
        "ID": "STDM_0809203_0020",
        "Text": "네가 말이지"
      },
      "STDM_0809203_0030": {
        "ID": "STDM_0809203_0030",
        "Text": "능력은 특수하지만\n주령 자체는 강하지 않아.\n거둬들일 수 있어!!"
      },
      "STDM_0809203_0040": {
        "ID": "STDM_0809203_0040",
        "Text": "무기고는 확보했으니\n이젠 물량으로——"
      },
      "STDM_0809203_0050": {
        "ID": "STDM_0809203_0050",
        "Text": "헉…!!"
      },
      "STDM_0809203_0060": {
        "ID": "STDM_0809203_0060",
        "Text": "주술사라면 죽지 않을 정도로만 베었다"
      },
      "STDM_0809203_0070": {
        "ID": "STDM_0809203_0070",
        "Text": "식신 술사라면 죽였겠지만\n주령 조종술은 조금 찜찜해서 말이야"
      },
      "STDM_0809203_0080": {
        "ID": "STDM_0809203_0080",
        "Text": "네 사후에\n네가 거둬들인 주령들이\n어떻게 될지 모르잖아"
      },
      "STDM_0809203_0090": {
        "ID": "STDM_0809203_0090",
        "Text": "일단 골칫거리는 피하고 싶거든.\n참 축복받은 혈통이네"
      },
      "STDM_0809203_0100": {
        "ID": "STDM_0809203_0100",
        "Text": "하지만 그런 축복받은 너희가\n주술도 쓰지 못하는\n나 같은 원숭이한테 졌다는 사실을"
      },
      "STDM_0809203_0110": {
        "ID": "STDM_0809203_0110",
        "Text": "오래 살고 싶거든 잊지 마라"
      },
      "STDM_0809203_0120": {
        "ID": "STDM_0809203_0120",
        "Text": "아——"
      },
      "STDM_0809203_0130": {
        "ID": "STDM_0809203_0130",
        "Text": "참, 축복이란 뜻의 메구미.\n그러고 보니 그랬었지"
      },
      "STDM_0809203_0140": {
        "ID": "STDM_0809203_0140",
        "Text": "내가 지어준 이름이었어"
      },
      "STDM_0809301_0010": {
        "ID": "STDM_0809301_0010",
        "Text": "모일, 살해된 성장체, 아마나이 리코의 시신은\n후시구로 토우지 본인이 직접\n반성교 본부 별의 아이의 집으로 가져왔다."
      },
      "STDM_0809301_0020": {
        "ID": "STDM_0809301_0020",
        "Text": "반성교 대표 간부 소노다 시게루와\n후시구로 토우지, 중개역 공시우.\n세 명 사이에서 시신이 양도된 것으로 추정."
      },
      "STDM_0809301_0030": {
        "ID": "STDM_0809301_0030",
        "Text": "여어, 오랜만이다"
      },
      "STDM_0809301_0040": {
        "ID": "STDM_0809301_0040",
        "Text": "살아있었나"
      },
      "STDM_0809301_0050": {
        "ID": "STDM_0809301_0050",
        "Text": "그럼, 물론이지. 아주 쌩쌩해"
      },
      "STDM_0809301_0060": {
        "ID": "STDM_0809301_0060",
        "Text": "반전 술식인가?!"
      },
      "STDM_0809301_0070": {
        "ID": "STDM_0809301_0070",
        "Text": "정답!!"
      },
      "STDM_0809301_0080": {
        "ID": "STDM_0809301_0080",
        "Text": "나도 지금까지 성공한 적은 없었어"
      },
      "STDM_0809301_0090": {
        "ID": "STDM_0809301_0090",
        "Text": "그런데 죽기 직전에 캐치했어.\n주력의 핵심을!"
      },
      "STDM_0809301_0100": {
        "ID": "STDM_0809301_0100",
        "Text": "네가 실패한 원인은\n내 목을 절단하지 않은 것과\n머리를 찌를 때\n그 주구를 쓰지 않은 거야"
      },
      "STDM_0809301_0110": {
        "ID": "STDM_0809301_0110",
        "Text": "…실패한 원인이라니?"
      },
      "STDM_0809301_0120": {
        "ID": "STDM_0809301_0120",
        "Text": "승부는 이제부터 시작인데"
      },
      "STDM_0809301_0130": {
        "ID": "STDM_0809301_0130",
        "Text": "아——? 그런가? 그렇구나"
      },
      "STDM_0809301_0140": {
        "ID": "STDM_0809301_0140",
        "Text": "…그럴지도 모르겠네!!"
      },
      "STDM_0809302_0010": {
        "ID": "STDM_0809302_0010",
        "Text": "미안하다. 아마나이"
      },
      "STDM_0809302_0020": {
        "ID": "STDM_0809302_0020",
        "Text": "난 지금\n널 위해 화를 내는 게 아니야.\n나는 아무도 미워하지 않아"
      },
      "STDM_0809302_0030": {
        "ID": "STDM_0809302_0030",
        "Text": "지금은 그저, 한없이 이 세계가 유쾌하다"
      },
      "STDM_0809302_0040": {
        "ID": "STDM_0809302_0040",
        "Text": "천상천하, 유아독존"
      },
      "STDM_0809302_0050": {
        "ID": "STDM_0809302_0050",
        "Text": "순전과 반전,\n각각의 무한을 충돌시킴으로써 생성되고\n가상의 질량을 밀어내는"
      },
      "STDM_0809303_0010": {
        "ID": "STDM_0809303_0010",
        "Text": "위화감"
      },
      "STDM_0809303_0020": {
        "ID": "STDM_0809303_0020",
        "Text": "「무임 노동 따윈 사절이야」\n평소의 나 같으면 그렇게 말하고 내뺐을 거다"
      },
      "STDM_0809303_0030": {
        "ID": "STDM_0809303_0030",
        "Text": "하지만 눈앞에는\n각성한 무하한 주술의 사용자가,\n그것도 아마 현대 최강이 된 주술사가 있다"
      },
      "STDM_0809303_0040": {
        "ID": "STDM_0809303_0040",
        "Text": "부정하고 싶어졌다.\n꺾어보고 싶어졌다"
      },
      "STDM_0809303_0050": {
        "ID": "STDM_0809303_0050",
        "Text": "날 부정한 젠인가와 주술계,\n그들의 정점을"
      },
      "STDM_0809303_0060": {
        "ID": "STDM_0809303_0060",
        "Text": "나 자신을 긍정하기 위해서\n평소의 나를 굽히고 말았다"
      },
      "STDM_0809303_0070": {
        "ID": "STDM_0809303_0070",
        "Text": "그 시점에서 이미 졌던 거야"
      },
      "STDM_0809303_0080": {
        "ID": "STDM_0809303_0080",
        "Text": "자존심은 예전에 버렸잖아"
      },
      "STDM_0809303_0090": {
        "ID": "STDM_0809303_0090",
        "Text": "자신도, 타인도 존중하지 않는\n그런 삶을 택했으면서"
      },
      "STDM_0809303_0100": {
        "ID": "STDM_0809303_0100",
        "Text": "마지막으로 남길 말은 있냐?"
      },
      "STDM_0809303_0110": {
        "ID": "STDM_0809303_0110",
        "Text": "…없어"
      },
      "STDM_0809303_0120": {
        "ID": "STDM_0809303_0120",
        "Text": "한 2, 3년쯤 지나고 나서\n내 자식이 젠인가로 팔려 갈 거다"
      },
      "STDM_0809303_0130": {
        "ID": "STDM_0809303_0130",
        "Text": "그러니 마음대로 해"
      },
      "STDM_0809303_0140": {
        "ID": "STDM_0809303_0140",
        "Text": "그 후, 반성교 시설 내에서\n주술고전 2학년 고죠 사토루가\n성장체 아마나이 리코의 시신을 회수."
      },
      "STDM_0809303_0150": {
        "ID": "STDM_0809303_0150",
        "Text": "얼마 안 있어 주술고전 2학년 게토 스구루도\n그 장소에서 합류했다."
      },
      "STDM_0809303_0160": {
        "ID": "STDM_0809303_0160",
        "Text": "늦었구나, 스구루.\n아니, 빨리 온 편인가?"
      },
      "STDM_0809303_0170": {
        "ID": "STDM_0809303_0170",
        "Text": "……"
      },
      "STDM_0809303_0180": {
        "ID": "STDM_0809303_0180",
        "Text": "사토루… 맞지?"
      },
      "STDM_0809303_0190": {
        "ID": "STDM_0809303_0190",
        "Text": "무슨 일이 있었던 거야…?!"
      },
      "STDM_0809303_0200": {
        "ID": "STDM_0809303_0200",
        "Text": "쇼코를 만났구나"
      },
      "STDM_0809303_0210": {
        "ID": "STDM_0809303_0210",
        "Text": "응. 치료를 받아서\n나는 멀쩡해"
      },
      "STDM_0809303_0220": {
        "ID": "STDM_0809303_0220",
        "Text": "아니. 내가 멀쩡해봤자 소용없지"
      },
      "STDM_0809303_0230": {
        "ID": "STDM_0809303_0230",
        "Text": "내가 실패한 거야.\n너는 잘못한 게 없어"
      },
      "STDM_0809303_0240": {
        "ID": "STDM_0809303_0240",
        "Text": "…돌아가자"
      },
      "STDM_0809303_0250": {
        "ID": "STDM_0809303_0250",
        "Text": "스구루"
      },
      "STDM_0809303_0260": {
        "ID": "STDM_0809303_0260",
        "Text": "이 녀석들, 다 죽일까?"
      },
      "STDM_0809303_0270": {
        "ID": "STDM_0809303_0270",
        "Text": "지금의 나라면\n아마 아무것도 느끼지 못할 거야"
      },
      "STDM_0809303_0280": {
        "ID": "STDM_0809303_0280",
        "Text": "됐어.\n무의미한 짓이야"
      },
      "STDM_0809303_0290": {
        "ID": "STDM_0809303_0290",
        "Text": "의미라"
      },
      "STDM_0809303_0300": {
        "ID": "STDM_0809303_0300",
        "Text": "그게 정말로 필요한가?"
      },
      "STDM_0809303_0310": {
        "ID": "STDM_0809303_0310",
        "Text": "중요한 일이지"
      },
      "STDM_0809303_0320": {
        "ID": "STDM_0809303_0320",
        "Text": "특히 주술사에겐"
      },
      "STDM_0809401_0010": {
        "ID": "STDM_0809401_0010",
        "Text": "그해 여름은 바빴다"
      },
      "STDM_0809401_0020": {
        "ID": "STDM_0809401_0020",
        "Text": "1년 후\n2007년 8월"
      },
      "STDM_0809401_0030": {
        "ID": "STDM_0809401_0030",
        "Text": "아마 작년에 빈번하게 발생한 재해의 영향도 있을 것이다.\n구더기처럼 주령들이 솟아났다"
      },
      "STDM_0809401_0040": {
        "ID": "STDM_0809401_0040",
        "Text": "퇴치하고 거둬들이는 것의 반복"
      },
      "STDM_0809401_0050": {
        "ID": "STDM_0809401_0050",
        "Text": "다른 사람들은 모르는 주령의 맛.\n토사물을 처리한 걸레를 통째로 집어삼키는 듯한 그 맛"
      },
      "STDM_0809401_0060": {
        "ID": "STDM_0809401_0060",
        "Text": "누굴 위해서?"
      },
      "STDM_0809401_0070": {
        "ID": "STDM_0809401_0070",
        "Text": "그날 이후, 나는 자신을 계속 타이르고 있다.\n내가 본 것은 주변에 흔해 빠진\n이미 다 알고 있는 추악함이다"
      },
      "STDM_0809401_0080": {
        "ID": "STDM_0809401_0080",
        "Text": "원숭이 놈들"
      },
      "STDM_0809401_0090": {
        "ID": "STDM_0809401_0090",
        "Text": "자신이 할 수 있는 일에 최선을 다하는 건\n기분이 좋아요"
      },
      "STDM_0809401_0100": {
        "ID": "STDM_0809401_0100",
        "Text": "혹시 그거 아니?\n주술사한테선 주령이 탄생하지 않아"
      },
      "STDM_0809401_0110": {
        "ID": "STDM_0809401_0110",
        "Text": "헉…"
      },
      "STDM_0809401_0120": {
        "ID": "STDM_0809401_0120",
        "Text": "그럼, 비주술사를 몰살하면 되잖아요"
      },
      "STDM_0809401_0130": {
        "ID": "STDM_0809401_0130",
        "Text": "게토, 그것도 가능해"
      },
      "STDM_0809401_0140": {
        "ID": "STDM_0809401_0140",
        "Text": "네…? 저기…"
      },
      "STDM_0809401_0150": {
        "ID": "STDM_0809401_0150",
        "Text": "비주술사를 계속 솎아 내서 생존 전략으로 주술사에 적응하게\n만드는 거야. 진화를 촉진하는 거지. 새들이 날개를 얻었듯이"
      },
      "STDM_0809401_0160": {
        "ID": "STDM_0809401_0160",
        "Text": "하지만 안타깝게도\n나는 그렇게까지 미치진 않았어"
      },
      "STDM_0809401_0170": {
        "ID": "STDM_0809401_0170",
        "Text": "비주술사가 싫으니?\n게토"
      },
      "STDM_0809401_0180": {
        "ID": "STDM_0809401_0180",
        "Text": "비주술사를 멸시하는 너, 그걸 부정하는 너"
      },
      "STDM_0809401_0185": {
        "ID": "STDM_0809401_0185",
        "Text": "어느 쪽을 본심으로 삼느냐는\n앞으로 네가 선택할 일이지"
      },
      "STDM_0809401_0190": {
        "ID": "STDM_0809401_0190",
        "Text": "젠장…!!"
      },
      "STDM_0809401_0200": {
        "ID": "STDM_0809401_0200",
        "Text": "우부스나가미… 그건 토지신이었어요.\n1급 안건이라고요…!!"
      },
      "STDM_0809401_0210": {
        "ID": "STDM_0809401_0210",
        "Text": "주술사라는 마라톤 게임.\n그 끝에 자리한 것이\n동료 주술사들의 시체 더미라면?"
      },
      "STDM_0809401_0220": {
        "ID": "STDM_0809401_0220",
        "Text": "본교 학생의 살상 사건에 대한\n조사 보고서"
      },
      "STDM_0809401_0230": {
        "ID": "STDM_0809401_0230",
        "Text": "이건 뭐죠?"
      },
      "STDM_0809401_0240": {
        "ID": "STDM_0809401_0240",
        "Text": "뭐긴요?\n저 둘이 이 일련의 사건의 원인이잖아요?"
      },
      "STDM_0809401_0250": {
        "ID": "STDM_0809401_0250",
        "Text": "아닌데요"
      },
      "STDM_0809401_0260": {
        "ID": "STDM_0809401_0260",
        "Text": "조사 대상 학생: 도쿄고 3학년 게토 스구루"
      },
      "STDM_0809401_0270": {
        "ID": "STDM_0809401_0270",
        "Text": "여러분, 일단 밖으로 나오실까요?"
      },
      "STDM_0809401_0280": {
        "ID": "STDM_0809401_0280",
        "Text": "게토 스구루는 현재 도주 중."
      },
      "STDM_0809401_0283": {
        "ID": "STDM_0809401_0283",
        "Text": "주술 규정 9조에 따라\n주저사로서 처형 대상이 됨."
      },
      "STDM_0809401_0290": {
        "ID": "STDM_0809401_0290",
        "Text": "설명해, 스구루"
      },
      "STDM_0809401_0300": {
        "ID": "STDM_0809401_0300",
        "Text": "비주술사를 죽여서 주술사만의 세상을 만들겠다고?!\n그딴 건 당연히 무리야!!"
      },
      "STDM_0809401_0310": {
        "ID": "STDM_0809401_0310",
        "Text": "오만하네.\n너라면 할 수 있잖아, 사토루"
      },
      "STDM_0809401_0320": {
        "ID": "STDM_0809401_0320",
        "Text": "본인은 할 수 있는 걸 타인에겐\n『불가능하다』고 훈계하는 거야?"
      },
      "STDM_0809401_0330": {
        "ID": "STDM_0809401_0330",
        "Text": "넌 고죠 사토루라서 최강인가?\n최강이라서 고죠 사토루인가?"
      },
      "STDM_0809401_0340": {
        "ID": "STDM_0809401_0340",
        "Text": "하고 싶은 말이 뭐야?"
      },
      "STDM_0809401_0350": {
        "ID": "STDM_0809401_0350",
        "Text": "어떻게 살지는 정했다.\n이제 내가 할 수 있는 걸 최선을 다해서 할 거야"
      },
      "STDM_0809401_0360": {
        "ID": "STDM_0809401_0360",
        "Text": "선생님, 나는 강하죠?"
      },
      "STDM_0809401_0370": {
        "ID": "STDM_0809401_0370",
        "Text": "그래. 건방진 소리지만, 사실이다"
      },
      "STDM_0809401_0380": {
        "ID": "STDM_0809401_0380",
        "Text": "그런데 나 혼자만 강해도 소용없는 건가 봐요.\n내가 구할 수 있는 건\n구원받을 준비가 된 녀석뿐이에요"
      },
      "STDM_0809401_0390": {
        "ID": "STDM_0809401_0390",
        "Text": "후시구로 메구미지?"
      },
      "STDM_0809401_0400": {
        "ID": "STDM_0809401_0400",
        "Text": "킥킥… 오케이"
      },
      "STDM_0809401_0405": {
        "ID": "STDM_0809401_0405",
        "Text": "뒷일은 나한테 맡기렴"
      },
      "STDM_0809401_0410": {
        "ID": "STDM_0809401_0410",
        "Text": "……"
      },
      "STDM_0809401_0420": {
        "ID": "STDM_0809401_0420",
        "Text": "강해져야 한다.\n나한테 뒤처지지 않을 만큼 말이야"
      },
      "STDM_0809401_0430": {
        "ID": "STDM_0809401_0430",
        "Text": "2018년 10월 19일"
      },
      "STDM_0809401_0440": {
        "ID": "STDM_0809401_0440",
        "Text": "고죠 선생님"
      },
      "STDM_0809401_0450": {
        "ID": "STDM_0809401_0450",
        "Text": "선생님도 잠을 자는구나"
      },
      "STDM_0809401_0460": {
        "ID": "STDM_0809401_0460",
        "Text": "당연하지, 넌 무슨 소리를 하는 거니?"
      },
      "STDM_0809401_0470": {
        "ID": "STDM_0809401_0470",
        "Text": "고죠 선생님!!"
      },
      "STDM_0809401_0480": {
        "ID": "STDM_0809401_0480",
        "Text": "아, 일어났다"
      },
      "STDM_0809401_0490": {
        "ID": "STDM_0809401_0490",
        "Text": "잠깐, 그 의자는 비싼 거잖아요"
      },
