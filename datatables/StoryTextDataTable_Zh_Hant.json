[
  {
    "Type": "DataTable",
    "Name": "StoryTextDataTable_Zh_Hant",
    "Flags": "RF_Public | RF_Standalone | RF_Transactional | RF_WasLoaded | RF_LoadCompleted",
    "Class": "UScriptClass'DataTable'",
    "Properties": {
      "RowStruct": {
        "ObjectName": "Class'GameDataTableRow_GameText'",
        "ObjectPath": "/Script/Abrams"
      },
      "ImportKeyField": "Id"
    },
    "Rows": {
      "CHAP_0001": {
        "ID": "CHAP_0001",
        "Text": "咒胎戴天 前篇"
      },
      "CHAP_0002": {
        "ID": "CHAP_0002",
        "Text": "咒胎戴天 後篇"
      },
      "CHAP_0003": {
        "ID": "CHAP_0003",
        "Text": "幼魚與逆罰"
      },
      "CHAP_0004": {
        "ID": "CHAP_0004",
        "Text": "京都姊妹校交流會"
      },
      "CHAP_0005": {
        "ID": "CHAP_0005",
        "Text": "起首雷同"
      },
      "CHAP_0006": {
        "ID": "CHAP_0006",
        "Text": "咒術迴戰0"
      },
      "CHAP_0007": {
        "ID": "CHAP_0007",
        "Text": "EX戰"
      },
      "CHAP_0008": {
        "ID": "CHAP_0008",
        "Text": "懷玉・玉折"
      },
      "CHAP_0009": {
        "ID": "CHAP_0009",
        "Text": "澀谷事變"
      },
      "STMSN_01000M": {
        "ID": "STMSN_01000M",
        "Text": "「最強」的傳授"
      },
      "STMSN_01000M_EXPLANATION": {
        "ID": "STMSN_01000M_EXPLANATION",
        "Text": "認知到自己的弱點\n少年決心要變強……\n追尋「正確的死亡」"
      },
      "STMSN_01001M": {
        "ID": "STMSN_01001M",
        "Text": "兩面宿儺"
      },
      "STMSN_01001M_EXPLANATION": {
        "ID": "STMSN_01001M_EXPLANATION",
        "Text": "封印被解開的兇惡咒物招來詛咒\n「只要我有咒力就可以了吧！」\n虎杖為了能迎戰詛咒而……"
      },
      "STMSN_01002M": {
        "ID": "STMSN_01002M",
        "Text": "秘密死刑"
      },
      "STMSN_01002M_EXPLANATION": {
        "ID": "STMSN_01002M_EXPLANATION",
        "Text": "特級咒術師「五條悟」確認宿儺寄宿體內\n便要求虎杖放出宿儺……\n最強對上最恐怖的戰鬥即將開始！"
      },
      "STMSN_01003M": {
        "ID": "STMSN_01003M",
        "Text": "遺言"
      },
      "STMSN_01003M_EXPLANATION": {
        "ID": "STMSN_01003M_EXPLANATION",
        "Text": "是要現在就死\n還是吃下宿儺所有的手指再死\n虎杖想著祖父的遺言，做出決定……"
      },
      "STMSN_01004M": {
        "ID": "STMSN_01004M",
        "Text": "為了自己"
      },
      "STMSN_01004M_EXPLANATION": {
        "ID": "STMSN_01004M_EXPLANATION",
        "Text": "被問到來高專的理由，虎杖細細思索\n祖父的遺言……只有自己辦得到的事情……\n最終他得出的結論是……！！"
      },
      "STMSN_01005M": {
        "ID": "STMSN_01005M",
        "Text": "鐵娘子"
      },
      "STMSN_01005M_EXPLANATION": {
        "ID": "STMSN_01005M_EXPLANATION",
        "Text": "釘崎與虎杖接受祓除咒靈的考試！\n領隊的五條其實有所意圖……"
      },
      "STMSN_01006M": {
        "ID": "STMSN_01006M",
        "Text": "開始"
      },
      "STMSN_01006M_EXPLANATION": {
        "ID": "STMSN_01006M_EXPLANATION",
        "Text": "咒靈抓小孩當人質\n釘崎被迫陷入攸關人命的取捨\n糾結到最後，她的選擇是……"
      },
      "STMSN_01007M": {
        "ID": "STMSN_01007M",
        "Text": "咒胎戴天"
      },
      "STMSN_01007M_EXPLANATION": {
        "ID": "STMSN_01007M_EXPLANATION",
        "Text": "少年院內發現咒胎\n從伊地知口中聽聞現況的虎杖等人\n趕赴救助倖存者但院內卻早已……"
      },
      "STMSN_01008M": {
        "ID": "STMSN_01008M",
        "Text": "逃出"
      },
      "STMSN_01008M_EXPLANATION": {
        "ID": "STMSN_01008M_EXPLANATION",
        "Text": "不慎落單於陌生環境的釘崎\n感受到附近出現異常的氣息……\n「怎麼會……這麼多！！」"
      },
      "STMSN_01009M": {
        "ID": "STMSN_01009M",
        "Text": "詛咒之王"
      },
      "STMSN_01009M_EXPLANATION": {
        "ID": "STMSN_01009M_EXPLANATION",
        "Text": "生死關頭之際虎杖收到伏黑的暗號\n本應是宿儺對抗特級咒靈的作戰，然而……\n「走，去宰了那些小鬼頭。」"
      },
      "STMSN_01010M": {
        "ID": "STMSN_01010M",
        "Text": "理由"
      },
      "STMSN_01010M_EXPLANATION": {
        "ID": "STMSN_01010M_EXPLANATION",
        "Text": "在外圍等待虎杖的伏黑只等來了宿儺\n「我想到了現在能做什麼……」\n暫時奪下身體主導權的宿儺打算……"
      },
      "STMSN_02011M": {
        "ID": "STMSN_02011M",
        "Text": "雨後"
      },
      "STMSN_02011M_EXPLANATION": {
        "ID": "STMSN_02011M_EXPLANATION",
        "Text": "伏黑向釘崎轉達了虎杖的遺言\n「自己死了就沒意義了啊……」\n此時一道身影接近正感傷虎杖之死的兩人……"
      },
      "STMSN_02012M": {
        "ID": "STMSN_02012M",
        "Text": "企圖"
      },
      "STMSN_02012M_EXPLANATION": {
        "ID": "STMSN_02012M_EXPLANATION",
        "Text": "漏瑚問起戰勝咒術師的方法\n夏油回道……\n「只要滿足2個條件就能贏喔。」"
      },
      "STMSN_02013M": {
        "ID": "STMSN_02013M",
        "Text": "束縛"
      },
      "STMSN_02013M_EXPLANATION": {
        "ID": "STMSN_02013M_EXPLANATION",
        "Text": "本該死去的虎杖和宿儺大眼瞪小眼\n「我們還沒死呢」\n宿儺向他提出復活的條件，可是……"
      },
      "STMSN_02014M": {
        "ID": "STMSN_02014M",
        "Text": "某個夢想"
      },
      "STMSN_02014M_EXPLANATION": {
        "ID": "STMSN_02014M_EXPLANATION",
        "Text": "五條告訴伊地知自己的夢想……沒想到\n「五五五五五條先生！！」\n伊地知究竟目擊到什麼！？"
      },
      "STMSN_02015M": {
        "ID": "STMSN_02015M",
        "Text": "電影鑑賞"
      },
      "STMSN_02015M_EXPLANATION": {
        "ID": "STMSN_02015M_EXPLANATION",
        "Text": "認知到自己弱點的虎杖\n接受五條提出的咒力控制修行\n「我想變強，快教我怎樣成為『最強』」"
      },
      "STMSN_02016M": {
        "ID": "STMSN_02016M",
        "Text": "邁進"
      },
      "STMSN_02016M_EXPLANATION": {
        "ID": "STMSN_02016M_EXPLANATION",
        "Text": "釘崎被貓熊狠狠拋到天上……\n「唔……再來！！」\n大家朝交流會更進一步！"
      },
      "STMSN_02017M": {
        "ID": "STMSN_02017M",
        "Text": "邁進－貳－"
      },
      "STMSN_02017M_EXPLANATION": {
        "ID": "STMSN_02017M_EXPLANATION",
        "Text": "伏黑思索著咒具的使用及攜帶方式\n「你那個時候為什麼逃走了」\n他想起當初宿儺的質問，有了靈感……"
      },
      "STMSN_02018S": {
        "ID": "STMSN_02018S",
        "Text": "邁進－參－"
      },
      "STMSN_02018S_EXPLANATION": {
        "ID": "STMSN_02018S_EXPLANATION",
        "Text": "不是什麼時候都能一對一戰鬥……\n在少年院吃到苦頭的釘崎\n找真希、狗卷一起進行特訓！"
      },
      "STMSN_02019S": {
        "ID": "STMSN_02019S",
        "Text": "邁進－肆－"
      },
      "STMSN_02019S_EXPLANATION": {
        "ID": "STMSN_02019S_EXPLANATION",
        "Text": "迎戰龐大的敵人……\n曾因巨形咒靈而身負重傷的伏黑\n與貓熊開始特訓！"
      },
      "STMSN_02020S": {
        "ID": "STMSN_02020S",
        "Text": "邁進－伍－"
      },
      "STMSN_02020S_EXPLANATION": {
        "ID": "STMSN_02020S_EXPLANATION",
        "Text": "五條出現在特訓後疲憊不堪\n正在休息的伏黑、釘崎的面前\n笑著要求他們……"
      },
      "STMSN_02021M": {
        "ID": "STMSN_02021M",
        "Text": "急襲"
      },
      "STMSN_02021M_EXPLANATION": {
        "ID": "STMSN_02021M_EXPLANATION",
        "Text": "移動中的五條突然遭遇奇襲！\n「你是什麼人？」\n來襲者到底有何目的……"
      },
      "STMSN_02022M": {
        "ID": "STMSN_02022M",
        "Text": "領域"
      },
      "STMSN_02022M_EXPLANATION": {
        "ID": "STMSN_02022M_EXPLANATION",
        "Text": "具現化生得領域「領域展開」\n被視為咒術戰最高形式的戰鬥即將開始……"
      },
      "STMSN_02023M": {
        "ID": "STMSN_02023M",
        "Text": "像個詛咒"
      },
      "STMSN_02023M_EXPLANATION": {
        "ID": "STMSN_02023M_EXPLANATION",
        "Text": "夏油對著受花御幫助而順利逃生的漏瑚\n仔細說明戰勝五條作戰計畫\n此時又一全新咒靈現身……"
      },
      "STMSN_02024M": {
        "ID": "STMSN_02024M",
        "Text": "咒力"
      },
      "STMSN_02024M_EXPLANATION": {
        "ID": "STMSN_02024M_EXPLANATION",
        "Text": "濫用咒術的「咒詛師」\n五條傳授虎杖該如何應對這群人的同時\n也察覺到虎杖某個習慣……"
      },
      "STMSN_02025M": {
        "ID": "STMSN_02025M",
        "Text": "跑腿"
      },
      "STMSN_02025M_EXPLANATION": {
        "ID": "STMSN_02025M_EXPLANATION",
        "Text": "在特訓中附加處罰的真希、伏黑和釘崎\n他們尚未得知有一群人\n正悄悄來訪高專……"
      },
      "STMSN_02026M": {
        "ID": "STMSN_02026M",
        "Text": "無聊"
      },
      "STMSN_02026M_EXPLANATION": {
        "ID": "STMSN_02026M_EXPLANATION",
        "Text": "特地來評鑑伏黑和釘崎的東堂問道\n「你喜歡什麼類型的女人」\n伏黑勉為其難地回答……可是！"
      },
      "STMSN_02027S": {
        "ID": "STMSN_02027S",
        "Text": "激勵"
      },
      "STMSN_02027S_EXPLANATION": {
        "ID": "STMSN_02027S_EXPLANATION",
        "Text": "被真依教訓一頓的釘崎迫切地想提升實力！\n「最後能相信的果然還是自己的肉體……」\n釘崎找來狗卷和貓熊……"
      },
      "STMSN_02028M": {
        "ID": "STMSN_02028M",
        "Text": "忠告"
      },
      "STMSN_02028M_EXPLANATION": {
        "ID": "STMSN_02028M_EXPLANATION",
        "Text": "保守派領袖樂巖寺與五條會面\n開始談判虎杖的事情\n以及今後咒術界的發展……"
      },
      "STMSN_03029M": {
        "ID": "STMSN_03029M",
        "Text": "幼魚與逆罰"
      },
      "STMSN_03029M_EXPLANATION": {
        "ID": "STMSN_03029M_EXPLANATION",
        "Text": "電影院內發現3名高中生的畸形屍體\n與被害者有「牽連」的少年\n與作案咒靈接觸……"
      },
      "STMSN_03030M": {
        "ID": "STMSN_03030M",
        "Text": "離職咒術師"
      },
      "STMSN_03030M_EXPLANATION": {
        "ID": "STMSN_03030M_EXPLANATION",
        "Text": "虎杖與領隊的七海一同\n調查畸形死亡案件\n兩人一路追蹤案發現場的殘穢……"
      },
      "STMSN_03031M": {
        "ID": "STMSN_03031M",
        "Text": "逕庭拳"
      },
      "STMSN_03031M_EXPLANATION": {
        "ID": "STMSN_03031M_EXPLANATION",
        "Text": "虎杖施展出在五條特訓下學會的新招式\n另一方面，七海也有所發現……"
      },
      "STMSN_03032M": {
        "ID": "STMSN_03032M",
        "Text": "靈魂的形狀"
      },
      "STMSN_03032M_EXPLANATION": {
        "ID": "STMSN_03032M_EXPLANATION",
        "Text": "順利鎖定真人的潛伏地點\n七海獨自前往處理\n沒想到現場卻出現大量的……"
      },
      "STMSN_03033M": {
        "ID": "STMSN_03033M",
        "Text": "調查"
      },
      "STMSN_03033M_EXPLANATION": {
        "ID": "STMSN_03033M_EXPLANATION",
        "Text": "與前來調查的虎杖聊過後吉野思索著\n虎杖的言詞……自己對媽媽的感情……\n但背地裡真人與同夥也伸出魔掌……"
      },
      "STMSN_03034M": {
        "ID": "STMSN_03034M",
        "Text": "加班時間"
      },
      "STMSN_03034M_EXPLANATION": {
        "ID": "STMSN_03034M_EXPLANATION",
        "Text": "原本一昧防禦真人猛烈攻勢的七海\n終於解除對自己的限制\n開始全力反擊！"
      },
      "STMSN_03035M": {
        "ID": "STMSN_03035M",
        "Text": "給將來的你"
      },
      "STMSN_03035M_EXPLANATION": {
        "ID": "STMSN_03035M_EXPLANATION",
        "Text": "母親被咒殺的吉野\n為了找出犯人襲擊里櫻高中\n虎杖雖然出面想收拾善後……"
      },
      "STMSN_03036M": {
        "ID": "STMSN_03036M",
        "Text": "天敵"
      },
      "STMSN_03036M_EXPLANATION": {
        "ID": "STMSN_03036M_EXPLANATION",
        "Text": "七海趕到陷入困境的虎杖身邊\n並察覺到真人狀態不太對勁\n於是兩人開始猛烈反擊！"
      },
      "STMSN_03037M": {
        "ID": "STMSN_03037M",
        "Text": "成長"
      },
      "STMSN_03037M_EXPLANATION": {
        "ID": "STMSN_03037M_EXPLANATION",
        "Text": "面對改造人不停防守的虎杖\n「殺……了我……」\n聽見對方開口求死……"
      },
      "STMSN_03038M": {
        "ID": "STMSN_03038M",
        "Text": "明天見"
      },
      "STMSN_03038M_EXPLANATION": {
        "ID": "STMSN_03038M_EXPLANATION",
        "Text": "在七海危急時虎杖及時趕到\n兩人打算速戰速決再次展開猛烈攻勢\n不料真人卻還有「殺手鐧」……"
      },
      "STMSN_03039M": {
        "ID": "STMSN_03039M",
        "Text": "反省"
      },
      "STMSN_03039M_EXPLANATION": {
        "ID": "STMSN_03039M_EXPLANATION",
        "Text": "敗逃的真人反省這次的失誤\n與夏油討論起今後的作戰計畫……"
      },
      "STMSN_03040S": {
        "ID": "STMSN_03040S",
        "Text": "姊妹淘聚會"
      },
      "STMSN_03040S_EXPLANATION": {
        "ID": "STMSN_03040S_EXPLANATION",
        "Text": "某次休假\n不知為何心情很差的釘崎來找真希\n一切原因要追溯到她出門逛街的時候……"
      },
      "STMSN_03041S": {
        "ID": "STMSN_03041S",
        "Text": "前輩與晚輩"
      },
      "STMSN_03041S_EXPLANATION": {
        "ID": "STMSN_03041S_EXPLANATION",
        "Text": "「回去以後好好休息吧」\n七海順利在時間內完成任務\n不料五條卻找上門有事相求"
      },
      "STMSN_03042S": {
        "ID": "STMSN_03042S",
        "Text": "貓熊與貓熊"
      },
      "STMSN_03042S_EXPLANATION": {
        "ID": "STMSN_03042S_EXPLANATION",
        "Text": "某次休假\n伏黑、狗卷和貓熊本來打算一起\n「去買新出的貓熊週邊！」可是……"
      },
      "STMSN_03043S": {
        "ID": "STMSN_03043S",
        "Text": "前輩與晚輩－貳－"
      },
      "STMSN_03043S_EXPLANATION": {
        "ID": "STMSN_03043S_EXPLANATION",
        "Text": "「哎呀正好遇到你們～」\n被七海婉拒「懇求」的五條\n來到正在特訓的釘崎、真希面前……"
      },
      "STMSN_04044M": {
        "ID": "STMSN_04044M",
        "Text": "驚喜"
      },
      "STMSN_04044M_EXPLANATION": {
        "ID": "STMSN_04044M_EXPLANATION",
        "Text": "時間來到京都姊妹校交流會開辦當天！\n這天也是告訴大家虎杖活著的日子。\n究竟大家會有什麼反應呢……"
      },
      "STMSN_04045M": {
        "ID": "STMSN_04045M",
        "Text": "作戰會議"
      },
      "STMSN_04045M_EXPLANATION": {
        "ID": "STMSN_04045M_EXPLANATION",
        "Text": "被眾人以為犧牲的虎杖變成額外戰力……\n真希正困擾該如何安排他，\n卻因為伏黑的一句話改變想法……"
      },
      "STMSN_04046M": {
        "ID": "STMSN_04046M",
        "Text": "京都姊妹校交流會"
      },
      "STMSN_04046M_EXPLANATION": {
        "ID": "STMSN_04046M_EXPLANATION",
        "Text": "京都姊妹校交流會第一天\n交雜無數盤算的團體戰即將開始……"
      },
      "STMSN_04047M": {
        "ID": "STMSN_04047M",
        "Text": "鑑定"
      },
      "STMSN_04047M_EXPLANATION": {
        "ID": "STMSN_04047M_EXPLANATION",
        "Text": "獨自打前鋒的傢伙\n現身於依照作戰計畫採取行動的\n東京校陣營！"
      },
      "STMSN_04048M": {
        "ID": "STMSN_04048M",
        "Text": "壞習慣"
      },
      "STMSN_04048M_EXPLANATION": {
        "ID": "STMSN_04048M_EXPLANATION",
        "Text": "虎杖在戰鬥中持續成長！\n但東堂卻發現一件事……\n「那就是你的壞習慣吧？」"
      },
      "STMSN_04049M": {
        "ID": "STMSN_04049M",
        "Text": "入侵"
      },
      "STMSN_04049M_EXPLANATION": {
        "ID": "STMSN_04049M_EXPLANATION",
        "Text": "各處陸續開始對決的時候\n獨自行動的狗卷面前\n卻出現不詳的氣息……"
      },
      "STMSN_04050M": {
        "ID": "STMSN_04050M",
        "Text": "賢者"
      },
      "STMSN_04050M_EXPLANATION": {
        "ID": "STMSN_04050M_EXPLANATION",
        "Text": "誕生於人類對森林的敬畏\n遠遠超出一般程度的特級\n伏黑等人試圖避免正面對決卻……"
      },
      "STMSN_04051M": {
        "ID": "STMSN_04051M",
        "Text": "咒具"
      },
      "STMSN_04051M_EXPLANATION": {
        "ID": "STMSN_04051M_EXPLANATION",
        "Text": "伏黑等人在花御的猛烈攻擊下硬撐\n但也已經快到極限了……"
      },
      "STMSN_04052M": {
        "ID": "STMSN_04052M",
        "Text": "黑閃"
      },
      "STMSN_04052M_EXPLANATION": {
        "ID": "STMSN_04052M_EXPLANATION",
        "Text": "「黑閃」\n咒力核心激發的黑色光芒……\n虎杖即將脫胎換骨……"
      },
      "STMSN_04053M": {
        "ID": "STMSN_04053M",
        "Text": "放不開"
      },
      "STMSN_04053M_EXPLANATION": {
        "ID": "STMSN_04053M_EXPLANATION",
        "Text": "虎杖學會黑閃後明顯成長\n聯手東堂開始猛攻！！\n「好了，開始料理吧」"
      },
      "STMSN_04054M": {
        "ID": "STMSN_04054M",
        "Text": "超乎常理"
      },
      "STMSN_04054M_EXPLANATION": {
        "ID": "STMSN_04054M_EXPLANATION",
        "Text": "東堂終於解放自己的術式！\nIQ53萬（自稱）所得出的結論會是……"
      },
      "STMSN_04055M": {
        "ID": "STMSN_04055M",
        "Text": "咒術甲子園"
      },
      "STMSN_04055M_EXPLANATION": {
        "ID": "STMSN_04055M_EXPLANATION",
        "Text": "交流會重新開始\n第2輪戰鬥是……棒球！？\n咒術甲子園，開打！"
      },
      "STMSN_04056S": {
        "ID": "STMSN_04056S",
        "Text": "聯合實習課程"
      },
      "STMSN_04056S_EXPLANATION": {
        "ID": "STMSN_04056S_EXPLANATION",
        "Text": "（五條一時興起的）1年級和2年級\n聯合實習課程開始！\n高專逐漸恢復日常生活……"
      },
      "STMSN_04057S": {
        "ID": "STMSN_04057S",
        "Text": "開花"
      },
      "STMSN_04057S_EXPLANATION": {
        "ID": "STMSN_04057S_EXPLANATION",
        "Text": "成功執行作戰卻也身受重傷的花御\n了解到戰鬥的愉悅，進一步成長……\n「花御也越來越像個詛咒了」"
      },
      "STMSN_04058S": {
        "ID": "STMSN_04058S",
        "Text": "聯合實習課程－貳－"
      },
      "STMSN_04058S_EXPLANATION": {
        "ID": "STMSN_04058S_EXPLANATION",
        "Text": "聯合實習戰第2回合\n不知為何冒出京都校的東堂！\n欠了東堂一次「人情」的伏黑會……"
      },
      "STMSN_05059M": {
        "ID": "STMSN_05059M",
        "Text": "起首雷同"
      },
      "STMSN_05059M_EXPLANATION": {
        "ID": "STMSN_05059M_EXPLANATION",
        "Text": "發生非咒術師被咒殺的案件\n虎杖等人出馬調查之下\n卻陸續挖掘出衝擊事實……"
      },
      "STMSN_05060M": {
        "ID": "STMSN_05060M",
        "Text": "案外案"
      },
      "STMSN_05060M_EXPLANATION": {
        "ID": "STMSN_05060M_EXPLANATION",
        "Text": "闖進領域的虎杖等人迎戰咒靈\n但入侵者卻不只他們三個……"
      },
      "STMSN_05061M": {
        "ID": "STMSN_05061M",
        "Text": "任務在身"
      },
      "STMSN_05061M_EXPLANATION": {
        "ID": "STMSN_05061M_EXPLANATION",
        "Text": "釘崎突然被拉出領域\n眼前這個新的敵人身分與目的為何？\n而咒殺事件的真相又是……"
      },
      "STMSN_05062M": {
        "ID": "STMSN_05062M",
        "Text": "共振"
      },
      "STMSN_05062M_EXPLANATION": {
        "ID": "STMSN_05062M_EXPLANATION",
        "Text": "伏黑成功拔除眼前的咒靈\n領域卻沒關閉，反而和「某個事件」一樣\n喚醒了某個傢伙……"
      },
      "STMSN_05063M": {
        "ID": "STMSN_05063M",
        "Text": "突破極限"
      },
      "STMSN_05063M_EXPLANATION": {
        "ID": "STMSN_05063M_EXPLANATION",
        "Text": "覺醒的伏黑正打算使用「殺手鐧」\n但腦中卻晃過「簡直是暴殄天物」\n宿儺的這句話，讓他停下動作"
      },
      "STMSN_05064M": {
        "ID": "STMSN_05064M",
        "Text": "兄弟"
      },
      "STMSN_05064M_EXPLANATION": {
        "ID": "STMSN_05064M_EXPLANATION",
        "Text": "壞相感應到手指氣息\n決定避開戰鬥優先回收手指\n然而「背後」冒出虎杖的那刻他瞬間變臉——"
      },
      "STMSN_05065M": {
        "ID": "STMSN_05065M",
        "Text": "共犯"
      },
      "STMSN_05065M_EXPLANATION": {
        "ID": "STMSN_05065M_EXPLANATION",
        "Text": "「只要中了就贏的術式，你們很強啊」\n虎杖與釘崎被壞相兄弟檔逼入絕境\n究竟兩人能否順利逆轉戰況呢……"
      },
      "STMSN_05066M": {
        "ID": "STMSN_05066M",
        "Text": "推薦"
      },
      "STMSN_05066M_EXPLANATION": {
        "ID": "STMSN_05066M_EXPLANATION",
        "Text": "足以引領咒術界的崇高地位「1級」\n連同虎杖在內，東京校有5名學生獲得推薦……"
      },
      "STMSN_05067S": {
        "ID": "STMSN_05067S",
        "Text": "中場休假"
      },
      "STMSN_05067S_EXPLANATION": {
        "ID": "STMSN_05067S_EXPLANATION",
        "Text": "某天假日，\n釘崎和真希一起去五條推薦的店\n但果然能被五條推薦的都不單純……"
      },
      "STMSN_05068S": {
        "ID": "STMSN_05068S",
        "Text": "出老千"
      },
      "STMSN_05068S_EXPLANATION": {
        "ID": "STMSN_05068S_EXPLANATION",
        "Text": "真人打撲克牌每把都贏\n不敢置信的漏瑚和花御懷疑他出老千！\n真人矢口否認，但實際上……"
      },
      "STMSN_05069S": {
        "ID": "STMSN_05069S",
        "Text": "中場考試"
      },
      "STMSN_05069S_EXPLANATION": {
        "ID": "STMSN_05069S_EXPLANATION",
        "Text": "聽見八十八橋的事情後\n狗卷和貓熊想確認伏黑的進步而約戰！\n「讓我看看你變得多強。」"
      },
      "STMSN_05070S": {
        "ID": "STMSN_05070S",
        "Text": "中場任務"
      },
      "STMSN_05070S_EXPLANATION": {
        "ID": "STMSN_05070S_EXPLANATION",
        "Text": "虎杖和五條擅自加入七海的任務\n但不太像平常的一時興起\n五條似乎有什麼打算……"
      },
      "STMSN_06071M": {
        "ID": "STMSN_06071M",
        "Text": "詛咒之子"
      },
      "STMSN_06071M_EXPLANATION": {
        "ID": "STMSN_06071M_EXPLANATION",
        "Text": "苦於詛咒希望自己能死去的少年……\n為了當好一個咒術師、當好一個人類\n轉入高專學習詛咒，與詛咒對抗"
      },
      "STMSN_06072M": {
        "ID": "STMSN_06072M",
        "Text": "詛咒的女王"
      },
      "STMSN_06072M_EXPLANATION": {
        "ID": "STMSN_06072M_EXPLANATION",
        "Text": "真希問起乙骨來高專的理由\n少年回答了自己的願望……"
      },
      "STMSN_06073S": {
        "ID": "STMSN_06073S",
        "Text": "擔心"
      },
      "STMSN_06073S_EXPLANATION": {
        "ID": "STMSN_06073S_EXPLANATION",
        "Text": "狗卷、貓熊也一起組隊參加實習！\n「棘，你很在意轉學生嗎？」\n狗卷會關注乙骨的原因是……"
      },
      "STMSN_06074M": {
        "ID": "STMSN_06074M",
        "Text": "解咒"
      },
      "STMSN_06074M_EXPLANATION": {
        "ID": "STMSN_06074M_EXPLANATION",
        "Text": "經歷這次實習，乙骨決定要幫里香解咒\n「用這個吧」\n五條親手交給他用來解咒的是……"
      },
      "STMSN_06075M": {
        "ID": "STMSN_06075M",
        "Text": "鍛鍊"
      },
      "STMSN_06075M_EXPLANATION": {
        "ID": "STMSN_06075M_EXPLANATION",
        "Text": "乙骨為了解咒而努力學習刀法\n接受五條特訓後一切就能結束……才怪！\n被找來進行力量特訓的人是……"
      },
      "STMSN_06076S": {
        "ID": "STMSN_06076S",
        "Text": "共鬥實習"
      },
      "STMSN_06076S_EXPLANATION": {
        "ID": "STMSN_06076S_EXPLANATION",
        "Text": "紀念真希的傷治好\n舉辦組隊參加的對戰大賽！\n令人在意的配對結果是……"
      },
      "STMSN_06077M": {
        "ID": "STMSN_06077M",
        "Text": "處罰與否"
      },
      "STMSN_06077M_EXPLANATION": {
        "ID": "STMSN_06077M_EXPLANATION",
        "Text": "時間來到夏季\n透過上課和特訓\n乙骨與真希等人的距離逐漸拉近"
      },
      "STMSN_06078M": {
        "ID": "STMSN_06078M",
        "Text": "黑之又黑"
      },
      "STMSN_06078M_EXPLANATION": {
        "ID": "STMSN_06078M_EXPLANATION",
        "Text": "這次狗卷出任務時會帶上乙骨……\n但面對無法言語溝通的狗卷，\n乙骨覺得他有些可怕……"
      },
      "STMSN_06079S": {
        "ID": "STMSN_06079S",
        "Text": "共鬥實習－貳－"
      },
      "STMSN_06079S_EXPLANATION": {
        "ID": "STMSN_06079S_EXPLANATION",
        "Text": "經歷商店街事件後拉近距離的狗卷與乙骨\n兩人要組隊挑戰二度舉辦的共鬥實習！"
      },
      "STMSN_06080M": {
        "ID": "STMSN_06080M",
        "Text": "處罰弱者"
      },
      "STMSN_06080M_EXPLANATION": {
        "ID": "STMSN_06080M_EXPLANATION",
        "Text": "咒詛師，用詛咒報復人世間的群體……\n當中被認為最惡劣的夏油現身高專\n他高調對所有人宣告自己的「計畫」……"
      },
      "STMSN_06081M": {
        "ID": "STMSN_06081M",
        "Text": "舊識"
      },
      "STMSN_06081M_EXPLANATION": {
        "ID": "STMSN_06081M_EXPLANATION",
        "Text": "五條回憶著不夠成熟的學生時代\n與夏油一起渡過的每一天……\n以及兩人訣別的時刻……"
      },
      "STMSN_06082M": {
        "ID": "STMSN_06082M",
        "Text": "堅強率直"
      },
      "STMSN_06082M_EXPLANATION": {
        "ID": "STMSN_06082M_EXPLANATION",
        "Text": "真希對思索著夏油那些言論的乙骨\n說起自己的家庭背景\n同時敵人的魔掌也伸向他們……"
      },
      "STMSN_06083M": {
        "ID": "STMSN_06083M",
        "Text": "死守"
      },
      "STMSN_06083M_EXPLANATION": {
        "ID": "STMSN_06083M_EXPLANATION",
        "Text": "五條對夏油不在前線這件事感到突兀\n緊急將狗卷和貓熊「傳」回高專\n「你們要保護那兩人。抱歉，是死守住那兩人！！」  "
      },
      "STMSN_06084M": {
        "ID": "STMSN_06084M",
        "Text": "完全顯現"
      },
      "STMSN_06084M_EXPLANATION": {
        "ID": "STMSN_06084M_EXPLANATION",
        "Text": "乙骨目睹真希等人慘烈的模樣……\n「我要殺了你！」\n迎戰最惡劣的咒詛師"
      },
      "STMSN_06085M": {
        "ID": "STMSN_06085M",
        "Text": "耀眼的黑暗"
      },
      "STMSN_06085M_EXPLANATION": {
        "ID": "STMSN_06085M_EXPLANATION",
        "Text": "賭上自身存在意義戰鬥的人\n為大義拿起武器的人\n兩人之間的決戰即將開始……"
      },
      "STMSN_06086M": {
        "ID": "STMSN_06086M",
        "Text": "謝謝"
      },
      "STMSN_06086M_EXPLANATION": {
        "ID": "STMSN_06086M_EXPLANATION",
        "Text": "乙骨睜開眼就看見滿臉擔心盯著他的真希等人\n還有里香的身影\n對於獻祭自己的乙骨，里香她……"
      },
      "STMSN_06087S": {
        "ID": "STMSN_06087S",
        "Text": "從今以後"
      },
      "STMSN_06087S_EXPLANATION": {
        "ID": "STMSN_06087S_EXPLANATION",
        "Text": "里香解咒後過了一段時間\n五條確認了乙骨「如今」的力量之後\n開口拜託他一件事情……"
      },
      "STMSN_06088S": {
        "ID": "STMSN_06088S",
        "Text": "師弟"
      },
      "STMSN_06088S_EXPLANATION": {
        "ID": "STMSN_06088S_EXPLANATION",
        "Text": "這也許是曾發生過的真實戰鬥……\n學生們合力挑戰五條老師\n超越最強吧！年輕人們！"
      },
      "STMSN_06089S": {
        "ID": "STMSN_06089S",
        "Text": "冠上特級之名的詛咒"
      },
      "STMSN_06089S_EXPLANATION": {
        "ID": "STMSN_06089S_EXPLANATION",
        "Text": "由各式各樣恐懼的情緒中誕生的\n最高等級的詛咒們……\n他們為了各自的本能、慾望及目的而行動"
      },
      "STMSN_08090M": {
        "ID": "STMSN_08090M",
        "Text": "懷玉"
      },
      "STMSN_08090M_EXPLANATION": {
        "ID": "STMSN_08090M_EXPLANATION",
        "Text": "年少時期的五條與夏油\n最強的兩人\n已經回不去的青春時光即將開始"
      },
      "STMSN_08091M": {
        "ID": "STMSN_08091M",
        "Text": "術師殺手"
      },
      "STMSN_08091M_EXPLANATION": {
        "ID": "STMSN_08091M_EXPLANATION",
        "Text": "伏黑甚爾看準了一行人\n進入高專結界的瞬間襲擊\n而甚爾超乎我方預料的秘密是？"
      },
      "STMSN_08092M": {
        "ID": "STMSN_08092M",
        "Text": "被摧毀的願望"
      },
      "STMSN_08092M_EXPLANATION": {
        "ID": "STMSN_08092M_EXPLANATION",
        "Text": "在即將與天元同化前\n天內想忠於自己的內心\n夏油打算實現她的那個願望……"
      },
      "STMSN_08093M": {
        "ID": "STMSN_08093M",
        "Text": "覺醒"
      },
      "STMSN_08093M_EXPLANATION": {
        "ID": "STMSN_08093M_EXPLANATION",
        "Text": "五條沒有死\n他在將死之際掌握了操作咒力的奧秘\n再次阻擋在甚爾面前"
      },
      "STMSN_08094M": {
        "ID": "STMSN_08094M",
        "Text": "玉折"
      },
      "STMSN_08094M_EXPLANATION": {
        "ID": "STMSN_08094M_EXPLANATION",
        "Text": "變成最強的五條\n變成獨自一人的夏油\n兩人的道路逐漸分歧"
      },
      "STMSN_09095M": {
        "ID": "STMSN_09095M",
        "Text": "宵祭"
      },
      "STMSN_09095M_EXPLANATION": {
        "ID": "STMSN_09095M_EXPLANATION",
        "Text": "與咒靈串通的機械丸，也就是與幸吉\n為了實現「和大家相見」的願望\n賭上至今為止的一切與真人戰鬥"
      },
      "STMSN_09096M": {
        "ID": "STMSN_09096M",
        "Text": "澀谷事變　開門"
      },
      "STMSN_09096M_EXPLANATION": {
        "ID": "STMSN_09096M_EXPLANATION",
        "Text": "2018年10月31日\n在萬聖節這天，咒詛師們\n在澀谷著手實行某項計畫"
      },
      "STMSN_09097M": {
        "ID": "STMSN_09097M",
        "Text": "對峙"
      },
      "STMSN_09097M_EXPLANATION": {
        "ID": "STMSN_09097M_EXPLANATION",
        "Text": "敵人與陷阱\n正等著抵達澀谷的五條悟\n五條展開與咒靈們的戰鬥"
      },
      "STMSN_09098M": {
        "ID": "STMSN_09098M",
        "Text": "獄門疆"
      },
      "STMSN_09098M_EXPLANATION": {
        "ID": "STMSN_09098M_EXPLANATION",
        "Text": "為了封印五條悟而準備的獄門疆\n出乎意料的人物與其開門同時現身\n"
      },
      "STMSN_09099M": {
        "ID": "STMSN_09099M",
        "Text": "昏亂"
      },
      "STMSN_09099M_EXPLANATION": {
        "ID": "STMSN_09099M_EXPLANATION",
        "Text": "迷你機械丸告知了五條被封印\n虎杖為了突破這個局面\n打算與七海會合"
      },
      "STMSN_09100M": {
        "ID": "STMSN_09100M",
        "Text": "降靈"
      },
      "STMSN_09100M_EXPLANATION": {
        "ID": "STMSN_09100M_EXPLANATION",
        "Text": "虎杖等人認為咒詛師們\n是在「顯眼的地點」守護「帳」的根基\n於是以高層大樓屋頂為目標前進"
      },
      "STMSN_09101M": {
        "ID": "STMSN_09101M",
        "Text": "鈍刀"
      },
      "STMSN_09101M_EXPLANATION": {
        "ID": "STMSN_09101M_EXPLANATION",
        "Text": "七海在負傷的釘崎與新田面前現身\n對重面表現出怒氣並出拳攻擊\n釘崎見識到了那壓倒性的力量"
      },
      "STMSN_09102M": {
        "ID": "STMSN_09102M",
        "Text": "赫鱗"
      },
      "STMSN_09102M_EXPLANATION": {
        "ID": "STMSN_09102M_EXPLANATION",
        "Text": "脹相攻擊抵達澀谷站地下的虎杖\n並且問他\n「弟弟最後有說了什麼遺言嗎？」"
      },
      "STMSN_09103M": {
        "ID": "STMSN_09103M",
        "Text": "搖蕩"
      },
      "STMSN_09103M_EXPLANATION": {
        "ID": "STMSN_09103M_EXPLANATION",
        "Text": "直毘人、七海、真希進入了陀艮的領域\n在有如海浪永無止盡不斷襲來的攻擊下\n咒術師們漸漸疲憊"
      },
      "STMSN_09104M": {
        "ID": "STMSN_09104M",
        "Text": "霹靂"
      },
      "STMSN_09104M_EXPLANATION": {
        "ID": "STMSN_09104M_EXPLANATION",
        "Text": "兩面宿儺奪走虎杖身體的主導權\n覺醒的他拒絕漏瑚締結「束縛」的提案\n向他提出對決"
      },
      "STMSN_09105M": {
        "ID": "STMSN_09105M",
        "Text": "失控"
      },
      "STMSN_09105M_EXPLANATION": {
        "ID": "STMSN_09105M_EXPLANATION",
        "Text": "突然出現的神秘男人把伏黑視為下個目標\n面對他壓倒性的力量\n陷入絕境的伏黑打算賭上性命應戰"
      },
      "STMSN_09106M": {
        "ID": "STMSN_09106M",
        "Text": "異戒神將"
      },
      "STMSN_09106M_EXPLANATION": {
        "ID": "STMSN_09106M_EXPLANATION",
        "Text": "因重面春太的刀刃攻擊而瀕死的伏黑\n開始從自己的術式「十種影法術」中\n召喚某個式神，進行調伏之儀"
      },
      "STMSN_09107M": {
        "ID": "STMSN_09107M",
        "Text": "是非"
      },
      "STMSN_09107M_EXPLANATION": {
        "ID": "STMSN_09107M_EXPLANATION",
        "Text": "受了重傷的七海仍在澀谷徘徊戰鬥\n真人出現在他面前\n而趕到兩人身邊的虎杖看到的是……"
      },
      "STMSN_09108M": {
        "ID": "STMSN_09108M",
        "Text": "同心"
      },
      "STMSN_09108M_EXPLANATION": {
        "ID": "STMSN_09108M_EXPLANATION",
        "Text": "回到戰線的釘崎遇到真人\n對於攻擊不管用的真人\n釘崎具有勝算"
      },
      "STMSN_09109M": {
        "ID": "STMSN_09109M",
        "Text": "茫然"
      },
      "STMSN_09109M_EXPLANATION": {
        "ID": "STMSN_09109M_EXPLANATION",
        "Text": "即使是重創真人的釘崎\n仍在虎杖眼前因攻擊倒下\n虎杖沮喪而失去自我時，某個男人出現了"
      },
      "STMSN_09110M": {
        "ID": "STMSN_09110M",
        "Text": "遺志"
      },
      "STMSN_09110M_EXPLANATION": {
        "ID": "STMSN_09110M_EXPLANATION",
        "Text": "虎杖懷抱夥伴們所託而站了起來\n接著東堂繼虎杖、真人之後也使出黑閃\n三人的戰鬥更加劇烈了"
      },
      "STMSN_09111M": {
        "ID": "STMSN_09111M",
        "Text": "變身"
      },
      "STMSN_09111M_EXPLANATION": {
        "ID": "STMSN_09111M_EXPLANATION",
        "Text": "在與虎杖進行激戰後\n真人終於掌握自己靈魂的本質\n以變身後的樣貌擋在虎杖面前"
      },
      "STMSN_09112M": {
        "ID": "STMSN_09112M",
        "Text": "離愁"
      },
      "STMSN_09112M_EXPLANATION": {
        "ID": "STMSN_09112M_EXPLANATION",
        "Text": "在京都校眾人前往澀谷途中\n機械丸在列車裡以與幸吉的身分\n向三輪留下最後的話語"
      },
      "STMSN_09113M": {
        "ID": "STMSN_09113M",
        "Text": "血戰"
      },
      "STMSN_09113M_EXPLANATION": {
        "ID": "STMSN_09113M_EXPLANATION",
        "Text": "脹相察覺設法讓他殺死兄弟的\n那名男人的真面目\n他憤怒地拿出身為哥哥的全力對戰\n"
      },
      "STMSN_09114M": {
        "ID": "STMSN_09114M",
        "Text": "澀谷事變　關門"
      },
      "STMSN_09114M_EXPLANATION": {
        "ID": "STMSN_09114M_EXPLANATION",
        "Text": "被稱為加茂憲倫的男人表示\n今後的世界將會是令人恐懼的混沌\n與更加激烈的戰鬥開端"
      },
      "STR_DEMO_LABEL_0001": {
        "ID": "STR_DEMO_LABEL_0001",
        "Text": "原作　『咒術迴戰』Gege Akutami"
      },
      "STR_DEMO_LABEL_0002": {
        "ID": "STR_DEMO_LABEL_0002",
        "Text": "（集英社『週刊少年JUMP』連載）"
      },
