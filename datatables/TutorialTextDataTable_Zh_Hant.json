        "Text": "避開攻擊10秒"
      },
      "TUT_INGAME_TASK_COMMAND_LABEL_0017": {
        "ID": "TUT_INGAME_TASK_COMMAND_LABEL_0017",
        "Text": "<img id=\"Guard\"/>＋<img id=\"MoveLeft\"/>或<img id=\"MoveRight\"/>"
      },
      "TUT_INGAME_TASK_MESSAGE_0018": {
        "ID": "TUT_INGAME_TASK_MESSAGE_0018",
        "Text": "讓五條老師的<GLO=GLS_GAME_WORDS_1502>歸零"
      },
      "TUT_INGAME_TASK_COMMAND_LABEL_0018": {
        "ID": "TUT_INGAME_TASK_COMMAND_LABEL_0018",
        "Text": "<img id=\"CursedEnergyAttack_1\"/>"
      },
      "TUT_INGAME_LABEL_0008": {
        "ID": "TUT_INGAME_LABEL_0008",
        "Text": "關於<GLO=GLS_GAME_WORDS_1301>"
      },
      "TUT_INGAME_MESSAGE_0008": {
        "ID": "TUT_INGAME_MESSAGE_0008",
        "Text": "連續輸入<img id=\"NormalAttack_1\"/>可以使出連結<GLO=GLS_GAME_WORDS_1302>和<GLO=GLS_GAME_WORDS_1307>的連擊「<GLO=GLS_GAME_WORDS_1301>」\n只有在<GLO=GLS_GAME_WORDS_1503>足以發動<GLO=GLS_GAME_WORDS_1307>的狀態下\n使出「<GLO=GLS_GAME_WORDS_1301>」會讓最後的招式變化為<GLO=GLS_GAME_WORDS_1307>"
      },
      "TUT_INGAME_LABEL_0009": {
        "ID": "TUT_INGAME_LABEL_0009",
        "Text": "關於<GLO=GLS_GAME_WORDS_1409>"
      },
      "TUT_INGAME_MESSAGE_0009": {
        "ID": "TUT_INGAME_MESSAGE_0009",
        "Text": "用<img id=\"Guard\"/>發動擋下敵方攻擊的「<GLO=GLS_GAME_WORDS_1409>」 \n長按中會成為<GLO=GLS_GAME_WORDS_1409>狀態，所受傷害無效化\n但是以<GLO=GLS_GAME_WORDS_1409>持續承受攻擊\n會使<GLO=GLS_GAME_WORDS_1409>破除，進入「<GLO=GLS_GAME_WORDS_1432>」狀態\n這項狀態將會成為重大破綻，需要注意\n\n另外，如果受到敵方攻擊的瞬間<GLO=GLS_GAME_WORDS_1409>成功\n就會變成「<GLO=GLS_GAME_WORDS_1410>」，容易製造反擊機會"
      },
      "TUT_INGAME_LABEL_0010": {
        "ID": "TUT_INGAME_LABEL_0010",
        "Text": "關於<GLO=GLS_GAME_WORDS_1431>"
      },
      "TUT_INGAME_MESSAGE_0010": {
        "ID": "TUT_INGAME_MESSAGE_0010",
        "Text": "<GLO=GLS_GAME_WORDS_1409>時按下<img id=\"MoveUp\"/><img id=\"MoveDown\"/><img id=\"MoveLeft\"/><img id=\"MoveRight\"/>會發動「<GLO=GLS_GAME_WORDS_1431>」\n往輸入方向移動，避開敵方攻擊"
      },
      "TUT_INGAME_LABEL_0011": {
        "ID": "TUT_INGAME_LABEL_0011",
        "Text": "總結"
      },
      "TUT_INGAME_MESSAGE_0011": {
        "ID": "TUT_INGAME_MESSAGE_0011",
        "Text": "讓<GLO=GLS_GAME_WORDS_1302>擊中敵方，使<GLO=GLS_GAME_WORDS_1503>上升\n用<GLO=GLS_GAME_WORDS_1307>削減敵方的<GLO=GLS_GAME_WORDS_1502><GLO=GLS_GAME_WORDS_1418>敵方吧\n\n<GLO=GLS_GAME_WORDS_1418>敵方，讓對手<GLO=GLS_GAME_WORDS_1422>歸零就是<GLO=GLS_GAME_WORDS_1601>目標"
      },
      "TUT_INGAME_CHARACTER_MESSAGE_0001": {
        "ID": "TUT_INGAME_CHARACTER_MESSAGE_0001",
        "Text": "那馬上開始特訓吧！"
      },
      "TUT_INGAME_CHARACTER_MESSAGE_0002": {
        "ID": "TUT_INGAME_CHARACTER_MESSAGE_0002",
        "Text": "好！請多指教！"
      },
      "TUT_INGAME_CHARACTER_MESSAGE_0003": {
        "ID": "TUT_INGAME_CHARACTER_MESSAGE_0003",
        "Text": "先試著來到我的身旁吧"
      },
      "TUT_INGAME_CHARACTER_MESSAGE_0004": {
        "ID": "TUT_INGAME_CHARACTER_MESSAGE_0004",
        "Text": "動作不錯！"
      },
      "TUT_INGAME_CHARACTER_MESSAGE_0005": {
        "ID": "TUT_INGAME_CHARACTER_MESSAGE_0005",
        "Text": "接下來試著讓攻擊打中我"
      },
      "TUT_INGAME_CHARACTER_MESSAGE_0006": {
        "ID": "TUT_INGAME_CHARACTER_MESSAGE_0006",
        "Text": "要是受傷我可不管喔？"
      },
      "TUT_INGAME_CHARACTER_MESSAGE_0007": {
        "ID": "TUT_INGAME_CHARACTER_MESSAGE_0007",
        "Text": "你在近身戰鬥這方面果然是高人一等啊！"
      },
      "TUT_INGAME_CHARACTER_MESSAGE_0008": {
        "ID": "TUT_INGAME_CHARACTER_MESSAGE_0008",
        "Text": "接下來我會攻擊，你應對看看"
      },
      "TUT_INGAME_CHARACTER_MESSAGE_0009": {
        "ID": "TUT_INGAME_CHARACTER_MESSAGE_0009",
        "Text": "很不錯的持久力！"
      },
      "TUT_INGAME_CHARACTER_MESSAGE_0010": {
        "ID": "TUT_INGAME_CHARACTER_MESSAGE_0010",
        "Text": "最後我來教你<GLO=GLS_GAME_WORDS_1503>的控制！"
      },
      "TUT_INGAME_CHARACTER_MESSAGE_0011": {
        "ID": "TUT_INGAME_CHARACTER_MESSAGE_0011",
        "Text": "把<GLO=GLS_GAME_WORDS_1503>加在悠仁你的體術上擊出吧"
      },
      "TUT_INGAME_CHARACTER_MESSAGE_0012": {
        "ID": "TUT_INGAME_CHARACTER_MESSAGE_0012",
        "Text": "那我已經辦得到了！！"
