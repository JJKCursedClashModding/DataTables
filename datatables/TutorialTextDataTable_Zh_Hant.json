      },
      "TUT_INGAME_CHARACTER_MESSAGE_0014": {
        "ID": "TUT_INGAME_CHARACTER_MESSAGE_0014",
        "Text": "這拳沒有包含<GLO=GLS_GAME_WORDS_1503>喔"
