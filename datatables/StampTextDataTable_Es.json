    "Flags": "RF_Public | RF_Standalone | RF_Transactional | RF_WasLoaded | RF_LoadCompleted",
    "Class": "UScriptClass'DataTable'",
    "Properties": {
      "RowStruct": {
        "ObjectName": "Class'GameDataTableRow_GameText'",
        "ObjectPath": "/Script/Abrams"
      },
      "ImportKeyField": "Id"
    },
    "Rows": {
      "CP_010_STAMP_001": {
        "ID": "CP_010_STAMP_001",
        "Text": "Qué ganas tenía."
      },
      "CP_010_STAMP_002": {
        "ID": "CP_010_STAMP_002",
        "Text": "Te debo una."
      },
      "CP_020_STAMP_001": {
        "ID": "CP_020_STAMP_001",
        "Text": "Vas bien. \nCúrratelo un poquito más."
      },
      "CP_030_STAMP_001": {
        "ID": "CP_030_STAMP_001",
        "Text": "Yo tampoco quiero perder."
      },
      "CP_030_STAMP_002": {
        "ID": "CP_030_STAMP_002",
        "Text": "Te enseñaré de lo que soy capaz."
      },
      "CP_040_STAMP_001": {
        "ID": "CP_040_STAMP_001",
        "Text": "¿No duermes o qué?"
      },
      "CP_040_STAMP_002": {
        "ID": "CP_040_STAMP_002",
        "Text": "He dado en el clavo."
      },
      "CP_050_STAMP_001": {
        "ID": "CP_050_STAMP_001",
        "Text": "Buenas."
      },
      "CP_050_STAMP_002": {
        "ID": "CP_050_STAMP_002",
        "Text": "¡Toma!"
      },
      "CP_060_STAMP_001": {
        "ID": "CP_060_STAMP_001",
        "Text": "Que sepas que no pienso contenerme."
      },
      "CP_070_STAMP_001": {
        "ID": "CP_070_STAMP_001",
        "Text": "Atún amarillo. Huevas de gambas."
      },
      "CP_080_STAMP_001": {
        "ID": "CP_080_STAMP_001",
        "Text": "Qué hay. Yo soy Panda."
      },
      "CP_090_STAMP_001": {
        "ID": "CP_090_STAMP_001",
        "Text": "Trabajar es un asco."
      },
      "CP_100_STAMP_001": {
        "ID": "CP_100_STAMP_001",
        "Text": "¿Qué clase de mujeres\nte gustan?"
      },
      "CP_110_STAMP_001": {
        "ID": "CP_110_STAMP_001",
        "Text": "¡Hay que darlo todo!"
      },
      "CP_120_STAMP_001": {
        "ID": "CP_120_STAMP_001",
        "Text": "Vamos a hacernos una foto."
      },
      "CP_130_STAMP_001": {
        "ID": "CP_130_STAMP_001",
        "Text": "Te estoy muy agradecido."
      },
      "CP_140_STAMP_001": {
        "ID": "CP_140_STAMP_001",
        "Text": "¿Qué pasa aquí?"
      },
      "CP_150_STAMP_001": {
        "ID": "CP_150_STAMP_001",
        "Text": "Estoy disfrutando de una pelea."
      },
      "CP_160_STAMP_001": {
        "ID": "CP_160_STAMP_001",
        "Text": "¡Abeja asesina!"
      },
      "CP_051_STAMP_001": {
        "ID": "CP_051_STAMP_001",
        "Text": "¿Estás llorando?"
      },
      "CP_051_STAMP_002": {
        "ID": "CP_051_STAMP_002",
        "Text": "Tanto en el cielo como en la tierra, soy el elegido."
      },
      "CP_121_STAMP_001": {
        "ID": "CP_121_STAMP_001",
        "Text": "Ayudar a los débiles y contener a los fuertes."
      },
      "CP_121_STAMP_002": {
        "ID": "CP_121_STAMP_002",
        "Text": "Somos los más fuertes."
      },
      "CP_170_STAMP_001": {
        "ID": "CP_170_STAMP_001",
        "Text": "¡En el blanco!"
      },
      "CP_170_STAMP_002": {
        "ID": "CP_170_STAMP_002",
        "Text": "¡Serás egoísta!"
      },
      "CP_170_STAMP_003": {
        "ID": "CP_170_STAMP_003",
        "Text": "Jo, qué penita me da."
      },
      "CP_180_STAMP_001": {
        "ID": "CP_180_STAMP_001",
        "Text": "Aguanta, Momo. ¡Eres la más mona!"
      },
      "CP_180_STAMP_002": {
        "ID": "CP_180_STAMP_002",
        "Text": "Nada cuqui, no."
      },
      "CP_190_STAMP_001": {
        "ID": "CP_190_STAMP_001",
        "Text": "No puedo permitirme perder. Me niego."
      },
      "CP_190_STAMP_002": {
        "ID": "CP_190_STAMP_002",
        "Text": "Lo he decidido por mi cuenta."
      },
      "CP_200_STAMP_001": {
        "ID": "CP_200_STAMP_001",
        "Text": "Hala, se acabó el curro. Ya puedes irte."
      },
      "CP_200_STAMP_002": {
        "ID": "CP_200_STAMP_002",
        "Text": "No, la pelea no ha hecho más que empezar."
      },
      "CP_210_STAMP_001": {
        "ID": "CP_210_STAMP_001",
        "Text": "¿Y si intentamos llevarnos bien?"
      },
      "CP_210_STAMP_002": {
        "ID": "CP_210_STAMP_002",
        "Text": "¡Holaaa! ¡Aquí la inútil de Miwa!"
      },
      "CP_220_STAMP_001": {
        "ID": "CP_220_STAMP_001",
        "Text": "Atadura celestial. ¿Has oído hablar de ella?"
      },
      "CP_220_STAMP_002": {
        "ID": "CP_220_STAMP_002",
        "Text": "Te han matado, ¿eh?"
      },
      "CP_230_STAMP_001": {
        "ID": "CP_230_STAMP_001",
        "Text": "¡Cumpliré mi deber de hermano mayor cueste lo que cueste!"
      },
      "CP_230_STAMP_002": {
        "ID": "CP_230_STAMP_002",
        "Text": "¡Soy el hermano mayor de Yûji!"
      },
      "CP_240_STAMP_001": {
        "ID": "CP_240_STAMP_001",
        "Text": "¿Acaso darías la vida por mí?"
      },
      "CP_240_STAMP_002": {
        "ID": "CP_240_STAMP_002",
        "Text": "Voy adonde va el dinero, eso está claro."
      },
      "CP_270_STAMP_001": {
        "ID": "CP_270_STAMP_001",
        "Text": "No te lo permitiré."
      },
      "CP_270_STAMP_002": {
        "ID": "CP_270_STAMP_002",
        "Text": "Esto lo vas a pagar."
      }
    }
  }
]