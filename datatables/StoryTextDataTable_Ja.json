[
  {
    "Type": "DataTable",
    "Name": "StoryTextDataTable_Ja",
    "Flags": "RF_Public | RF_Standalone | RF_Transactional | RF_WasLoaded | RF_LoadCompleted",
    "Class": "UScriptClass'DataTable'",
    "Properties": {
      "RowStruct": {
        "ObjectName": "Class'GameDataTableRow_GameText'",
        "ObjectPath": "/Script/Abrams"
      },
      "ImportKeyField": "Id"
    },
    "Rows": {
      "CHAP_0001": {
        "ID": "CHAP_0001",
        "Text": "呪胎戴天 前編"
      },
      "CHAP_0002": {
        "ID": "CHAP_0002",
        "Text": "呪胎戴天 後編"
      },
      "CHAP_0003": {
        "ID": "CHAP_0003",
        "Text": "幼魚と逆罰"
      },
      "CHAP_0004": {
        "ID": "CHAP_0004",
        "Text": "京都姉妹校交流会"
      },
      "CHAP_0005": {
        "ID": "CHAP_0005",
        "Text": "起首雷同"
      },
      "CHAP_0006": {
        "ID": "CHAP_0006",
        "Text": "呪術廻戦０"
      },
      "CHAP_0007": {
        "ID": "CHAP_0007",
        "Text": "EXバトル"
      },
      "CHAP_0008": {
        "ID": "CHAP_0008",
        "Text": "懐玉・玉折"
      },
      "CHAP_0009": {
        "ID": "CHAP_0009",
        "Text": "渋谷事変"
      },
      "STMSN_01000M": {
        "ID": "STMSN_01000M",
        "Text": "「最強」の伝授"
      },
      "STMSN_01000M_EXPLANATION": {
        "ID": "STMSN_01000M_EXPLANATION",
        "Text": "自身の弱さを知り\n少年は強くなると決意する…\n”正しい死”を求めて"
      },
      "STMSN_01001M": {
        "ID": "STMSN_01001M",
        "Text": "両面宿儺"
      },
      "STMSN_01001M_EXPLANATION": {
        "ID": "STMSN_01001M_EXPLANATION",
        "Text": "凶悪な呪物の封印が解かれ呪いが集まる\n「俺にジュリョクがあればいいんだろ！」\n虎杖は呪いに立ち向かうために…"
      },
      "STMSN_01002M": {
        "ID": "STMSN_01002M",
        "Text": "秘匿死刑"
      },
      "STMSN_01002M_EXPLANATION": {
        "ID": "STMSN_01002M_EXPLANATION",
        "Text": "特級呪術師”五条悟”が宿儺受肉を確認\n虎杖に代わるように指示する…\n最強と最恐の戦いが始まる！"
      },
      "STMSN_01003M": {
        "ID": "STMSN_01003M",
        "Text": "遺言"
      },
      "STMSN_01003M_EXPLANATION": {
        "ID": "STMSN_01003M_EXPLANATION",
        "Text": "今すぐ死ぬか\n宿儺の指を全て取り込み死ぬか\n祖父の遺言を想い、虎杖は選択する…"
      },
      "STMSN_01004M": {
        "ID": "STMSN_01004M",
        "Text": "自分のために"
      },
      "STMSN_01004M_EXPLANATION": {
        "ID": "STMSN_01004M_EXPLANATION",
        "Text": "虎杖は高専に来た理由を問われ考える\n祖父の遺言…　自身にしかできないこと…\n虎杖が出した答えは…！！"
      },
      "STMSN_01005M": {
        "ID": "STMSN_01005M",
        "Text": "鉄骨娘"
      },
      "STMSN_01005M_EXPLANATION": {
        "ID": "STMSN_01005M_EXPLANATION",
        "Text": "釘崎と虎杖は呪霊祓除の試験に挑む！\n引率の五条にはある狙いがあり…"
      },
      "STMSN_01006M": {
        "ID": "STMSN_01006M",
        "Text": "始まり"
      },
      "STMSN_01006M_EXPLANATION": {
        "ID": "STMSN_01006M_EXPLANATION",
        "Text": "呪霊が子供を人質に取り\n釘崎に命をかけた天秤を突き付ける\n葛藤の末、釘崎が出した答えは…"
      },
      "STMSN_01007M": {
        "ID": "STMSN_01007M",
        "Text": "呪胎戴天"
      },
      "STMSN_01007M_EXPLANATION": {
        "ID": "STMSN_01007M_EXPLANATION",
        "Text": "少年院で呪胎が確認される\n伊地知から状況を聞いた虎杖達が\n生存者救出に向かうが院内は既に…"
      },
      "STMSN_01008M": {
        "ID": "STMSN_01008M",
        "Text": "脱出"
      },
      "STMSN_01008M_EXPLANATION": {
        "ID": "STMSN_01008M_EXPLANATION",
        "Text": "一人異なる場所で彷徨う釘崎は\n付近に異様な気配を感じ取る…\n「何…この数！！」"
      },
      "STMSN_01009M": {
        "ID": "STMSN_01009M",
        "Text": "呪いの王"
      },
      "STMSN_01009M_EXPLANATION": {
        "ID": "STMSN_01009M_EXPLANATION",
        "Text": "死の淵に立つ虎杖に伏黒の合図が届く\n宿儺と特級呪霊をぶつける作戦だったが…\n「おい　ガキ共を殺しに行くぞ」"
      },
      "STMSN_01010M": {
        "ID": "STMSN_01010M",
        "Text": "理由"
      },
      "STMSN_01010M_EXPLANATION": {
        "ID": "STMSN_01010M_EXPLANATION",
        "Text": "外で虎杖を待つ伏黒の前に宿儺が現れる\n「俺に今できることを考えた」\n一時的に体の主導権を得ている宿儺は…"
      },
      "STMSN_02011M": {
        "ID": "STMSN_02011M",
        "Text": "雨後"
      },
      "STMSN_02011M_EXPLANATION": {
        "ID": "STMSN_02011M_EXPLANATION",
        "Text": "釘崎に虎杖の遺言を伝えた伏黒\n「自分が死んでりゃ世話ないわよ…」\n虎杖の死を惜しむ二人に人影が近付く…"
      },
      "STMSN_02012M": {
        "ID": "STMSN_02012M",
        "Text": "企み"
      },
      "STMSN_02012M_EXPLANATION": {
        "ID": "STMSN_02012M_EXPLANATION",
        "Text": "漏瑚は呪術師に勝つ方法を問い\n夏油が答える…\n「２つ条件を満たせば勝てるよ」"
      },
      "STMSN_02013M": {
        "ID": "STMSN_02013M",
        "Text": "縛り"
      },
      "STMSN_02013M_EXPLANATION": {
        "ID": "STMSN_02013M_EXPLANATION",
        "Text": "死んだ筈の虎杖は宿儺と睨み合っていた\n「俺達はまだ死んでいない」\n宿儺は生き返る条件を提示するが…"
      },
      "STMSN_02014M": {
        "ID": "STMSN_02014M",
        "Text": "ある夢想"
      },
      "STMSN_02014M_EXPLANATION": {
        "ID": "STMSN_02014M_EXPLANATION",
        "Text": "五条は伊地知に自身の夢を話す…のだが\n「ごごご五ご五条さん！！」\n伊地知が目撃したモノとは！？"
      },
      "STMSN_02015M": {
        "ID": "STMSN_02015M",
        "Text": "映画鑑賞"
      },
      "STMSN_02015M_EXPLANATION": {
        "ID": "STMSN_02015M_EXPLANATION",
        "Text": "自身の弱さを知った虎杖は\n五条に呪力制御の修業をつけてもらう\n「強くなりたい　”最強”を教えてくれ」"
      },
      "STMSN_02016M": {
        "ID": "STMSN_02016M",
        "Text": "邁進"
      },
      "STMSN_02016M_EXPLANATION": {
        "ID": "STMSN_02016M_EXPLANATION",
        "Text": "パンダに投げ飛ばされ宙を舞う釘崎…\n「クッ…まだまだぁ！」\n交流会に向けて邁進する！"
      },
      "STMSN_02017M": {
        "ID": "STMSN_02017M",
        "Text": "邁進 -弐-"
      },
      "STMSN_02017M_EXPLANATION": {
        "ID": "STMSN_02017M_EXPLANATION",
        "Text": "伏黒は呪具の扱いと持ち運び方法を思案する\n「オマエあの時　何故逃げた」\n宿儺の言葉を思い出しあることに思い至り…"
      },
      "STMSN_02018S": {
        "ID": "STMSN_02018S",
        "Text": "邁進 -参-"
      },
      "STMSN_02018S_EXPLANATION": {
        "ID": "STMSN_02018S_EXPLANATION",
        "Text": "いつも一対一の戦いとは限らない…\n少年院でそのことを痛感した釘崎は\n真希、狗巻と共に特訓を開始する！"
      },
      "STMSN_02019S": {
        "ID": "STMSN_02019S",
        "Text": "邁進 -肆-"
      },
      "STMSN_02019S_EXPLANATION": {
        "ID": "STMSN_02019S_EXPLANATION",
        "Text": "巨大な敵との戦い…\n以前、巨体の呪霊と戦い負傷した伏黒は\nパンダと共に特訓を開始する！"
      },
      "STMSN_02020S": {
        "ID": "STMSN_02020S",
        "Text": "邁進 -伍-"
      },
      "STMSN_02020S_EXPLANATION": {
        "ID": "STMSN_02020S_EXPLANATION",
        "Text": "特訓で疲弊し休息していた伏黒、釘崎の元に\n笑顔の五条が現れ二人に…"
      },
      "STMSN_02021M": {
        "ID": "STMSN_02021M",
        "Text": "急襲"
      },
      "STMSN_02021M_EXPLANATION": {
        "ID": "STMSN_02021M_EXPLANATION",
        "Text": "移動中の五条が急襲される！\n「君　何者？」\n襲撃者の目的は一体…"
      },
      "STMSN_02022M": {
        "ID": "STMSN_02022M",
        "Text": "領域"
      },
      "STMSN_02022M_EXPLANATION": {
        "ID": "STMSN_02022M_EXPLANATION",
        "Text": "生得領域の具現化　”領域展開”\n呪術戦の頂点と呼ばれる戦いが始まる…"
      },
      "STMSN_02023M": {
        "ID": "STMSN_02023M",
        "Text": "呪いらしく"
      },
      "STMSN_02023M_EXPLANATION": {
        "ID": "STMSN_02023M_EXPLANATION",
        "Text": "花御の助けで逃走に成功した漏瑚に\n夏油が五条に打ち勝つ作戦について説明する\nそこには新たな呪霊の姿が…"
      },
      "STMSN_02024M": {
        "ID": "STMSN_02024M",
        "Text": "呪力"
      },
      "STMSN_02024M_EXPLANATION": {
        "ID": "STMSN_02024M_EXPLANATION",
        "Text": "呪術を悪用する者”呪詛師”\nその対処方法を五条が虎杖に教授する\nそして五条は虎杖のある癖に気が付き…"
      },
      "STMSN_02025M": {
        "ID": "STMSN_02025M",
        "Text": "遣い走り"
      },
      "STMSN_02025M_EXPLANATION": {
        "ID": "STMSN_02025M_EXPLANATION",
        "Text": "罰ゲームを設け特訓する真希、伏黒、釘崎\n三人はまだ知らない\nある者達が高専に訪れていることを…"
      },
      "STMSN_02026M": {
        "ID": "STMSN_02026M",
        "Text": "退屈"
      },
      "STMSN_02026M_EXPLANATION": {
        "ID": "STMSN_02026M_EXPLANATION",
        "Text": "伏黒、釘崎の品定めに来た東堂は質問する\n「どんな女がタイプだ」\n渋々伏黒は答える…のだが！"
      },
      "STMSN_02027S": {
        "ID": "STMSN_02027S",
        "Text": "奮励"
      },
      "STMSN_02027S_EXPLANATION": {
        "ID": "STMSN_02027S_EXPLANATION",
        "Text": "真依にやられた釘崎は力を欲していた！\n「最終的に信じられるのは己が肉体ね…」\n釘崎は狗巻とパンダを見つけ…"
      },
      "STMSN_02028M": {
        "ID": "STMSN_02028M",
        "Text": "忠告"
      },
      "STMSN_02028M_EXPLANATION": {
        "ID": "STMSN_02028M_EXPLANATION",
        "Text": "保守派筆頭の楽巌寺と五条が対面\n虎杖の一件、\nそして今後の呪術界について話し始める…"
      },
      "STMSN_03029M": {
        "ID": "STMSN_03029M",
        "Text": "幼魚と逆罰"
      },
      "STMSN_03029M_EXPLANATION": {
        "ID": "STMSN_03029M_EXPLANATION",
        "Text": "映画館で高校生3名の変死体が発見される\n被害者と”関係”があった少年は\n犯人である呪霊と接触し…"
      },
      "STMSN_03030M": {
        "ID": "STMSN_03030M",
        "Text": "脱サラ呪術師"
      },
      "STMSN_03030M_EXPLANATION": {
        "ID": "STMSN_03030M_EXPLANATION",
        "Text": "引率役の七海と共に\n虎杖は変死事件の調査に向かう\n現場で発見した残穢の先で二人は…"
      },
      "STMSN_03031M": {
        "ID": "STMSN_03031M",
        "Text": "逕庭拳"
      },
      "STMSN_03031M_EXPLANATION": {
        "ID": "STMSN_03031M_EXPLANATION",
        "Text": "虎杖は五条との特訓で修得した技を発揮する\n一方、七海はあることに気付く…"
      },
      "STMSN_03032M": {
        "ID": "STMSN_03032M",
        "Text": "魂の形"
      },
      "STMSN_03032M_EXPLANATION": {
        "ID": "STMSN_03032M_EXPLANATION",
        "Text": "真人の潜伏場所の特定に成功し\n七海が単独で向かう\nだが潜伏場所には大量の…"
      },
      "STMSN_03033M": {
        "ID": "STMSN_03033M",
        "Text": "調査"
      },
      "STMSN_03033M_EXPLANATION": {
        "ID": "STMSN_03033M_EXPLANATION",
        "Text": "調査に来た虎杖と対話した吉野は思案する\n虎杖の言葉…　母への想い…\nだが裏で真人達の思惑が動き始め…"
      },
      "STMSN_03034M": {
        "ID": "STMSN_03034M",
        "Text": "時間外労働"
      },
      "STMSN_03034M_EXPLANATION": {
        "ID": "STMSN_03034M_EXPLANATION",
        "Text": "真人の猛攻に防戦一方の七海は\n自身に科していた制限を解除\n七海は反撃を始める！"
      },
      "STMSN_03035M": {
        "ID": "STMSN_03035M",
        "Text": "いつかの君へ"
      },
      "STMSN_03035M_EXPLANATION": {
        "ID": "STMSN_03035M_EXPLANATION",
        "Text": "母を呪殺された吉野は\n犯人捜索のために里桜高校を襲撃する\n虎杖が事態収拾に向かうが…"
      },
      "STMSN_03036M": {
        "ID": "STMSN_03036M",
        "Text": "天敵"
      },
      "STMSN_03036M_EXPLANATION": {
        "ID": "STMSN_03036M_EXPLANATION",
        "Text": "虎杖の窮地に七海が駆けつける\n真人の様子の変化に気付き\n二人で猛攻を開始する！"
      },
      "STMSN_03037M": {
        "ID": "STMSN_03037M",
        "Text": "成長"
      },
      "STMSN_03037M_EXPLANATION": {
        "ID": "STMSN_03037M_EXPLANATION",
        "Text": "改造人間に防戦一方の虎杖\n「ころ……して……」\n死を願う言葉を聞き…"
      },
      "STMSN_03038M": {
        "ID": "STMSN_03038M",
        "Text": "また明日"
      },
      "STMSN_03038M_EXPLANATION": {
        "ID": "STMSN_03038M_EXPLANATION",
        "Text": "七海の窮地に虎杖が駆けつける\n二人は決着を付けるべく\n猛攻を再開するが真人は”奥の手”を…"
      },
      "STMSN_03039M": {
        "ID": "STMSN_03039M",
        "Text": "反省"
      },
      "STMSN_03039M_EXPLANATION": {
        "ID": "STMSN_03039M_EXPLANATION",
        "Text": "敗走した真人は今回の失敗を反省\n今後の作戦について夏油が話し始める…"
      },
      "STMSN_03040S": {
        "ID": "STMSN_03040S",
        "Text": "女子会"
      },
      "STMSN_03040S_EXPLANATION": {
        "ID": "STMSN_03040S_EXPLANATION",
        "Text": "とある休日\n真希の元に何故か不機嫌な釘崎が訪れる\n原因は釘崎が買い物に出かけた時まで遡る…"
      },
      "STMSN_03041S": {
        "ID": "STMSN_03041S",
        "Text": "先輩と後輩"
      },
      "STMSN_03041S_EXPLANATION": {
        "ID": "STMSN_03041S_EXPLANATION",
        "Text": "「帰ったらゆっくりと休みましょう」\n時間内に任務を終えた七海の元に\n五条がお願いをしに現れる…"
      },
      "STMSN_03042S": {
        "ID": "STMSN_03042S",
        "Text": "パンダとパンダ"
      },
      "STMSN_03042S_EXPLANATION": {
        "ID": "STMSN_03042S_EXPLANATION",
        "Text": "とある休日\nパンダと共に伏黒、狗巻は\n新作パンダグッズを買いに行く！のだが…"
      },
      "STMSN_03043S": {
        "ID": "STMSN_03043S",
        "Text": "先輩と後輩 -弐-"
      },
      "STMSN_03043S_EXPLANATION": {
        "ID": "STMSN_03043S_EXPLANATION",
        "Text": "「やあやあ、ちょうど良い所に」\n特訓している釘崎、真希の元に\n七海に”お願い”を断られた五条が現れ…"
      },
      "STMSN_04044M": {
        "ID": "STMSN_04044M",
        "Text": "サプライズ"
      },
      "STMSN_04044M_EXPLANATION": {
        "ID": "STMSN_04044M_EXPLANATION",
        "Text": "京都姉妹校交流会、開催当日！\nそして虎杖の生存を公表する日でもあった\n果たして皆の反応は…"
      },
      "STMSN_04045M": {
        "ID": "STMSN_04045M",
        "Text": "作戦会議"
      },
      "STMSN_04045M_EXPLANATION": {
        "ID": "STMSN_04045M_EXPLANATION",
        "Text": "死んだと思われていた虎杖は予定外の戦力…\n扱いに困っていた真希だったが\n伏黒の一言で考えが変わる…"
      },
      "STMSN_04046M": {
        "ID": "STMSN_04046M",
        "Text": "京都姉妹校交流会"
      },
      "STMSN_04046M_EXPLANATION": {
        "ID": "STMSN_04046M_EXPLANATION",
        "Text": "京都姉妹校交流会　一日目\n様々な想い入り交じる団体戦が始まる…"
      },
      "STMSN_04047M": {
        "ID": "STMSN_04047M",
        "Text": "品定め"
      },
      "STMSN_04047M_EXPLANATION": {
        "ID": "STMSN_04047M_EXPLANATION",
        "Text": "作戦通り行動を開始した東京校陣営の元に\n単機特攻して来た者が姿を現す！"
      },
      "STMSN_04048M": {
        "ID": "STMSN_04048M",
        "Text": "悪癖"
      },
      "STMSN_04048M_EXPLANATION": {
        "ID": "STMSN_04048M_EXPLANATION",
        "Text": "戦いの中で成長を続ける虎杖！\nだが東堂はあることに気が付く…\n「それはオマエの悪癖だな？」"
      },
      "STMSN_04049M": {
        "ID": "STMSN_04049M",
        "Text": "侵入"
      },
      "STMSN_04049M_EXPLANATION": {
        "ID": "STMSN_04049M_EXPLANATION",
        "Text": "各々の戦いが決着していく中、\n単独行動をしていた狗巻の前に\n不穏な気配が近付く…"
      },
      "STMSN_04050M": {
        "ID": "STMSN_04050M",
        "Text": "賢者"
      },
      "STMSN_04050M_EXPLANATION": {
        "ID": "STMSN_04050M_EXPLANATION",
        "Text": "森への畏怖から生まれた者\n遥か格上の特級\n伏黒達は戦闘を避けようとするが…"
      },
      "STMSN_04051M": {
        "ID": "STMSN_04051M",
        "Text": "呪具"
      },
      "STMSN_04051M_EXPLANATION": {
        "ID": "STMSN_04051M_EXPLANATION",
        "Text": "花御の猛攻を耐え抜く伏黒達\nだが紙一重の均衡が崩れようとしていた…"
      },
      "STMSN_04052M": {
        "ID": "STMSN_04052M",
        "Text": "黒閃"
      },
      "STMSN_04052M_EXPLANATION": {
        "ID": "STMSN_04052M_EXPLANATION",
        "Text": "”黒閃”\n呪力の核心に迫る黒き閃光…\n虎杖は羽化を始めようとしていた…"
      },
      "STMSN_04053M": {
        "ID": "STMSN_04053M",
        "Text": "窮屈"
      },
      "STMSN_04053M_EXPLANATION": {
        "ID": "STMSN_04053M_EXPLANATION",
        "Text": "黒閃を得て成長した虎杖\n東堂と共に猛攻を開始する！！\n「さぁ、調理を始めようか」"
      },
      "STMSN_04054M": {
        "ID": "STMSN_04054M",
        "Text": "規格外"
      },
      "STMSN_04054M_EXPLANATION": {
        "ID": "STMSN_04054M_EXPLANATION",
        "Text": "ついに東堂が術式を解禁する！\nIQ53万（自称）がハジキ出した結論は…"
      },
      "STMSN_04055M": {
        "ID": "STMSN_04055M",
        "Text": "呪術甲子園"
      },
      "STMSN_04055M_EXPLANATION": {
        "ID": "STMSN_04055M_EXPLANATION",
        "Text": "交流会が再開\n2回戦は･･･野球！？\n呪術甲子園　プレイボーッ！"
      },
      "STMSN_04056S": {
        "ID": "STMSN_04056S",
        "Text": "合同実習授業"
      },
      "STMSN_04056S_EXPLANATION": {
        "ID": "STMSN_04056S_EXPLANATION",
        "Text": "（五条の思いつきで）1年と2年の\n合同実習授業が始まる！\n高専は日常を取り戻しつつあった…"
      },
      "STMSN_04057S": {
        "ID": "STMSN_04057S",
        "Text": "開花"
      },
      "STMSN_04057S_EXPLANATION": {
        "ID": "STMSN_04057S_EXPLANATION",
        "Text": "作戦は成功しつつも重傷を負った花御は\n戦う愉悦を知り、更に成長する…\n「花御も呪いらしくなってきたね」"
      },
      "STMSN_04058S": {
        "ID": "STMSN_04058S",
        "Text": "合同実習授業 -弐-"
      },
      "STMSN_04058S_EXPLANATION": {
        "ID": "STMSN_04058S_EXPLANATION",
        "Text": "合同実習の2回戦目\n何故か京都校の東堂が参戦！\n東堂に”借り”がある伏黒は…"
      },
      "STMSN_05059M": {
        "ID": "STMSN_05059M",
        "Text": "起首雷同"
      },
      "STMSN_05059M_EXPLANATION": {
        "ID": "STMSN_05059M_EXPLANATION",
        "Text": "非術師が呪殺される事件が発生\n虎杖達が調査を進めるにつれ\n衝撃の事実が発覚していく…"
      },
      "STMSN_05060M": {
        "ID": "STMSN_05060M",
        "Text": "別件"
      },
      "STMSN_05060M_EXPLANATION": {
        "ID": "STMSN_05060M_EXPLANATION",
        "Text": "領域内に入った虎杖達は呪霊と対峙する\nだが侵入者は三人だけではなかった…"
      },
      "STMSN_05061M": {
        "ID": "STMSN_05061M",
        "Text": "お遣い"
      },
      "STMSN_05061M_EXPLANATION": {
        "ID": "STMSN_05061M_EXPLANATION",
        "Text": "突如、領域外へ引きずり出された釘崎\n新たな敵の正体と目的とは\nそして呪殺事件の真相は…"
      },
      "STMSN_05062M": {
        "ID": "STMSN_05062M",
        "Text": "共振"
      },
      "STMSN_05062M_EXPLANATION": {
        "ID": "STMSN_05062M_EXPLANATION",
        "Text": "伏黒は目の前の呪霊祓除に成功する\nだが領域は閉じず、”ある事件”に雷同し\n目覚めたモノがその姿を現す…"
      },
      "STMSN_05063M": {
        "ID": "STMSN_05063M",
        "Text": "限界の先"
      },
      "STMSN_05063M_EXPLANATION": {
        "ID": "STMSN_05063M_EXPLANATION",
        "Text": "目覚めた伏黒は”奥の手”を使おうとする\n「宝の持ち腐れだな」\n頭に宿儺の言葉が過り、彼は手を止めた"
      },
      "STMSN_05064M": {
        "ID": "STMSN_05064M",
        "Text": "兄弟"
      },
      "STMSN_05064M_EXPLANATION": {
        "ID": "STMSN_05064M_EXPLANATION",
        "Text": "指の気配を感じた壊相は\n交戦を避け、指の回収を優先する\nだが”背後”に虎杖が現れ態度が一変する…"
      },
      "STMSN_05065M": {
        "ID": "STMSN_05065M",
        "Text": "共犯"
      },
      "STMSN_05065M_EXPLANATION": {
        "ID": "STMSN_05065M_EXPLANATION",
        "Text": "「当たれば勝ちの術式　強いなオマエら」\n壊相達の術式で追い込まれる虎杖と釘崎\n果たして二人は絶望的な状況を覆せるのか…"
      },
      "STMSN_05066M": {
        "ID": "STMSN_05066M",
        "Text": "推薦"
      },
      "STMSN_05066M_EXPLANATION": {
        "ID": "STMSN_05066M_EXPLANATION",
        "Text": "呪術界を牽引していく存在である”1級”\nそれに虎杖を含めた東京校5名が推薦され…"
      },
      "STMSN_05067S": {
        "ID": "STMSN_05067S",
        "Text": "幕間の休日"
      },
      "STMSN_05067S_EXPLANATION": {
        "ID": "STMSN_05067S_EXPLANATION",
        "Text": "とある休日、釘崎と真希は\n五条に勧められたお店に出向くのだが\n五条のオススメに裏が無い訳が無く･･･"
      },
      "STMSN_05068S": {
        "ID": "STMSN_05068S",
        "Text": "イカサマ"
      },
      "STMSN_05068S_EXPLANATION": {
        "ID": "STMSN_05068S_EXPLANATION",
        "Text": "トランプで連勝する真人\n不信に思った漏瑚と花御はイカサマを疑う！\n否定する真人だが真相は…"
      },
      "STMSN_05069S": {
        "ID": "STMSN_05069S",
        "Text": "幕間の試験"
      },
      "STMSN_05069S_EXPLANATION": {
        "ID": "STMSN_05069S_EXPLANATION",
        "Text": "八十八橋の一件を聞いた狗巻とパンダは\n伏黒の成長を確認するために手合わせする！\n「どれくらい強くなったか見せてみろ」"
      },
      "STMSN_05070S": {
        "ID": "STMSN_05070S",
        "Text": "幕間の任務"
      },
      "STMSN_05070S_EXPLANATION": {
        "ID": "STMSN_05070S_EXPLANATION",
        "Text": "七海の任務へ勝手に同行する虎杖と五条\nいつもの気まぐれではなく\n五条には何か思惑があるようだった…"
      },
      "STMSN_06071M": {
        "ID": "STMSN_06071M",
        "Text": "呪いの子"
      },
      "STMSN_06071M_EXPLANATION": {
        "ID": "STMSN_06071M_EXPLANATION",
        "Text": "呪いに苦しみ、自身の死を望む少年…\n呪術師として、人として成長するために\n少年は呪術高専で呪いを学び、呪いと戦う"
      },
      "STMSN_06072M": {
        "ID": "STMSN_06072M",
        "Text": "呪いの女王"
      },
      "STMSN_06072M_EXPLANATION": {
        "ID": "STMSN_06072M_EXPLANATION",
        "Text": "真希は高専に来た理由を乙骨に問う\n少年は答える　自身の望みを…"
      },
      "STMSN_06073S": {
        "ID": "STMSN_06073S",
        "Text": "心配"
      },
      "STMSN_06073S_EXPLANATION": {
        "ID": "STMSN_06073S_EXPLANATION",
        "Text": "狗巻、パンダもペア実習に挑む！\n「棘　転校生のこと気にしてんのか？」\n狗巻が乙骨を気にかける理由とは…"
      },
      "STMSN_06074M": {
        "ID": "STMSN_06074M",
        "Text": "解呪"
      },
      "STMSN_06074M_EXPLANATION": {
        "ID": "STMSN_06074M_EXPLANATION",
        "Text": "実習を経て、乙骨は里香の解呪を決意する\n「これを使うといい」\n解呪のために五条から手渡されたのは…"
      },
      "STMSN_06075M": {
        "ID": "STMSN_06075M",
        "Text": "鍛錬"
      },
      "STMSN_06075M_EXPLANATION": {
        "ID": "STMSN_06075M_EXPLANATION",
        "Text": "解呪のために刀の使い方を教わる乙骨\n五条との特訓で終わり…ではなかった！\nパワー特訓の相手に選ばれたのは…"
      },
      "STMSN_06076S": {
        "ID": "STMSN_06076S",
        "Text": "共闘実習"
      },
      "STMSN_06076S_EXPLANATION": {
        "ID": "STMSN_06076S_EXPLANATION",
        "Text": "真希のケガが完治した記念に\nペア形式の対戦大会が開催！\n気になるペアの結果は…"
      },
      "STMSN_06077M": {
        "ID": "STMSN_06077M",
        "Text": "罰の有無"
      },
      "STMSN_06077M_EXPLANATION": {
        "ID": "STMSN_06077M_EXPLANATION",
        "Text": "季節が巡って夏となった頃\n授業、特訓を通じて\n乙骨と真希達の距離は少しずつ縮まっていた"
      },
      "STMSN_06078M": {
        "ID": "STMSN_06078M",
        "Text": "黒く黒く"
      },
      "STMSN_06078M_EXPLANATION": {
        "ID": "STMSN_06078M_EXPLANATION",
        "Text": "狗巻の任務に乙骨も同行することになる…\nだが乙骨は意思疎通ができない狗巻を\nまだ少し怖いと感じており…"
      },
      "STMSN_06079S": {
        "ID": "STMSN_06079S",
        "Text": "共闘実習 -弐-"
      },
      "STMSN_06079S_EXPLANATION": {
        "ID": "STMSN_06079S_EXPLANATION",
        "Text": "商店街の一件で距離が縮まった狗巻と乙骨\n再び開催されたペア実習に二人で挑む！"
      },
      "STMSN_06080M": {
        "ID": "STMSN_06080M",
        "Text": "弱者に罰を"
      },
      "STMSN_06080M_EXPLANATION": {
        "ID": "STMSN_06080M_EXPLANATION",
        "Text": "呪詛師　呪いを用いて人の世に仇なす者…\n中でも最悪と評される夏油が高専に現れる\n彼は高らかに宣言する　自身の”計画”を…"
      },
      "STMSN_06081M": {
        "ID": "STMSN_06081M",
        "Text": "旧知"
      },
      "STMSN_06081M_EXPLANATION": {
        "ID": "STMSN_06081M_EXPLANATION",
        "Text": "五条は未熟だった学生の頃を思い返す\n夏油と共に過ごした日々…\nそして決別した日を…"
      },
      "STMSN_06082M": {
        "ID": "STMSN_06082M",
        "Text": "強く真っ直ぐ"
      },
      "STMSN_06082M_EXPLANATION": {
        "ID": "STMSN_06082M_EXPLANATION",
        "Text": "夏油の言葉について考える乙骨に\n真希が自身の生い立ちについて話す\nそんな二人の元へ毒牙が近付く…"
      },
      "STMSN_06083M": {
        "ID": "STMSN_06083M",
        "Text": "死守"
      },
      "STMSN_06083M_EXPLANATION": {
        "ID": "STMSN_06083M_EXPLANATION",
        "Text": "五条は前線に出てこない夏油に違和感を覚え\n狗巻、パンダを高専に”送る”\n「二人を守れ　悪いが死守だ！！」"
      },
      "STMSN_06084M": {
        "ID": "STMSN_06084M",
        "Text": "完全顕現"
      },
      "STMSN_06084M_EXPLANATION": {
        "ID": "STMSN_06084M_EXPLANATION",
        "Text": "乙骨は真希達の無残な姿を目撃…\n「ぶっ殺してやる」\n最悪の呪詛師に立ち向かう"
      },
      "STMSN_06085M": {
        "ID": "STMSN_06085M",
        "Text": "眩しい闇"
      },
      "STMSN_06085M_EXPLANATION": {
        "ID": "STMSN_06085M_EXPLANATION",
        "Text": "自らの存在をかけ戦う者\n大義のために戦う者\n二人の最後の戦いが始まる…"
      },
      "STMSN_06086M": {
        "ID": "STMSN_06086M",
        "Text": "ありがとう"
      },
      "STMSN_06086M_EXPLANATION": {
        "ID": "STMSN_06086M_EXPLANATION",
        "Text": "乙骨が目覚めると心配そうに見つめる真希達\nそして里香の姿があった\n自身を贄とした乙骨に対し里香は…"
      },
      "STMSN_06087S": {
        "ID": "STMSN_06087S",
        "Text": "此れから"
      },
      "STMSN_06087S_EXPLANATION": {
        "ID": "STMSN_06087S_EXPLANATION",
        "Text": "里香の解呪からしばらく経った頃\n乙骨の”今”の力を確認した五条は\nあるお願いがあると言い…"
      },
      "STMSN_06088S": {
        "ID": "STMSN_06088S",
        "Text": "師弟"
      },
      "STMSN_06088S_EXPLANATION": {
        "ID": "STMSN_06088S_EXPLANATION",
        "Text": "これはあったかもしれない戦い…\n五条先生に教え子達が挑む\n最強を超えろ！若人達！"
      },
      "STMSN_06089S": {
        "ID": "STMSN_06089S",
        "Text": "特級の名を冠する呪い"
      },
      "STMSN_06089S_EXPLANATION": {
        "ID": "STMSN_06089S_EXPLANATION",
        "Text": "様々な畏怖から生まれ堕ちた\n最上位の呪い達…\n彼らは本能、欲望、目的のために躍動する"
      },
      "STMSN_08090M": {
        "ID": "STMSN_08090M",
        "Text": "懐玉"
      },
      "STMSN_08090M_EXPLANATION": {
        "ID": "STMSN_08090M_EXPLANATION",
        "Text": "若き日の五条と夏油\n最強の二人の\nもう戻れない青い春が始まる"
      },
      "STMSN_08091M": {
        "ID": "STMSN_08091M",
        "Text": "術師殺し"
      },
      "STMSN_08091M_EXPLANATION": {
        "ID": "STMSN_08091M_EXPLANATION",
        "Text": "高専の結界に入った瞬間を狙い\n伏黒甚爾が襲いかかる\n予想を超える甚爾の秘密とは"
      },
      "STMSN_08092M": {
        "ID": "STMSN_08092M",
        "Text": "潰える願い"
      },
      "STMSN_08092M_EXPLANATION": {
        "ID": "STMSN_08092M_EXPLANATION",
        "Text": "天元との同化直前に\n天内は自分の気持ちに従おうとする\n夏油が叶えさせようとした、その願いは…"
      },
      "STMSN_08093M": {
        "ID": "STMSN_08093M",
        "Text": "覚醒"
      },
      "STMSN_08093M_EXPLANATION": {
        "ID": "STMSN_08093M_EXPLANATION",
        "Text": "五条は死んではいなかった\n死に際で掴んだ呪力操作の秘奥と共に\n再び甚爾の前に立ちはだかる"
      },
      "STMSN_08094M": {
        "ID": "STMSN_08094M",
        "Text": "玉折"
      },
      "STMSN_08094M_EXPLANATION": {
        "ID": "STMSN_08094M_EXPLANATION",
        "Text": "最強になった五条\n一人になった夏油\n分かれてゆく二人の道"
      },
      "STMSN_09095M": {
        "ID": "STMSN_09095M",
        "Text": "宵祭り"
      },
      "STMSN_09095M_EXPLANATION": {
        "ID": "STMSN_09095M_EXPLANATION",
        "Text": "呪霊側と通じていたメカ丸こと与幸吉\n“皆に会う”その願いを叶えるため\nこれまでの全てを懸けて真人と戦う"
      },
      "STMSN_09096M": {
        "ID": "STMSN_09096M",
        "Text": "渋谷事変　開門"
      },
      "STMSN_09096M_EXPLANATION": {
        "ID": "STMSN_09096M_EXPLANATION",
        "Text": "２０１８年１０月３１日\nハロウィンの渋谷で呪詛師達が\nある計画を実行に移す"
      },
      "STMSN_09097M": {
        "ID": "STMSN_09097M",
        "Text": "対峙"
      },
      "STMSN_09097M_EXPLANATION": {
        "ID": "STMSN_09097M_EXPLANATION",
        "Text": "渋谷に到着した五条悟を\n待ち受ける敵と罠\n五条と呪霊たちの戦いが始まる"
      },
      "STMSN_09098M": {
        "ID": "STMSN_09098M",
        "Text": "獄門疆"
      },
      "STMSN_09098M_EXPLANATION": {
        "ID": "STMSN_09098M_EXPLANATION",
        "Text": "五条悟を封印すべく準備された獄門疆\nその開門と同時に現れたのは\n意外な人物だった"
      },
      "STMSN_09099M": {
        "ID": "STMSN_09099M",
        "Text": "昏乱"
      },
      "STMSN_09099M_EXPLANATION": {
        "ID": "STMSN_09099M_EXPLANATION",
        "Text": "五条封印をミニメカ丸によって\n知らされた虎杖は　局面を打開するため\n七海と合流しようとする"
      },
      "STMSN_09100M": {
        "ID": "STMSN_09100M",
        "Text": "降霊"
      },
      "STMSN_09100M_EXPLANATION": {
        "ID": "STMSN_09100M_EXPLANATION",
        "Text": "呪詛師たちは\"目立つ場所\"で\n\"帳\"の基を守っていると考えた虎杖たちは\n高くそびえ立つビルの屋上を目指す"
      },
      "STMSN_09101M": {
        "ID": "STMSN_09101M",
        "Text": "鈍刀"
      },
      "STMSN_09101M_EXPLANATION": {
        "ID": "STMSN_09101M_EXPLANATION",
        "Text": "負傷した釘崎と新田の前に現れた七海は\n重面への怒りを露に拳を振り上げた\n釘崎はその圧倒的な力を目の当たりにする"
      },
      "STMSN_09102M": {
        "ID": "STMSN_09102M",
        "Text": "赫鱗"
      },
      "STMSN_09102M_EXPLANATION": {
        "ID": "STMSN_09102M_EXPLANATION",
        "Text": "渋谷駅地下に辿り着いた虎杖に\n脹相が襲い掛かり問いかける\n「弟は最期に何か言い遺したか？」　"
      },
      "STMSN_09103M": {
        "ID": "STMSN_09103M",
        "Text": "揺蕩"
      },
      "STMSN_09103M_EXPLANATION": {
        "ID": "STMSN_09103M_EXPLANATION",
        "Text": "陀艮の領域に入った直毘人、七海、真希\n大海のごとく底知れぬ攻撃の波に\n呪術師たちは疲弊してゆく"
      },
      "STMSN_09104M": {
        "ID": "STMSN_09104M",
        "Text": "霹靂"
      },
      "STMSN_09104M_EXPLANATION": {
        "ID": "STMSN_09104M_EXPLANATION",
        "Text": "虎杖から身体の主導権を奪い目覚めた\n両面宿儺は“縛り”を結べという\n漏瑚の提案を一蹴し、勝負を仕掛ける"
      },
      "STMSN_09105M": {
        "ID": "STMSN_09105M",
        "Text": "暴走"
      },
      "STMSN_09105M_EXPLANATION": {
        "ID": "STMSN_09105M_EXPLANATION",
        "Text": "突如現れた謎の男は次なる標的を\n伏黒に据える　その圧倒的な膂力を前に\n窮地の伏黒は捨て身の覚悟で勝負に出る"
      },
      "STMSN_09106M": {
        "ID": "STMSN_09106M",
        "Text": "異戒神将"
      },
      "STMSN_09106M_EXPLANATION": {
        "ID": "STMSN_09106M_EXPLANATION",
        "Text": "重面春太の凶刃を受け危殆に瀕した伏黒は\n自身の術式「十種影法術」の内\nある式神を呼び出し調伏の儀を始める"
      },
      "STMSN_09107M": {
        "ID": "STMSN_09107M",
        "Text": "理非"
      },
      "STMSN_09107M_EXPLANATION": {
        "ID": "STMSN_09107M_EXPLANATION",
        "Text": "深手を負いながらも渋谷を彷徨い戦う\n七海の前に真人が現れる　二人の元へ\n駆け付けた虎杖が目にしたものは…"
      },
      "STMSN_09108M": {
        "ID": "STMSN_09108M",
        "Text": "同心"
      },
      "STMSN_09108M_EXPLANATION": {
        "ID": "STMSN_09108M_EXPLANATION",
        "Text": "戦線へ戻った釘崎は真人と遭遇\n攻撃が通じない真人に対して\n釘崎には勝算があった"
      },
      "STMSN_09109M": {
        "ID": "STMSN_09109M",
        "Text": "喪心"
      },
      "STMSN_09109M_EXPLANATION": {
        "ID": "STMSN_09109M_EXPLANATION",
        "Text": "真人に大きな爪痕を残した釘崎も\n虎杖の前で凶刃に倒れてしまう　失意に\n自己を失う虎杖、だがそこへあの男が現れる"
      },
      "STMSN_09110M": {
        "ID": "STMSN_09110M",
        "Text": "遺志"
      },
      "STMSN_09110M_EXPLANATION": {
        "ID": "STMSN_09110M_EXPLANATION",
        "Text": "仲間から託されたものを胸に立ち上がる虎杖\nそして虎杖、真人に続いて東堂も黒閃を決め\n三者の戦いは熾烈を極めていく"
      },
      "STMSN_09111M": {
        "ID": "STMSN_09111M",
        "Text": "変身"
      },
      "STMSN_09111M_EXPLANATION": {
        "ID": "STMSN_09111M_EXPLANATION",
        "Text": "虎杖との死闘の果て\n真人は遂に己の魂の本質を摑む\n変貌した真人が虎杖の前に立ち塞がる"
      },
      "STMSN_09112M": {
        "ID": "STMSN_09112M",
        "Text": "離愁"
      },
      "STMSN_09112M_EXPLANATION": {
        "ID": "STMSN_09112M_EXPLANATION",
        "Text": "京都校の面々が渋谷へと向かう途次\nその車中でメカ丸は与幸吉として\n三輪への最期の言葉を遺す"
      },
      "STMSN_09113M": {
        "ID": "STMSN_09113M",
        "Text": "血戦"
      },
      "STMSN_09113M_EXPLANATION": {
        "ID": "STMSN_09113M_EXPLANATION",
        "Text": "兄弟を殺させるよう仕向けた男の\n正体に気付き怒りを露にする脹相は\n兄としての全力で戦いに挑む"
      },
      "STMSN_09114M": {
        "ID": "STMSN_09114M",
        "Text": "渋谷事変　閉門"
      },
      "STMSN_09114M_EXPLANATION": {
        "ID": "STMSN_09114M_EXPLANATION",
        "Text": "加茂憲倫と呼ばれた男が語る\nこれからの世界\n恐るべき混沌と更なる戦いの始まりだった"
      },
      "STR_DEMO_LABEL_0001": {
        "ID": "STR_DEMO_LABEL_0001",
        "Text": "原作　「呪術廻戦」芥見下々"
      },
      "STR_DEMO_LABEL_0002": {
        "ID": "STR_DEMO_LABEL_0002",
        "Text": "（集英社「週刊少年ジャンプ」連載）"
      },
      "STR_DEMO_LABEL_0003": {
        "ID": "STR_DEMO_LABEL_0003",
        "Text": "制作　バンダイナムコエンターテインメント"
      },
      "STR_STDM_SS_001": {
        "ID": "STR_STDM_SS_001",
        "Text": "伏黒が苦手な物"
      },
      "STR_STDM_SS_002": {
        "ID": "STR_STDM_SS_002",
        "Text": "在りし日の…"
      },
      "STR_STDM_SS_003": {
        "ID": "STR_STDM_SS_003",
        "Text": "釘崎の想い"
      },
      "STR_STDM_SS_004": {
        "ID": "STR_STDM_SS_004",
        "Text": "GTゴジョー"
      },
      "STR_STDM_SS_005": {
        "ID": "STR_STDM_SS_005",
        "Text": "恒例行事"
      },
      "STR_STDM_SS_006": {
        "ID": "STR_STDM_SS_006",
        "Text": "七海の手料理"
      },
      "STR_STDM_SS_007": {
        "ID": "STR_STDM_SS_007",
        "Text": "社会とは…"
      },
      "STR_STDM_SS_008": {
        "ID": "STR_STDM_SS_008",
        "Text": "男子たるもの！"
      },
      "STR_STDM_SS_009": {
        "ID": "STR_STDM_SS_009",
        "Text": "リサーチ"
      },
      "STR_STDM_SS_010": {
        "ID": "STR_STDM_SS_010",
        "Text": "教えて！ナナミン！"
      },
      "STR_STDM_SS_011": {
        "ID": "STR_STDM_SS_011",
        "Text": "似顔絵バトル"
      },
      "STR_STDM_SS_012": {
        "ID": "STR_STDM_SS_012",
        "Text": "ブラザー"
      },
      "STR_STDM_SS_013": {
        "ID": "STR_STDM_SS_013",
        "Text": "次の世代"
      },
      "STR_STDM_SS_014": {
        "ID": "STR_STDM_SS_014",
        "Text": "伏黒の勧め"
      },
      "STR_STDM_SS_015": {
        "ID": "STR_STDM_SS_015",
        "Text": "鍛え方…？"
      },
      "STR_STDM_SS_016": {
        "ID": "STR_STDM_SS_016",
        "Text": "武の才"
      },
      "STR_STDM_SS_017": {
        "ID": "STR_STDM_SS_017",
        "Text": "狗巻セレクト"
      },
      "STR_STDM_SS_018": {
        "ID": "STR_STDM_SS_018",
        "Text": "先輩の厚意"
      },
      "STR_STDM_SS_019": {
        "ID": "STR_STDM_SS_019",
        "Text": "目論み"
      },
      "STR_STDM_SS_020": {
        "ID": "STR_STDM_SS_020",
        "Text": "伏黒の好み"
      },
      "STR_STDM_SS_021": {
        "ID": "STR_STDM_SS_021",
        "Text": "フィーリング"
      },
      "STR_STDM_SS_022": {
        "ID": "STR_STDM_SS_022",
        "Text": "スイーツ呪術師"
      },
      "STR_STDM_SS_023": {
        "ID": "STR_STDM_SS_023",
        "Text": "美の秘訣"
      },
      "STR_STDM_SS_024": {
        "ID": "STR_STDM_SS_024",
        "Text": "コーディネーター釘崎"
      },
      "STR_STDM_SS_025": {
        "ID": "STR_STDM_SS_025",
        "Text": "狗巻語を会得？"
      },
      "STR_STDM_SS_026": {
        "ID": "STR_STDM_SS_026",
        "Text": "イメチェン"
      },
      "STR_STDM_SS_027": {
        "ID": "STR_STDM_SS_027",
        "Text": "パンダはパンダ？"
      },
      "STR_STDM_SS_028": {
        "ID": "STR_STDM_SS_028",
        "Text": "パンダはクッション？"
      },
      "STR_STDM_SS_029": {
        "ID": "STR_STDM_SS_029",
        "Text": "社会人として"
      },
      "STR_STDM_SS_030": {
        "ID": "STR_STDM_SS_030",
        "Text": "五条先生のバイブル"
      },
      "STR_STDM_SS_031": {
        "ID": "STR_STDM_SS_031",
        "Text": "昔と今"
      },
      "STR_STDM_SS_032": {
        "ID": "STR_STDM_SS_032",
        "Text": "花御の憂心"
      },
      "STR_STDM_SS_033": {
        "ID": "STR_STDM_SS_033",
        "Text": "新入り"
      },
      "STR_STDM_SS_034": {
        "ID": "STR_STDM_SS_034",
        "Text": "感謝"
      },
      "STR_STDM_SS_035": {
        "ID": "STR_STDM_SS_035",
        "Text": "闇（より黒い）鍋"
      },
      "STR_STDM_SS_036": {
        "ID": "STR_STDM_SS_036",
        "Text": "気懸り"
      },
      "STR_STDM_SS_037": {
        "ID": "STR_STDM_SS_037",
        "Text": "いつの間に！"
      },
      "STR_STDM_SS_038": {
        "ID": "STR_STDM_SS_038",
        "Text": "杞憂"
      },
      "STR_STDM_SS_039": {
        "ID": "STR_STDM_SS_039",
        "Text": "パパンダ"
      },
      "STR_STDM_SS_040": {
        "ID": "STR_STDM_SS_040",
        "Text": "友達"
      },
      "STR_STDM_SS_041": {
        "ID": "STR_STDM_SS_041",
        "Text": "拒否反応！？"
      },
      "STR_STDM_SS_042": {
        "ID": "STR_STDM_SS_042",
        "Text": "警告"
      },
      "STR_STDM_SS_043": {
        "ID": "STR_STDM_SS_043",
        "Text": "日頃の行い"
      },
      "STR_STDM_SS_044": {
        "ID": "STR_STDM_SS_044",
        "Text": "次こそは"
      },
      "STR_STDM_SS_045": {
        "ID": "STR_STDM_SS_045",
        "Text": "虎杖の持ち味"
      }
    }
  }
