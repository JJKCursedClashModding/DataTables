      "TUT_INGAME_LABEL_0006": {
        "ID": "TUT_INGAME_LABEL_0006",
        "Text": "关于<GLO=GLS_GAME_WORDS_1307>"
      },
      "TUT_INGAME_MESSAGE_0006": {
        "ID": "TUT_INGAME_MESSAGE_0006",
        "Text": "用诅咒祓除诅咒的攻击就是「<GLO=GLS_GAME_WORDS_1307>」\n是对敌人造成伤害的基本手段\n\n<img id=\"CursedEnergyAttack_1\"/>和<img id=\"CursedEnergyAttack_2\"/>可以各使出不同的<GLO=GLS_GAME_WORDS_1307>\n要使用这些招式，需要让<GLO=GLS_GAME_WORDS_1503>量表累积<GLO=GLS_GAME_WORDS_1503>\n<GLO=GLS_GAME_WORDS_1503>量表在使用过后会随时间<GLO=GLS_GAME_WORDS_1819>"
      },
      "TUT_INGAME_LABEL_0007": {
        "ID": "TUT_INGAME_LABEL_0007",
        "Text": "关于<GLO=GLS_GAME_WORDS_1401>"
