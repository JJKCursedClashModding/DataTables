    "Rows": {
      "CP_010_STAMP_001": {
        "ID": "CP_010_STAMP_001",
        "Text": "¡Es un honor!"
      },
      "CP_010_STAMP_002": {
        "ID": "CP_010_STAMP_002",
        "Text": "¡Te lo agradezco!"
      },
      "CP_020_STAMP_001": {
        "ID": "CP_020_STAMP_001",
        "Text": "Así se hace. Sólo esfuérzate un poco más."
      },
      "CP_030_STAMP_001": {
        "ID": "CP_030_STAMP_001",
        "Text": "Tampoco quiero perder."
      },
      "CP_030_STAMP_002": {
        "ID": "CP_030_STAMP_002",
        "Text": "Te lo mostraré."
      },
      "CP_040_STAMP_001": {
        "ID": "CP_040_STAMP_001",
        "Text": "¿Problemas para dormir?"
      },
      "CP_040_STAMP_002": {
        "ID": "CP_040_STAMP_002",
        "Text": "Lo logré."
      },
      "CP_050_STAMP_001": {
        "ID": "CP_050_STAMP_001",
        "Text": "Hola."
      },
      "CP_050_STAMP_002": {
        "ID": "CP_050_STAMP_002",
        "Text": "¡Hurra!"
      },
      "CP_060_STAMP_001": {
        "ID": "CP_060_STAMP_001",
        "Text": "No me contendré, lo sabes."
      },
      "CP_070_STAMP_001": {
        "ID": "CP_070_STAMP_001",
        "Text": "Atún de aleta amarilla. Hueva de camarón."
      },
      "CP_080_STAMP_001": {
        "ID": "CP_080_STAMP_001",
        "Text": "Soy Panda. Es un gustirijillo."
      },
      "CP_090_STAMP_001": {
        "ID": "CP_090_STAMP_001",
        "Text": "Trabajar apesta."
      },
      "CP_100_STAMP_001": {
        "ID": "CP_100_STAMP_001",
        "Text": "¿Qué tipo de mujeres\nte gustan?"
      },
      "CP_110_STAMP_001": {
        "ID": "CP_110_STAMP_001",
        "Text": "¡Hagamos nuestro mejor esfuerzo!"
      },
      "CP_120_STAMP_001": {
        "ID": "CP_120_STAMP_001",
        "Text": "Tomémonos una foto."
      },
      "CP_130_STAMP_001": {
        "ID": "CP_130_STAMP_001",
        "Text": "Te estoy eternamente agradecido."
      },
      "CP_140_STAMP_001": {
        "ID": "CP_140_STAMP_001",
        "Text": "¿Qué fue eso?"
      },
      "CP_150_STAMP_001": {
        "ID": "CP_150_STAMP_001",
        "Text": "Estoy disfrutando de esta pelea."
      },
      "CP_160_STAMP_001": {
        "ID": "CP_160_STAMP_001",
        "Text": "¡Los voy a matar!"
      },
      "CP_051_STAMP_001": {
        "ID": "CP_051_STAMP_001",
        "Text": "¿Estás llorando?"
      },
      "CP_051_STAMP_002": {
        "ID": "CP_051_STAMP_002",
        "Text": "En el cielo y en la tierra, soy el único que merece veneración."
      },
      "CP_121_STAMP_001": {
        "ID": "CP_121_STAMP_001",
        "Text": "Ayudar al débil y contener al fuerte."
      },
      "CP_121_STAMP_002": {
        "ID": "CP_121_STAMP_002",
        "Text": "Somos los más fuertes."
      },
      "CP_170_STAMP_001": {
        "ID": "CP_170_STAMP_001",
        "Text": "¡Me alegra que haya asestado!"
      },
      "CP_170_STAMP_002": {
        "ID": "CP_170_STAMP_002",
        "Text": "¡Eres tan egoísta!"
      },
      "CP_170_STAMP_003": {
        "ID": "CP_170_STAMP_003",
        "Text": "Oh, vaya, pobre..."
      },
      "CP_180_STAMP_001": {
        "ID": "CP_180_STAMP_001",
        "Text": "Resiste, Momo. ¡Eres una ternura!"
      },
      "CP_180_STAMP_002": {
        "ID": "CP_180_STAMP_002",
        "Text": "Eso no es nada tierno..."
      },
      "CP_190_STAMP_001": {
        "ID": "CP_190_STAMP_001",
        "Text": "No puedo perder. Me rehúso."
      },
      "CP_190_STAMP_002": {
        "ID": "CP_190_STAMP_002",
        "Text": "Tomé esta decisión por mí mismo."
      },
      "CP_200_STAMP_001": {
        "ID": "CP_200_STAMP_001",
        "Text": "Se terminó el espectáculo. Todos a sus casas."
      },
      "CP_200_STAMP_002": {
        "ID": "CP_200_STAMP_002",
        "Text": "La pelea apenas comienza."
      },
      "CP_210_STAMP_001": {
        "ID": "CP_210_STAMP_001",
        "Text": "¿No podemos llevarnos bien?"
      },
      "CP_210_STAMP_002": {
        "ID": "CP_210_STAMP_002",
        "Text": "¡Hola! ¡Aquí Miwa la inútil!"
      },
      "CP_220_STAMP_001": {
        "ID": "CP_220_STAMP_001",
        "Text": "Pacto celestial. ¿Lo conoces?"
      },
      "CP_220_STAMP_002": {
        "ID": "CP_220_STAMP_002",
        "Text": "¿Moriste...?"
      },
      "CP_230_STAMP_001": {
        "ID": "CP_230_STAMP_001",
        "Text": "¡Cumpliré mi deber como el hermano mayor con toda mi fuerza!"
      },
      "CP_230_STAMP_002": {
        "ID": "CP_230_STAMP_002",
        "Text": "¡Soy el hermano mayor de Yuji!"
      },
      "CP_240_STAMP_001": {
        "ID": "CP_240_STAMP_001",
        "Text": "¿Morirías por mí?"
      },
      "CP_240_STAMP_002": {
        "ID": "CP_240_STAMP_002",
        "Text": "Claro que estoy del lado del dinero."
      },
      "CP_270_STAMP_001": {
        "ID": "CP_270_STAMP_001",
        "Text": "No te lo permitiré."
      },
      "CP_270_STAMP_002": {
        "ID": "CP_270_STAMP_002",
        "Text": "Esto te costará."
      }
    }
  }
]