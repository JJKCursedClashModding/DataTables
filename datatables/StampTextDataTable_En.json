      "CP_010_STAMP_001": {
        "ID": "CP_010_STAMP_001",
        "Text": "This is an honor."
      },
      "CP_010_STAMP_002": {
        "ID": "CP_010_STAMP_002",
        "Text": "Thank you for that."
      },
      "CP_020_STAMP_001": {
        "ID": "CP_020_STAMP_001",
        "Text": "That's the way.\nJust try a little harder."
      },
      "CP_030_STAMP_001": {
        "ID": "CP_030_STAMP_001",
        "Text": "I don't want to lose either."
      },
      "CP_030_STAMP_002": {
        "ID": "CP_030_STAMP_002",
        "Text": "I'll show you."
      },
      "CP_040_STAMP_001": {
        "ID": "CP_040_STAMP_001",
        "Text": "Trouble sleeping?"
      },
      "CP_040_STAMP_002": {
        "ID": "CP_040_STAMP_002",
        "Text": "Nailed it."
      },
      "CP_050_STAMP_001": {
        "ID": "CP_050_STAMP_001",
        "Text": "Hey there."
      },
      "CP_050_STAMP_002": {
        "ID": "CP_050_STAMP_002",
        "Text": "Yay!"
      },
      "CP_060_STAMP_001": {
        "ID": "CP_060_STAMP_001",
        "Text": "I won't hold back, you know."
      },
      "CP_070_STAMP_001": {
        "ID": "CP_070_STAMP_001",
        "Text": "Yellowfin tuna. Prawn roe."
      },
      "CP_080_STAMP_001": {
        "ID": "CP_080_STAMP_001",
        "Text": "I'm Panda. Nice to meetcha."
      },
      "CP_090_STAMP_001": {
        "ID": "CP_090_STAMP_001",
        "Text": "Working sucks."
      },
      "CP_100_STAMP_001": {
        "ID": "CP_100_STAMP_001",
        "Text": "What kind of woman\nis your type?"
      },
      "CP_110_STAMP_001": {
        "ID": "CP_110_STAMP_001",
        "Text": "Let's do our best!"
      },
      "CP_120_STAMP_001": {
        "ID": "CP_120_STAMP_001",
        "Text": "Let's take a photo together."
      },
      "CP_130_STAMP_001": {
        "ID": "CP_130_STAMP_001",
        "Text": "I'm just so grateful to you."
      },
      "CP_140_STAMP_001": {
        "ID": "CP_140_STAMP_001",
        "Text": "What just happened?"
      },
      "CP_150_STAMP_001": {
        "ID": "CP_150_STAMP_001",
        "Text": "I'm enjoying a fight."
      },
      "CP_160_STAMP_001": {
        "ID": "CP_160_STAMP_001",
        "Text": "Death by Wasp!"
      },
      "CP_051_STAMP_001": {
        "ID": "CP_051_STAMP_001",
        "Text": "You crying?"
      },
      "CP_051_STAMP_002": {
        "ID": "CP_051_STAMP_002",
        "Text": "Throughout heaven and earth, I alone am the honored one."
      },
      "CP_121_STAMP_001": {
        "ID": "CP_121_STAMP_001",
        "Text": "Help the weak, and discourage the strong."
      },
      "CP_121_STAMP_002": {
        "ID": "CP_121_STAMP_002",
        "Text": "We're the strongest."
      },
      "CP_170_STAMP_001": {
        "ID": "CP_170_STAMP_001",
        "Text": "Glad that one landed!"
      },
      "CP_170_STAMP_002": {
        "ID": "CP_170_STAMP_002",
        "Text": "You're so selfish!"
      },
      "CP_170_STAMP_003": {
        "ID": "CP_170_STAMP_003",
        "Text": "Oh boy, poor thing..."
      },
      "CP_180_STAMP_001": {
        "ID": "CP_180_STAMP_001",
        "Text": "Hang in there, me. You're the cutest one!"
      },
      "CP_180_STAMP_002": {
        "ID": "CP_180_STAMP_002",
        "Text": "Not cute at all..."
      },
      "CP_190_STAMP_001": {
        "ID": "CP_190_STAMP_001",
        "Text": "I can't afford to lose. I refuse to lose."
      },
      "CP_190_STAMP_002": {
        "ID": "CP_190_STAMP_002",
        "Text": "I made this decision for myself."
      },
      "CP_200_STAMP_001": {
        "ID": "CP_200_STAMP_001",
        "Text": "Okay, job's done. You're free to go now."
      },
      "CP_200_STAMP_002": {
        "ID": "CP_200_STAMP_002",
        "Text": "Our fight is just getting started."
      },
      "CP_210_STAMP_001": {
        "ID": "CP_210_STAMP_001",
        "Text": "Can't we all just get along?"
      },
      "CP_210_STAMP_002": {
        "ID": "CP_210_STAMP_002",
        "Text": "Hello! Useless Miwa here!"
      },
      "CP_220_STAMP_001": {
        "ID": "CP_220_STAMP_001",
        "Text": "Heavenly Pact. Have you heard of it?"
      },
      "CP_220_STAMP_002": {
        "ID": "CP_220_STAMP_002",
        "Text": "Dead, are you...?"
      },
      "CP_230_STAMP_001": {
        "ID": "CP_230_STAMP_001",
        "Text": "I will fulfill my duty as the older brother using all my strength!"
      },
      "CP_230_STAMP_002": {
        "ID": "CP_230_STAMP_002",
        "Text": "I'm Yuji's big brother!"
      },
      "CP_240_STAMP_001": {
        "ID": "CP_240_STAMP_001",
        "Text": "Perish for me, would you?"
      },
      "CP_240_STAMP_002": {
        "ID": "CP_240_STAMP_002",
        "Text": "I'm on the side of money, of course."
      },
      "CP_270_STAMP_001": {
        "ID": "CP_270_STAMP_001",
        "Text": "I won't let you."
      },
      "CP_270_STAMP_002": {
        "ID": "CP_270_STAMP_002",
        "Text": "This is going to cost you."
      }
    }
  }
