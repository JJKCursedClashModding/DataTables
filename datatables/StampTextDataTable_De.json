[
  {
    "Type": "DataTable",
    "Name": "StampTextDataTable_De",
    "Flags": "RF_Public | RF_Standalone | RF_Transactional | RF_WasLoaded | RF_LoadCompleted",
    "Class": "UScriptClass'DataTable'",
    "Properties": {
      "RowStruct": {
        "ObjectName": "Class'GameDataTableRow_GameText'",
        "ObjectPath": "/Script/Abrams"
      },
      "ImportKeyField": "Id"
    },
    "Rows": {
      "CP_010_STAMP_001": {
        "ID": "CP_010_STAMP_001",
        "Text": "Es ist mir eine Ehre."
      },
      "CP_010_STAMP_002": {
        "ID": "CP_010_STAMP_002",
        "Text": "Danke dafür."
      },
      "CP_020_STAMP_001": {
        "ID": "CP_020_STAMP_001",
        "Text": "Genau so. Gib dir noch mehr Mühe."
      },
      "CP_030_STAMP_001": {
        "ID": "CP_030_STAMP_001",
        "Text": "Ich will auch nicht verlieren."
      },
      "CP_030_STAMP_002": {
        "ID": "CP_030_STAMP_002",
        "Text": "Ich zeig's dir."
      },
      "CP_040_STAMP_001": {
        "ID": "CP_040_STAMP_001",
        "Text": "Kannst du nicht schlafen?"
      },
      "CP_040_STAMP_002": {
        "ID": "CP_040_STAMP_002",
        "Text": "Volltreffer."
      },
      "CP_050_STAMP_001": {
        "ID": "CP_050_STAMP_001",
        "Text": "Hey."
      },
      "CP_050_STAMP_002": {
        "ID": "CP_050_STAMP_002",
        "Text": "Yeah!"
      },
      "CP_060_STAMP_001": {
        "ID": "CP_060_STAMP_001",
        "Text": "Ich werde mich nicht \nzurückhalten, okay?"
      },
      "CP_070_STAMP_001": {
        "ID": "CP_070_STAMP_001",
        "Text": "Gelbflossenthunfisch. Krabbenlaich."
      },
      "CP_080_STAMP_001": {
        "ID": "CP_080_STAMP_001",
        "Text": "Ich bin Panda. Schön, dich\nkennenzulernen."
      },
      "CP_090_STAMP_001": {
        "ID": "CP_090_STAMP_001",
        "Text": "Arbeit nervt."
      },
      "CP_100_STAMP_001": {
        "ID": "CP_100_STAMP_001",
        "Text": "Auf was für Frauen stehst du?"
      },
      "CP_110_STAMP_001": {
        "ID": "CP_110_STAMP_001",
        "Text": "Geben wir unser Bestes!"
      },
      "CP_120_STAMP_001": {
        "ID": "CP_120_STAMP_001",
        "Text": "Lass uns ein Foto \nzusammen machen."
      },
      "CP_130_STAMP_001": {
        "ID": "CP_130_STAMP_001",
        "Text": "Ich bin dir so was von dankbar."
      },
      "CP_140_STAMP_001": {
        "ID": "CP_140_STAMP_001",
        "Text": "Was ist gerade passiert?"
      },
      "CP_150_STAMP_001": {
        "ID": "CP_150_STAMP_001",
        "Text": "Ich empfinde gerade wirklich \nFreude am Kampf."
      },
      "CP_160_STAMP_001": {
        "ID": "CP_160_STAMP_001",
        "Text": "Wespentod!"
      },
      "CP_051_STAMP_001": {
        "ID": "CP_051_STAMP_001",
        "Text": "Weinst du?"
      },
      "CP_051_STAMP_002": {
        "ID": "CP_051_STAMP_002",
        "Text": "Im Himmel und auf Erden bin einzig ich erhaben."
      },
      "CP_121_STAMP_001": {
        "ID": "CP_121_STAMP_001",
        "Text": "Den Schwachen helfen, die Starken einschüchtern."
      },
      "CP_121_STAMP_002": {
        "ID": "CP_121_STAMP_002",
        "Text": "Wir sind die Stärksten."
      },
      "CP_170_STAMP_001": {
        "ID": "CP_170_STAMP_001",
        "Text": "Ein Glückstreffer!"
      },
      "CP_170_STAMP_002": {
        "ID": "CP_170_STAMP_002",
        "Text": "Immer denkst du nur an dich!"
      },
      "CP_170_STAMP_003": {
        "ID": "CP_170_STAMP_003",
        "Text": "Oh Junge, armes Ding ..."
      },
      "CP_180_STAMP_001": {
        "ID": "CP_180_STAMP_001",
        "Text": "Ich werde mich darum kümmern! Auf meine süße Art."
      },
      "CP_180_STAMP_002": {
        "ID": "CP_180_STAMP_002",
        "Text": "Überhaupt nicht süß ..."
      },
      "CP_190_STAMP_001": {
        "ID": "CP_190_STAMP_001",
        "Text": "Ich kann nicht verlieren. Ich weigere mich einfach."
      },
      "CP_190_STAMP_002": {
        "ID": "CP_190_STAMP_002",
        "Text": "Diese Entscheidung habe ich selbst getroffen."
      },
      "CP_200_STAMP_001": {
        "ID": "CP_200_STAMP_001",
        "Text": "Dein Job ist erledigt. Also zisch ab, los."
      },
      "CP_200_STAMP_002": {
        "ID": "CP_200_STAMP_002",
        "Text": "Es geht doch gerade erst los."
      },
      "CP_210_STAMP_001": {
        "ID": "CP_210_STAMP_001",
        "Text": "Können wir uns nicht alle vertragen?"
      },
      "CP_210_STAMP_002": {
        "ID": "CP_210_STAMP_002",
        "Text": "Hallo! Die nutzlose Miwa hier!"
      },
      "CP_220_STAMP_001": {
        "ID": "CP_220_STAMP_001",
        "Text": "Bann des Himmels. Schon davon gehört?"
      },
      "CP_220_STAMP_002": {
        "ID": "CP_220_STAMP_002",
        "Text": "Bist du tot ...?"
      },
      "CP_230_STAMP_001": {
        "ID": "CP_230_STAMP_001",
        "Text": "Ich werde mit all meiner Kraft meiner Pflicht als ihr Bruder nachkommen!"
      },
      "CP_230_STAMP_002": {
        "ID": "CP_230_STAMP_002",
        "Text": "Ich bin Yujis großer Bruder!"
      },
      "CP_240_STAMP_001": {
        "ID": "CP_240_STAMP_001",
        "Text": "Tu mir doch den Gefallen und stirb, ja?"
      },
      "CP_240_STAMP_002": {
        "ID": "CP_240_STAMP_002",
        "Text": "Selbstverständlich stehe ich auf der Seite des Geldes."
      },
      "CP_270_STAMP_001": {
        "ID": "CP_270_STAMP_001",
        "Text": "Das lasse ich nicht zu."
      },
      "CP_270_STAMP_002": {
        "ID": "CP_270_STAMP_002",
        "Text": "Das wirst du bereuen."
      }
    }
  }
]