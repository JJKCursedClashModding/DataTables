      "CP_230_UNIQUE_4": {
        "ID": "CP_230_UNIQUE_4",
        "Text": "Ich atme immer noch."
      },
      "CP_230_UNIQUE_5": {
        "ID": "CP_230_UNIQUE_5",
        "Text": "Gibt es einen Grund, um mein Leben nicht für meinen Bruder zu riskieren?"
      },
      "CP_230_UNIQUE_6": {
        "ID": "CP_230_UNIQUE_6",
        "Text": "Aus dem Weg! Ich bin ihr großer Bruder!"
      },
      "CP_230_UNIQUE_7": {
        "ID": "CP_230_UNIQUE_7",
        "Text": "Ich werde mit all meiner Kraft meiner Pflicht als ihr Bruder nachkommen!"
      },
      "CP_230_UNIQUE_8": {
        "ID": "CP_230_UNIQUE_8",
        "Text": "So ein Idiot könnte die beiden nicht besiegen."
      },
      "CP_230_UNIQUE_9": {
        "ID": "CP_230_UNIQUE_9",
        "Text": "Nenn mich doch mal \"großer Bruder\". Nur ein Mal."
      },
      "CP_230_UNIQUE_10": {
        "ID": "CP_230_UNIQUE_10",
        "Text": "Das ist nicht wahr! Ich bin Yujis großer Bruder!"
      },
      "CP_230_UNIQUE_11": {
        "ID": "CP_230_UNIQUE_11",
        "Text": "Eso! Kechizu! Seht zu!\nSeht, was euer großer Bruder draufhat!"
      },
      "CP_230_UNIQUE_12": {
        "ID": "CP_230_UNIQUE_12",
        "Text": "Das ist die letzte Möglichkeit, um zu gewinnen."
